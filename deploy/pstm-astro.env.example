# ─────────────────────────────────────────────────────────────────────────────
# PSTM Astro backend — environment template
#
# On the VPS this lives at /etc/pstm-astro.env (chmod 600, owned by the service
# user). It is loaded by BOTH systemd units (pstm-astro + pstm-worker).
# NEVER commit the real, filled-in version. Copy this file, fill it, deploy it
# out-of-band (scp / secret manager), and keep it off git.
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime ---
HOST=127.0.0.1
PORT=4321
NODE_ENV=production

# --- Database (Supabase DIRECT connection, port 5432 — NOT the Supavisor pooler) ---
# Project Settings → Database → Connection string → "Direct connection".
# The VPS connects straight to Postgres; Workers go through Hyperdrive instead.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- Redis (local on the VPS, used by BullMQ; activated in Phase A3) ---
# Bind to 127.0.0.1, set requirepass, enable AOF. See VPS_SETUP.md.
REDIS_URL=redis://:REDIS_PASSWORD@127.0.0.1:6379

# --- CORS for /api/public/* (cross-origin callers, e.g. the live root site) ---
# Comma-separated allow-list of origins. Same-origin (app.<domain>) works without
# this; only set it if another origin embeds the public quote form. Leave empty
# to emit no cross-origin headers. NOTE: read server-side only — the PUBLIC_ prefix
# is Astro's client-exposure convention but we read it via process.env, so it is
# NOT shipped to the browser.
PUBLIC_ALLOWED_ORIGINS=https://app.your-domain.com,https://your-domain.com

# --- Server-to-server auth (tool → VPS /api/internal/*) ---
# Shared HMAC secret. The internal tool (Repo B) mints short-lived JWTs with the
# SAME secret; the VPS verifies them. Generate: openssl rand -hex 32
INTERNAL_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# --- SMTP (Google Workspace) — used by the pstm-worker email job ONLY (Phase A3) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=GOOGLE_APP_PASSWORD
SMTP_FROM="PSTM <no-reply@your-domain.com>"

# --- PDF pipeline (Phase A3) — worker only ---
# Optional: override the DOCX quotation template path. Defaults to
# <app>/templates/quotation.docx. LibreOffice (soffice) must be installed.
# PDF_TEMPLATE_PATH=/var/www/pstm/astro-web/templates/quotation.docx

# --- Cloudflare R2 (PDF / Excel output storage; Phase A3) ---
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=pstm-files
# S3-compatible endpoint, e.g. https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
# Public base URL for serving files (R2 custom domain or public bucket URL)
R2_PUBLIC_BASE_URL=https://files.your-domain.com

# --- Legacy calc backend (Render) — keep until Python calc is ported (gap 7.12) ---
PUBLIC_API_URL=https://kb-vertex-by-pst-1.onrender.com
