                  CALL +91 9819153834
                </a>
                <a href="/quote" class={`flex w-full items-center justify-center gap-2 rounded-sm py-4 text-sm font-bold uppercase tracking-widest shadow-md transition-colors ${pathname === '/quote' ? 'bg-emerald-500 text-[#050f09]' : 'bg-white text-[#050f09] active:bg-zinc-200'}`}>
