---
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = "Vertex by Primesteeltech" } = Astro.props;

// Get the current URL path to determine which link should be active (green)
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- LOCAL BUSINESS SCHEMA FOR AI & GOOGLE -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Prime Steeltech India Pvt Ltd",
      "image": "https://www.yourdomain.com/favicon.svg",
      "description": "Premium manufacturer of BIS-approved Ringlock scaffolding, Cuplock scaffolding, formwork, and heavy-duty structural materials, Staricase Towers, Anti Skid Walkway Planks.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mumbai", 
        "addressRegion": "Maharashtra",
        "addressCountry": "IN"
      },
      "url": "https://www.yourdomain.com",
      "telephone": "+91-9819153834",
      "priceRange": "$"
    }
    </script>
  </head>
  <body class="bg-[#050f09] text-white font-jakarta antialiased selection:bg-emerald-500 selection:text-[#050f09] relative">
    
    <header class="relative z-50 w-full flex flex-col shadow-[0_10px_40px_rgba(0,0,0,0.3)] transition-all duration-300">
      
      <div class="hidden lg:flex w-full bg-[#050f09] border-b border-white/5 relative z-20">
