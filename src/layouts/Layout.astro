                  <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500 border-2 border-[#050f09]"></span>
                </span>
                <svg class="w-3.5 h-3.5 xl:w-4 xl:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
