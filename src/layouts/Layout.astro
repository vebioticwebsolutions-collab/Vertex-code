                <svg class={`h-3.5 w-3.5 transform group-hover:rotate-180 transition-transform duration-200 ${pathname.startsWith('/products') ? 'text-emerald-400' : 'text-emerald-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              
              <div class="absolute top-[80%] left-1/2 -translate-x-1/2 pt-4 w-64 origin-top opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 z-50">
                <div class="rounded-sm bg-[#0a170e]/95 backdrop-blur-md p-3 shadow-[0_15px_40px_rgba(0,0,0,0.5)] ring-1 ring-white/10 text-center flex flex-col gap-2 border-t-4 border-emerald-500">
                  <a href="/products/ringlock-scaffolding" class={`block rounded-sm px-4 py-3 text-[11px] font-bold uppercase tracking-widest transition-colors ${pathname === '/products/ringlock-scaffolding' ? 'bg-emerald-500/20 text-emerald-400' : 'text-zinc-300 hover:bg-emerald-500/10 hover:text-white'}`}>RINGLOCK SCAFFOLDING</a>
                  <a href="/products/staircase-tower" class={`block rounded-sm px-4 py-3 text-[11px] font-bold uppercase tracking-widest transition-colors ${pathname === '/products/staircase-tower' ? 'bg-emerald-500/20 text-emerald-400' : 'text-zinc-300 hover:bg-emerald-500/10 hover:text-white'}`}>STAIRCASE TOWERS</a>
                  <a href="/products/walkway-planks" class={`block rounded-sm px-4 py-3 text-[11px] font-bold uppercase tracking-widest transition-colors ${pathname === '/products/walkway-planks' ? 'bg-emerald-500/20 text-emerald-400' : 'text-zinc-300 hover:bg-emerald-500/10 hover:text-white'}`}>WALKWAY PLANKS</a>
                </div>
              </div>
            </div>

            <a href="/rentals" class={`text-xs font-bold tracking-widest uppercase transition-colors flex items-center gap-1.5 ${pathname.startsWith('/rentals') ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>
              RENTALS
              <span class="px-1.5 py-0.5 rounded-[2px] bg-emerald-500/20 text-[9px] text-emerald-400 tracking-wider">NEW</span>
            </a>

            <a href="/our-projects" class={`text-xs font-bold tracking-widest uppercase transition-colors ${pathname.startsWith('/our-projects') ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>OUR PROJECTS</a>
            <a href="/about" class={`text-xs font-bold tracking-widest uppercase transition-colors ${pathname.startsWith('/about') ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>ABOUT</a>
            
            <div class="flex items-center gap-4 xl:gap-5 ml-2 xl:ml-4 pl-4 xl:pl-6 border-l border-white/10">
              <a href="tel:+919819153834" class="inline-flex items-center justify-center rounded-sm bg-transparent text-xs font-bold uppercase tracking-widest text-zinc-300 hover:text-emerald-400 transition-colors" aria-label="Call Us">
