            <a href="/products/walkway-planks" class={`text-xs font-bold uppercase tracking-widest py-1 ${pathname === '/products/walkway-planks' ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>WALKWAY PLANKS</a>
          </div>

