                <div class="relative group py-6">
                  <a href="/products" class={`flex items-center gap-1.5 text-xs font-bold tracking-widest uppercase transition-colors focus:outline-none pb-1 ${pathname.startsWith('/products') ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>
                    PRODUCTS
                    <svg class={`h-3.5 w-3.5 transform group-hover:rotate-180 transition-transform duration-200 ${pathname.startsWith('/products') ? 'text-emerald-400' : 'text-emerald-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                  </a>
                  
                  <div class="absolute top-[80%] left-1/2 -translate-x-1/2 pt-4 w-64 origin-top opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 z-50">
                    <div class="rounded-sm bg-[#0a170e]/95 backdrop-blur-md p-3 shadow-2xl ring-1 ring-white/10 text-center flex flex-col gap-2 border-t-4 border-emerald-500">
                      <a href="/products/ringlock-scaffolding" class={`block rounded-sm px-4 py-3 text-[11px] font-bold uppercase tracking-widest transition-colors ${pathname === '/products/ringlock-scaffolding' ? 'bg-emerald-500/20 text-emerald-400' : 'text-zinc-300 hover:bg-emerald-500/10 hover:text-white'}`}>RINGLOCK SCAFFOLDING</a>
                      <a href="/products/staircase-tower" class={`block rounded-sm px-4 py-3 text-[11px] font-bold uppercase tracking-widest transition-colors ${pathname === '/products/staircase-tower' ? 'bg-emerald-500/20 text-emerald-400' : 'text-zinc-300 hover:bg-emerald-500/10 hover:text-white'}`}>STAIRCASE TOWERS</a>
                      <a href="/products/walkway-planks" class={`block rounded-sm px-4 py-3 text-[11px] font-bold uppercase tracking-widest transition-colors ${pathname === '/products/walkway-planks' ? 'bg-emerald-500/20 text-emerald-400' : 'text-zinc-300 hover:bg-emerald-500/10 hover:text-white'}`}>WALKWAY PLANKS</a>
                    </div>
                  </div>
                </div>

                <a href="/about" class={`text-xs font-bold tracking-widest uppercase transition-colors ${pathname.startsWith('/about') ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>ABOUT</a>
                <a href="/blogs" class={`text-xs font-bold tracking-widest uppercase transition-colors ${pathname.startsWith('/blogs') ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>BLOGS</a>
                
                <div class="flex items-center gap-4 ml-2 pl-6 border-l border-white/10">
                  <a href="tel:+919819153834" class="inline-flex items-center justify-center gap-2 rounded-sm border border-emerald-500/50 bg-emerald-500/10 px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-emerald-400 hover:bg-emerald-500 hover:text-[#050f09] transition-all duration-300">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    CALL US
                  </a>
                  <a href="/quote" class={`inline-flex items-center justify-center gap-2 rounded-sm px-6 py-2.5 text-xs font-bold uppercase tracking-widest transition-all duration-300 ${pathname === '/quote' ? 'bg-emerald-500 text-[#050f09] shadow-[0_0_20px_rgba(52,211,153,0.4)]' : 'bg-white text-[#050f09] shadow-[0_0_15px_rgba(255,255,255,0.1)] hover:bg-emerald-400 hover:shadow-[0_0_20px_rgba(52,211,153,0.4)]'}`}>
                    <span class="relative flex h-2 w-2">
                      <span class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${pathname === '/quote' ? 'bg-[#050f09]' : 'bg-red-400'}`}></span>
                      <span class={`relative inline-flex rounded-full h-2 w-2 ${pathname === '/quote' ? 'bg-[#050f09]' : 'bg-red-600'}`}></span>
                    </span>
                    LIVE QUOTE
