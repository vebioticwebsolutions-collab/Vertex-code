                <a href="/products" class={`text-[10px] font-bold uppercase tracking-[0.2em] transition-colors ${pathname === '/products' ? 'text-emerald-400' : 'text-zinc-500 hover:text-emerald-400'}`}>PRODUCTS CATALOG</a>
                <a href="/products/ringlock-scaffolding" class={`text-xs font-bold uppercase tracking-widest py-1 ${pathname === '/products/ringlock-scaffolding' ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>RINGLOCK SCAFFOLDING</a>
                <a href="/products/staircase-tower" class={`text-xs font-bold uppercase tracking-widest py-1 ${pathname === '/products/staircase-tower' ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>STAIRCASE TOWERS</a>
                <a href="/products/walkway-planks" class={`text-xs font-bold uppercase tracking-widest py-1 ${pathname === '/products/walkway-planks' ? 'text-emerald-400' : 'text-zinc-300 hover:text-white'}`}>WALKWAY PLANKS</a>
