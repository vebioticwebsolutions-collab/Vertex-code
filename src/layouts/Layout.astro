              </a>

              <a href="#" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-emerald-400 transition-colors" aria-label="Facebook">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
              </a>

            </div>
          </div>

          <!-- ==========================================
               MAIN NAVIGATION (Untouched Layout)
               ========================================== -->
          <div class="w-full bg-[#0a170e]/80 backdrop-blur-lg border-b border-emerald-500/10">
            <div class="mx-auto flex max-w-7xl h-20 items-center justify-between px-4 sm:px-6 lg:px-8">
              
              <div class="flex items-center">
                <a href="/" class="group flex flex-col text-left">
                  <span class="text-xl sm:text-2xl font-black tracking-[0.15em] text-white uppercase group-hover:text-emerald-400 transition-colors">
                    VERTEX
                  </span>
                  <span class="text-[9px] sm:text-[10px] font-bold tracking-[0.2em] text-emerald-500 uppercase -mt-1">
