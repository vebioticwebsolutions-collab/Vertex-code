              <button id="mobile-menu-btn" class="flex lg:hidden rounded-sm p-2 text-zinc-300 hover:bg-white/5 hover:text-white focus:outline-none transition-colors" aria-label="Toggle Menu">
                <svg id="menu-icon-open" class="h-7 w-7 block" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
                <svg id="menu-icon-close" class="h-7 w-7 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
