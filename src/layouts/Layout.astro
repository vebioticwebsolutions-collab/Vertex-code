---
import '../styles/global.css';

export interface Props {
    title?: string;
}

const { title = "Vertex by Primesteeltech" } = Astro.props;

// Get the current URL path to determine which link should be active (green)
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="bg-[#050f09] text-white font-jakarta antialiased selection:bg-emerald-500 selection:text-[#050f09] relative">
        
        <header class="relative z-50 w-full flex flex-col shadow-[0_4px_30px_rgba(0,0,0,0.1)] transition-all duration-300">
          
          <!-- ==========================================
               TOP SOCIAL BAR (New Addition)
               ========================================== -->
          <div class="hidden lg:flex w-full bg-[#050f09] border-b border-white/5">
            <div class="mx-auto flex w-full max-w-7xl h-10 items-center justify-end px-4 sm:px-6 lg:px-8 gap-5">
              
              <span class="text-[9px] font-bold tracking-[0.2em] text-zinc-500 uppercase mr-2 border-r border-white/10 pr-5">Follow Us</span>
              
              <a href="#" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-emerald-400 transition-colors" aria-label="LinkedIn">
