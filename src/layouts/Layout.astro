              </div>

              <!-- Mobile Social Icons -->
              <div class="flex items-center justify-center gap-6 mt-2 pt-6 border-t border-white/5">
                <a href="#" class="text-zinc-500 hover:text-emerald-400 transition-colors" aria-label="LinkedIn"><svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.849-3.037-1.85 0-2.133 1.448-2.133 2.94v5.666H9.356V9h3.414v1.566h.049c.475-.9 1.636-1.85 3.367-1.85 3.595 0 4.26 2.366 4.26 5.443v6.293zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.063 2.063 2.063 0 0 1 2.063-2.063 2.063 2.063 0 0 1 2.063 2.063 2.062 2.062 0 0 1-2.063 2.063zm1.777 13.019H3.56V9h3.554v11.452zM22.225 0H1.77C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.77 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
                <a href="#" class="text-zinc-500 hover:text-emerald-400 transition-colors" aria-label="X (Twitter)"><svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg></a>
                <a href="#" class="text-zinc-500 hover:text-emerald-400 transition-colors" aria-label="YouTube"><svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
                <a href="#" class="text-zinc-500 hover:text-emerald-400 transition-colors" aria-label="Instagram"><svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.059 3.252.148 4.771 1.691 4.919 4.919.047 1.266.058 1.646.058 4.859s-.011 3.593-.058 4.859c-.148 3.227-1.668 4.771-4.919 4.919-1.266.047-1.646.059-4.85.059s-3.584-.012-4.85-.059c-3.252-.148-4.771-1.691-4.919-4.919-.047-1.266-.058-1.646-.058-4.859s.011-3.593.058-4.859c.148-3.227 1.668-4.771 4.919-4.919 1.266-.047 1.646-.059 4.85-.059zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948s.014 3.667.072 4.947c.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.947.072s3.668-.014 4.948-.072c4.358-.2 6.78-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.2-4.358-2.618-6.78-6.979-6.98-1.28-.058-1.689-.072-4.948-.072zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
                <a href="#" class="text-zinc-500 hover:text-emerald-400 transition-colors" aria-label="Facebook"><svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg></a>
              </div>

            </div>
          </div>
        </header>

        <slot />

        <footer class="bg-[#0a170e] border-t border-emerald-500/10 pt-16 pb-8 text-zinc-400 relative z-10">
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
              <div>
                <span class="text-2xl font-black tracking-wider text-white uppercase block mb-1">VERTEX</span>
                <span class="text-[10px] font-bold tracking-widest text-emerald-400 uppercase">BY PRIMESTEELTECH</span>
                <p class="font-jakarta mt-6 text-sm leading-relaxed max-w-sm">
                  Engineering high-capacity staircase towers, heavy-duty walkway planks, and advanced ringlock scaffolding for the modern infrastructure frontier.
                </p>
              </div>
              <div>
                <h4 class="text-white font-bold uppercase tracking-wider mb-6">Core Navigation</h4>
                <ul class="space-y-3 font-jakarta text-sm">
                  <li><a href="/" class="hover:text-emerald-400 transition-colors">Home</a></li>
                  <li><a href="/about" class="hover:text-emerald-400 transition-colors">About</a></li>
