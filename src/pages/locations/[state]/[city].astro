---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { locations } from '../../../data/locations.js';

// ==========================================
// IMAGE IMPORTS (Reusing your high-quality assets)
// ==========================================
import img3_1 from '../../../assets/home-page/3-1.jpeg'; 
import img3_2 from '../../../assets/home-page/3-2.jpeg';
import img4_1 from '../../../assets/home-page/4-1.jpeg';
import img4_2 from '../../../assets/home-page/4-2.jpeg';
import img4_3 from '../../../assets/home-page/4-3.jpg';
import img4_4 from '../../../assets/home-page/4-4.jpg';
import img6_1 from '../../../assets/home-page/6-1.jpg';
import img6_2 from '../../../assets/home-page/6-2.jpg';
import img6_3 from '../../../assets/home-page/6-3.jpg';
import img6_4 from '../../../assets/home-page/6-4 option 1.jpg'; 

// ==========================================
// DYNAMIC ROUTE GENERATOR
// ==========================================
export function getStaticPaths() {
  return locations.map((loc) => {
    return {
      params: { state: loc.state, city: loc.slug },
      props: { locationData: loc },
    };
  });
}

const { locationData } = Astro.props;

// Formatting helpers for SEO text
const cityName = locationData.name;
const regionName = locationData.region;
const pinCodeText = locationData.pin ? ` (PIN: ${locationData.pin})` : '';
const stateName = locationData.state.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase());
---

<Layout title={`Scaffolding Manufacturer in ${cityName} | Vertex by Primesteeltech`}>
  
  <main class="bg-[#050f09] text-white overflow-hidden">
    
    <section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 border-b border-emerald-500/10 text-center z-10">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#10b98105_1px,transparent_1px),linear-gradient(to_bottom,#10b98105_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[1000px] h-[400px] bg-emerald-500/20 blur-[130px] rounded-full pointer-events-none"></div>

      <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-col items-center">
        
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_20px_rgba(16,185,129,0.15)] backdrop-blur-sm">
          <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 animate-pulse"></span>
          <span>Industrial Supplier for {cityName} {pinCodeText}</span>
        </div>

        <h1 class="text-3xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl uppercase leading-[1.15] max-w-4xl mb-6">
          Premium Scaffolding & <br class="hidden sm:inline"/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-500">Walkway Planks in {cityName}</span>
        </h1>

        <p class="font-jakarta text-sm sm:text-base lg:text-lg leading-relaxed text-zinc-300 max-w-3xl font-medium mb-10">
          Vertex by Primesteeltech provides elite, BIS-approved structural engineering materials directly to mega-infrastructure and commercial sites across <strong>{cityName}</strong> and the greater <strong>{regionName}</strong> corridor.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-5 w-full sm:w-auto">
          <a href="/find-us" class="w-full sm:w-auto inline-flex h-14 min-w-[220px] items-center justify-center rounded-sm border border-emerald-500/30 bg-[#0a170e] px-8 text-sm font-bold text-emerald-400 hover:bg-emerald-500/10 transition-all uppercase tracking-widest gap-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            View All Locations
          </a>
          <a href="/quote" class="w-full sm:w-auto inline-flex h-14 min-w-[220px] items-center justify-center rounded-sm bg-emerald-500 px-8 text-sm font-extrabold text-[#050f09] shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:bg-emerald-400 transition-all uppercase tracking-widest">
            Quote for {cityName} &rarr;
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 border-b border-emerald-500/10 relative bg-[#0a170e]">
      <div class="absolute right-0 top-0 w-1/3 h-full bg-emerald-500/5 blur-[100px] pointer-events-none"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          
          <div class="order-2 lg:order-1 relative">
            <div class="absolute inset-0 bg-emerald-500/20 blur-3xl rounded-full transform -translate-x-10 translate-y-10"></div>
            <div class="relative w-full h-[400px] sm:h-[450px]">
              <div class="absolute top-0 left-0 w-3/4 h-[300px] sm:h-[350px] border border-emerald-500/20 rounded-sm overflow-hidden shadow-[0_0_40px_rgba(16,185,129,0.15)] z-10">
                <Image src={img3_1} alt={`Scaffolding Supply in ${cityName}`} class="w-full h-full object-cover" />
              </div>
              <div class="absolute bottom-0 right-0 w-2/3 h-[200px] sm:h-[250px] border border-emerald-500/30 rounded-sm overflow-hidden shadow-2xl z-20">
                <Image src={img3_2} alt={`Industrial Construction in ${regionName}`} class="w-full h-full object-cover" />
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center gap-2 mb-4">
              <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 px-3 py-1 rounded-sm border border-emerald-500/20">Direct Logistics Routing</span>
            </div>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white uppercase tracking-tight mb-6 leading-tight">
              Rapid Deployment to <span class="text-emerald-400">{cityName}</span> Sites
            </h2>
            <div class="space-y-6 font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium">
              <p>
                As a leading force under Primesteeltech, Vertex has established dedicated logistics channels ensuring our premium formwork and scaffolding arrays reach industrial and commercial sites in <strong>{cityName}</strong> with minimal lead times.
              </p>
              <p>
                We understand that delays in material procurement translate directly to lost capital. Our supply chain is optimized to bypass traditional bottlenecks, delivering high-tensile, OSHA-compliant structural nodes straight to your project in the {regionName} sector.
              </p>
            </div>
            
            <ul class="mt-8 space-y-4 font-jakarta text-sm">
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-zinc-200"><strong class="text-white">Priority Freight:</strong> Direct routes established for {cityName} deliveries.</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-zinc-200"><strong class="text-white">Volume Capacity:</strong> Capable of supplying mega-projects in {stateName}.</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-16">
          <div>
            <div class="inline-flex items-center justify-center bg-emerald-500/10 border border-emerald-500/30 px-3 py-1.5 rounded-full mb-4">
              <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">Premium System Engineering</span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-6 leading-tight">
              Best Quality <span class="text-emerald-400">Ringlock Systems</span> in {cityName}
            </h2>
            <div class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium space-y-4">
              <p>
                Contractors operating in <strong>{cityName}</strong> require materials that perform relentlessly under extreme site conditions. Our flagship Ringlock Scaffolding is forged from top-tier BIS-approved steel.
              </p>
              <p>
                The advanced multi-directional rosette node design provides unparalleled structural rigidity, securing maximum safety for workers at high elevations while significantly reducing erection time compared to traditional cuplock arrays.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4 sm:gap-6 relative">
             <div class="absolute inset-0 bg-emerald-500/20 blur-3xl rounded-full"></div>
             <Image src={img4_1} class="w-full h-56 sm:h-72 object-cover rounded-md border-2 border-emerald-400 shadow-[0_0_25px_rgba(16,185,129,0.3)] relative z-10" alt={`Ringlock Scaffolding ${cityName}`} />
             <Image src={img4_2} class="w-full h-56 sm:h-72 object-cover rounded-md border-2 border-emerald-400 shadow-[0_0_25px_rgba(16,185,129,0.3)] relative z-10 transform translate-y-6 sm:translate-y-8" alt="Industrial Ringlock Nodes" />
          </div>
        </div>

        <div class="bg-[#0a170e] border border-emerald-500/20 rounded-sm p-8 sm:p-12 shadow-[0_0_40px_rgba(16,185,129,0.05)] relative overflow-hidden mt-12 sm:mt-24">
           <div class="absolute right-0 top-0 w-64 h-64 bg-emerald-500/5 blur-[80px] pointer-events-none"></div>
           
           <h3 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight mb-10 relative z-10">
             Top-Tier <span class="text-emerald-400">Staircase Towers & Walkway Planks</span> for {regionName}
           </h3>

           <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 relative z-10">
             <div class="flex flex-col sm:flex-row gap-6 items-start group">
                <div class="w-full sm:w-40 h-40 shrink-0 rounded-sm overflow-hidden border border-emerald-500/20 relative">
                  <Image src={img4_3} class="w-full h-full object-cover transform group-hover:scale-110 transition-duration-500" alt="Scaffolding Staircase Towers" />
                </div>
                <div>
                  <h4 class="text-white font-bold uppercase tracking-wider mb-2 text-sm">Industrial Staircase Towers</h4>
                  <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
                    Engineered for high-volume worker egress on {cityName} job sites. Our modular towers feature interlocking stringers and wide landings for absolute vertical safety.
                  </p>
                </div>
             </div>

             <div class="flex flex-col sm:flex-row gap-6 items-start group">
                <div class="w-full sm:w-40 h-40 shrink-0 rounded-sm overflow-hidden border border-emerald-500/20 relative">
                  <Image src={img4_4} class="w-full h-full object-cover transform group-hover:scale-110 transition-duration-500" alt="Steel Walkway Planks" />
                </div>
                <div>
                  <h4 class="text-white font-bold uppercase tracking-wider mb-2 text-sm">High-Traction Planks</h4>
                  <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
                    Manufactured with a punched-matrix surface for anti-slip performance. Highly resistant to bending or sagging under heavy material loads.
                  </p>
                </div>
             </div>
           </div>
        </div>

      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-4">
            Why Contractors in <span class="text-emerald-400">{cityName}</span> Choose Vertex
          </h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full shadow-[0_0_10px_rgba(16,185,129,0.8)]"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div class="p-8 border border-white/5 bg-[#050f09] rounded-sm hover:border-emerald-500/30 transition-colors shadow-sm">
            <div class="w-12 h-12 mx-auto bg-emerald-500/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-3">Weather Resilient</h3>
            <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
              Industrial sites in the {regionName} belt face harsh environmental factors. Our hot-dip galvanized steel prevents rapid oxidation and rust.
            </p>
          </div>

          <div class="p-8 border border-white/5 bg-[#050f09] rounded-sm hover:border-emerald-500/30 transition-colors shadow-sm">
            <div class="w-12 h-12 mx-auto bg-emerald-500/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-3">Safety & Compliance</h3>
            <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
              Every plank, node, and tower manufactured for the {cityName} market undergoes rigorous load-testing to ensure 100% OSHA and BIS compliance.
            </p>
          </div>

          <div class="p-8 border border-white/5 bg-[#050f09] rounded-sm hover:border-emerald-500/30 transition-colors shadow-sm">
            <div class="w-12 h-12 mx-auto bg-emerald-500/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-3">Inventory Capacity</h3>
            <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
              Our massive central manufacturing hub means we can scale and deploy equipment for massive infrastructure projects in {stateName} without delay.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-4">
            Engineered for <span class="text-emerald-400">{cityName}'s</span> Industries
          </h2>
          <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium">
            From towering commercial skyscrapers to heavy civil infrastructure, our modular systems are deployed in the most demanding sectors.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-[#0a170e] border border-white/5 rounded-sm overflow-hidden hover:border-emerald-500/40 transition-all duration-300 group flex flex-col shadow-lg">
            <div class="h-48 overflow-hidden relative">
              <Image src={img6_1} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" alt="High-Rise Scaffolding" />
            </div>
            <div class="p-5 flex flex-col flex-grow relative">
              <h3 class="text-white font-black uppercase tracking-wider text-sm mb-2 group-hover:text-emerald-400 transition-colors">Commercial Towers</h3>
              <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Extreme elevation load-bearing systems ensuring worker safety at high altitudes.</p>
            </div>
          </div>

          <div class="bg-[#0a170e] border border-white/5 rounded-sm overflow-hidden hover:border-emerald-500/40 transition-all duration-300 group flex flex-col shadow-lg">
            <div class="h-48 overflow-hidden relative">
              <Image src={img6_2} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" alt="Bridge Infrastructure Scaffolding" />
            </div>
            <div class="p-5 flex flex-col flex-grow relative">
              <h3 class="text-white font-black uppercase tracking-wider text-sm mb-2 group-hover:text-emerald-400 transition-colors">Infrastructure</h3>
              <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Suspended and ground-up structural support for heavy civil engineering works.</p>
            </div>
          </div>

          <div class="bg-[#0a170e] border border-white/5 rounded-sm overflow-hidden hover:border-emerald-500/40 transition-all duration-300 group flex flex-col shadow-lg">
            <div class="h-48 overflow-hidden relative">
              <Image src={img6_3} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" alt="Industrial Refinery Scaffolding" />
            </div>
            <div class="p-5 flex flex-col flex-grow relative">
              <h3 class="text-white font-black uppercase tracking-wider text-sm mb-2 group-hover:text-emerald-400 transition-colors">Refineries & Industrial</h3>
              <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Complex, multi-directional access solutions built to navigate dense piping networks.</p>
            </div>
          </div>

          <div class="bg-[#0a170e] border border-white/5 rounded-sm overflow-hidden hover:border-emerald-500/40 transition-all duration-300 group flex flex-col shadow-lg">
            <div class="h-48 overflow-hidden relative">
              <Image src={img6_4} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" alt="Architectural Building Scaffolding" />
            </div>
            <div class="p-5 flex flex-col flex-grow relative">
              <h3 class="text-white font-black uppercase tracking-wider text-sm mb-2 group-hover:text-emerald-400 transition-colors">Architectural</h3>
              <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Clean, precise, and highly adaptable ringlock arrays for unique structural facades.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] text-center relative overflow-hidden z-10">
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-2xl h-40 bg-emerald-500/10 blur-[100px] rounded-full pointer-events-none z-0"></div>

      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative z-10">
        <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-4">
          Secure Materials for Your <span class="text-emerald-400">{cityName}</span> Project
        </h2>
        <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-10 max-w-xl mx-auto font-medium">
          Access factory-direct pricing and rapid dispatch schedules tailored for the {regionName} corridor.
        </p>
        
        <a href="/quote" class="w-full sm:w-auto inline-flex h-14 items-center justify-center rounded-sm bg-emerald-500 px-10 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-colors shadow-[0_0_20px_rgba(16,185,129,0.3)]">
          Calculate Exact Quote &rarr;
        </a>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
</style>