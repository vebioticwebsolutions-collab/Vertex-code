---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Product images for the selection step
import ringlockImg from '../assets/products/Ringlock product.jpg';
import plankImg from '../assets/products/walkway plank.jpg';
import towerImg from '../assets/products/staircase tower product.jpg';
---

<Layout title="Live Quote Engine | Vertex by Primesteeltech">
  <main class="bg-[#050f09] min-h-screen pt-24 pb-16 flex items-center justify-center relative overflow-hidden">
    
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none z-0"></div>

    <div class="w-full max-w-4xl px-4 sm:px-6 relative z-10">
      
      <div class="mb-8 max-w-2xl mx-auto">
        <div class="flex justify-between mb-3">
          <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 px-3 py-1 rounded-full border border-emerald-500/20" id="step-indicator">Step 1 of 6</span>
          <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mt-1" id="step-title">Introduction</span>
        </div>
        <div class="w-full h-2 bg-[#0a170e] rounded-full overflow-hidden border border-white/5 relative">
          <div id="progress-bar" class="absolute top-0 left-0 h-full bg-emerald-500 w-1/6 transition-all duration-700 ease-out shadow-[0_0_15px_rgba(16,185,129,0.8)]"></div>
        </div>
      </div>

      <div class="bg-[#08120b] backdrop-blur-2xl border border-white/5 rounded-xl shadow-[0_0_50px_rgba(0,0,0,0.5)] relative overflow-hidden max-w-3xl mx-auto">
        
        <div id="step-1" class="form-step p-8 sm:p-12 text-center transition-opacity duration-500">
          <div class="w-20 h-20 mx-auto bg-[#050f09] border border-emerald-500/30 rounded-2xl flex items-center justify-center mb-8 shadow-[inset_0_0_20px_rgba(16,185,129,0.1)] transform rotate-3">
            <svg class="w-10 h-10 text-emerald-400 -rotate-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Live Quote <span class="text-emerald-400">Engine</span></h1>
          <p class="font-jakarta text-zinc-400 text-sm sm:text-base leading-relaxed mb-10 max-w-md mx-auto">
            Bypass the middlemen. Our proprietary engine connects your project requirements directly to our manufacturing database, generating accurate logistics and material pricing in real-time.
          </p>
          
          <button onclick="nextStep(2, 'Business Details')" class="w-full sm:w-auto inline-flex h-14 items-center justify-center rounded-sm bg-emerald-500 px-12 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] hover:-translate-y-1">
            Start Configuration &rarr;
          </button>
        </div>

        <div id="step-2" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Business <span class="text-emerald-400">Details</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Enter your organizational details to register your quote file.</p>
          
          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Full Name *</label>
                <input type="text" id="entry-name" placeholder="John Doe" class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Company Name *</label>
                <input type="text" id="entry-company" placeholder="BuildCorp India Ltd." class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
              </div>
            </div>
            
            <div>
              <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">GSTIN (Optional)</label>
              <input type="text" id="entry-gstin" placeholder="27XXXXX1234X1XX" class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors uppercase" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Email Address *</label>
                <input type="email" id="entry-email" placeholder="john@buildcorp.in" class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Mobile Number *</label>
                <div class="flex">
                  <span class="inline-flex items-center px-4 bg-white/5 border border-r-0 border-white/10 rounded-l-sm text-zinc-400 text-sm font-jakarta border-r-transparent">+91</span>
                  <input type="tel" id="entry-mobile" placeholder="98765 43210" class="w-full bg-[#050f09] border border-white/10 rounded-r-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
                </div>
              </div>
            </div>
          </div>

          <div class="mt-10 flex gap-4 pt-6 border-t border-white/5">
            <button onclick="nextStep(1, 'Introduction')" class="hidden sm:flex h-14 items-center justify-center rounded-sm border border-white/10 bg-transparent px-8 text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
              Back
            </button>
            <button onclick="saveUserDataAndProceed()" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] hover:-translate-y-1">
              Send OTP &rarr;
            </button>
          </div>
        </div>

        <div id="step-3" class="form-step hidden p-8 sm:p-12 text-center transition-opacity duration-500">
          <div class="w-16 h-16 mx-auto bg-emerald-500/10 border border-emerald-500/30 rounded-full flex items-center justify-center mb-6 shadow-inner">
            <svg class="w-8 h-8 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-2">Verify <span class="text-emerald-400">Identity</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8" id="otp-message">Enter the 4-digit code sent to your mobile.</p>
          
          <div class="flex justify-center gap-3 mb-8">
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
          </div>

          <button onclick="verifyOTPAndProceed()" class="w-full sm:max-w-xs mx-auto flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] hover:-translate-y-1 mb-8">
            Verify & Continue &rarr;
          </button>

          <div class="bg-[#050f09]/80 border border-emerald-500/20 p-5 rounded-md flex items-start gap-4 text-left max-w-md mx-auto">
            <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <div>
              <p class="text-[11px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Encrypted Payload</p>
              <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">
                Your organizational data is securely vaulted. It is strictly utilized for structural quote generation and backend logistics routing.
              </p>
            </div>
          </div>
        </div>

        <div id="step-4" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Select <span class="text-emerald-400">System</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Select the primary structural system required for your site.</p>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
            
            <label class="cursor-pointer group relative block">
              <input type="radio" name="product_selection" value="ringlock" class="peer sr-only" onchange="selectProduct('ringlock')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/10 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_30px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all flex flex-col overflow-hidden h-full">
                <div class="aspect-video bg-zinc-900 relative border-b border-white/5 overflow-hidden">
                  <Image src={ringlockImg} alt="Ringlock" class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700" />
                </div>
                <div class="p-5 flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-sm uppercase tracking-wide">Ringlock Array</h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="product_selection" value="tower" class="peer sr-only" onchange="selectProduct('tower')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/10 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_30px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all flex flex-col overflow-hidden h-full">
                <div class="aspect-video bg-zinc-900 relative border-b border-white/5 overflow-hidden">
                  <Image src={towerImg} alt="Staircase Tower" class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700" />
                </div>
                <div class="p-5 flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-sm uppercase tracking-wide">Staircase Tower</h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="product_selection" value="plank" class="peer sr-only" onchange="selectProduct('plank')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/10 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_30px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all flex flex-col overflow-hidden h-full">
                <div class="aspect-video bg-zinc-900 relative border-b border-white/5 overflow-hidden">
                  <Image src={plankImg} alt="Walkway Planks" class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700" />
                </div>
                <div class="p-5 flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-sm uppercase tracking-wide">Walkway Planks</h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

          </div>

          <div class="mt-10 pt-6 border-t border-white/5">
            <button id="btn-product-disabled" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-zinc-800 text-zinc-500 px-8 text-[13px] font-black uppercase tracking-[0.15em] cursor-not-allowed">
              Select System &rarr;
            </button>
            
            <button id="btn-product-proceed" style="display: none;" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] hover:-translate-y-1">
              Proceed &rarr;
            </button>
          </div>
        </div>

        <div id="step-5" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Walkway <span class="text-emerald-400">Specifications</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Select the specific type of walkway plank required for your site.</p>
          
          <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5 mb-10">
            
            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-without-hook" class="peer sr-only" onchange="selectPlankType('2-fold-without-hook')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/5 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_20px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all p-3 flex flex-col overflow-hidden h-full">
                <div class="aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nWithout+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[10px] sm:text-xs uppercase tracking-wide">2-Fold Without Hook</h3>
                  <div class="custom-radio w-4 h-4 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-2 h-2 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-standard-hook" class="peer sr-only" onchange="selectPlankType('2-fold-standard-hook')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/5 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_20px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all p-3 flex flex-col overflow-hidden h-full">
                <div class="aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nStandard+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[10px] sm:text-xs uppercase tracking-wide">2-Fold Standard Hook</h3>
                  <div class="custom-radio w-4 h-4 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-2 h-2 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-dog-ear" class="peer sr-only" onchange="selectPlankType('2-fold-dog-ear')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/5 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_20px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all p-3 flex flex-col overflow-hidden h-full">
                <div class="aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nDog+Ear+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[10px] sm:text-xs uppercase tracking-wide">2-Fold Dog Ear Hook</h3>
                  <div class="custom-radio w-4 h-4 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-2 h-2 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-gi-hook" class="peer sr-only" onchange="selectPlankType('2-fold-gi-hook')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/5 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_20px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all p-3 flex flex-col overflow-hidden h-full">
                <div class="aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nGI+With+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[10px] sm:text-xs uppercase tracking-wide">2-Fold GI With Hook</h3>
                  <div class="custom-radio w-4 h-4 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-2 h-2 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="3-fold-without-hook" class="peer sr-only" onchange="selectPlankType('3-fold-without-hook')" />
              <div class="rounded-xl bg-[#0a170e] border border-white/5 peer-checked:border-emerald-400 peer-checked:bg-emerald-500/5 peer-checked:shadow-[0_0_20px_rgba(16,185,129,0.2)] peer-checked:[&_.custom-radio]:border-emerald-400 peer-checked:[&_.custom-radio]:bg-emerald-500 peer-checked:[&_.custom-check]:opacity-100 transition-all p-3 flex flex-col overflow-hidden h-full">
