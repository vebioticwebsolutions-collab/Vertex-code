---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Product images for the selection step
import ringlockImg from '../assets/products/Ringlock product.jpg';
import plankImg from '../assets/products/walkway plank.jpg';
import towerImg from '../assets/products/staircase tower product.jpg';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<Layout title="Live Quote Engine | Vertex by Primesteeltech">
  
  <a href="tel:+919876543210" class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-emerald-500 text-[#050f09] rounded-full shadow-[0_0_25px_rgba(16,185,129,0.5)] hover:scale-110 hover:bg-white transition-all duration-300 group">
    <svg class="w-6 h-6 transform group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
  </a>

  <main data-api-url={API_URL} class="bg-[#050f09] min-h-screen pt-24 pb-16 flex items-center justify-center relative overflow-hidden">
    
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none z-0"></div>

    <div class="w-full max-w-4xl px-4 sm:px-6 relative z-10">
      
      <div class="mb-8 max-w-xl mx-auto">
        <div class="flex justify-between mb-3">
          <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 px-3 py-1 rounded-full border border-emerald-500/20" id="step-indicator">Step 1 of 5</span>
          <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mt-1" id="step-title">Introduction</span>
        </div>
        <div class="w-full h-2 bg-[#0a170e] rounded-full overflow-hidden border border-white/5 relative">
          <div id="progress-bar" class="absolute top-0 left-0 h-full bg-emerald-500 w-1/5 transition-all duration-700 ease-out shadow-[0_0_15px_rgba(16,185,129,0.8)]"></div>
        </div>
      </div>

      <div class="bg-[#08120b] backdrop-blur-2xl border border-white/5 rounded-xl shadow-[0_0_50px_rgba(0,0,0,0.5)] relative overflow-hidden max-w-3xl mx-auto">
        
        <div id="step-1" class="form-step p-8 sm:p-12 text-center transition-opacity duration-500">
          <div class="w-20 h-20 mx-auto bg-[#050f09] border border-emerald-500/30 rounded-2xl flex items-center justify-center mb-8 shadow-[inset_0_0_20px_rgba(16,185,129,0.1)] transform rotate-3">
            <svg class="w-10 h-10 text-emerald-400 -rotate-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Live Quote <span class="text-emerald-400">Engine</span></h1>
          <p class="font-jakarta text-zinc-400 text-sm sm:text-base leading-relaxed mb-10 max-w-md mx-auto">
            Bypass the middlemen. Our proprietary engine connects your project requirements directly to our manufacturing database, generating accurate logistics and material pricing in real-time.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <button onclick="goToStep(2, 2, 'Select System')" class="inline-flex h-14 items-center justify-center rounded-sm bg-emerald-500 px-10 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:-translate-y-1">
              Start Configuration &rarr;
            </button>
            <a href="tel:+919876543210" class="inline-flex h-14 items-center justify-center rounded-sm border border-emerald-500/30 bg-emerald-500/10 px-8 text-[12px] font-bold text-emerald-400 uppercase tracking-widest hover:bg-emerald-500 hover:text-[#050f09] transition-all duration-300">
              <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call Sales Direct
            </a>
          </div>
        </div>

        <div id="step-2" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Select <span class="text-emerald-400">System</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Select the primary structural system required for your site.</p>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
            <label class="cursor-pointer group relative block">
              <input type="radio" name="product_selection" value="ringlock" class="peer sr-only" onchange="selectProduct('ringlock')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/10 transition-all flex flex-col overflow-hidden h-full">
                <div class="h-64 sm:h-48 bg-zinc-900 relative border-b border-white/5 overflow-hidden">
                  <Image src={ringlockImg} alt="Ringlock" class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700" />
                </div>
                <div class="p-5 flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[13px] sm:text-sm uppercase tracking-wide">Ringlock Array</h3>
                  <div class="custom-radio w-6 h-6 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="product_selection" value="tower" class="peer sr-only" onchange="selectProduct('tower')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/10 transition-all flex flex-col overflow-hidden h-full">
                <div class="h-64 sm:h-48 bg-zinc-900 relative border-b border-white/5 overflow-hidden">
                  <Image src={towerImg} alt="Staircase Tower" class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700" />
                </div>
                <div class="p-5 flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[13px] sm:text-sm uppercase tracking-wide">Staircase Tower</h3>
                  <div class="custom-radio w-6 h-6 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="product_selection" value="plank" class="peer sr-only" onchange="selectProduct('plank')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/10 transition-all flex flex-col overflow-hidden h-full">
                <div class="h-64 sm:h-48 bg-zinc-900 relative border-b border-white/5 overflow-hidden">
                  <Image src={plankImg} alt="Walkway Planks" class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700" />
                </div>
                <div class="p-5 flex items-center justify-between mt-auto">
                  <h3 class="text-white font-black text-[13px] sm:text-sm uppercase tracking-wide">Walkway Planks</h3>
                  <div class="custom-radio w-6 h-6 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>
          </div>

          <div class="mt-10 pt-6 border-t border-white/5 flex gap-4">
            <button onclick="goToStep(1, 1, 'Introduction')" class="hidden sm:flex h-14 items-center justify-center rounded-md border border-white/10 bg-transparent px-8 text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
              Back
            </button>
            <button id="btn-product-disabled" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-zinc-800 text-zinc-500 px-8 text-[13px] font-black uppercase tracking-[0.15em] cursor-not-allowed">
              Select System &rarr;
            </button>
            <button id="btn-product-proceed" style="display: none;" onclick="handleSystemProceed()" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:-translate-y-1">
              Proceed &rarr;
            </button>
          </div>
        </div>

        <div id="step-3" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Walkway <span class="text-emerald-400">Specifications</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Select the specific type of walkway plank required for your site.</p>
          
          <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5 mb-10">
            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-without-hook" class="sr-only" onchange="selectPlankType('2-fold-without-hook')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/5 transition-all p-3 sm:p-4 flex flex-col overflow-hidden h-full">
                <div class="aspect-square sm:aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nWithout+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto gap-2">
                  <h3 class="text-white font-black text-[11px] sm:text-xs uppercase tracking-wide leading-tight">2-Fold<br/><span class="text-[9px] text-zinc-400">Without Hook</span></h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-standard-hook" class="sr-only" onchange="selectPlankType('2-fold-standard-hook')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/5 transition-all p-3 sm:p-4 flex flex-col overflow-hidden h-full">
                <div class="aspect-square sm:aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nStandard+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto gap-2">
                  <h3 class="text-white font-black text-[11px] sm:text-xs uppercase tracking-wide leading-tight">2-Fold<br/><span class="text-[9px] text-zinc-400">Standard Hook</span></h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-dog-ear" class="sr-only" onchange="selectPlankType('2-fold-dog-ear')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/5 transition-all p-3 sm:p-4 flex flex-col overflow-hidden h-full">
                <div class="aspect-square sm:aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nDog+Ear+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto gap-2">
                  <h3 class="text-white font-black text-[11px] sm:text-xs uppercase tracking-wide leading-tight">2-Fold<br/><span class="text-[9px] text-zinc-400">Dog Ear Hook</span></h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="2-fold-gi-hook" class="sr-only" onchange="selectPlankType('2-fold-gi-hook')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/5 transition-all p-3 sm:p-4 flex flex-col overflow-hidden h-full">
                <div class="aspect-square sm:aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=2-Fold\nGI+With+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto gap-2">
                  <h3 class="text-white font-black text-[11px] sm:text-xs uppercase tracking-wide leading-tight">2-Fold<br/><span class="text-[9px] text-zinc-400">GI With Hook</span></h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="3-fold-without-hook" class="sr-only" onchange="selectPlankType('3-fold-without-hook')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/5 transition-all p-3 sm:p-4 flex flex-col overflow-hidden h-full">
                <div class="aspect-square sm:aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=3-Fold\nWithout+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto gap-2">
                  <h3 class="text-white font-black text-[11px] sm:text-xs uppercase tracking-wide leading-tight">3-Fold<br/><span class="text-[9px] text-zinc-400">Without Hook</span></h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>

            <label class="cursor-pointer group relative block">
              <input type="radio" name="plank_type" value="3-fold-standard-hook" class="sr-only" onchange="selectPlankType('3-fold-standard-hook')" />
              <div class="radio-card rounded-xl bg-[#0a170e] border border-white/5 transition-all p-3 sm:p-4 flex flex-col overflow-hidden h-full">
                <div class="aspect-square sm:aspect-[4/3] bg-zinc-900 rounded-md mb-3 border border-white/10 overflow-hidden relative">
                  <img src="https://placehold.co/600x400/050f09/10b981?text=3-Fold\nStandard+Hook" alt="Placeholder" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
                </div>
                <div class="flex items-center justify-between mt-auto gap-2">
                  <h3 class="text-white font-black text-[11px] sm:text-xs uppercase tracking-wide leading-tight">3-Fold<br/><span class="text-[9px] text-zinc-400">Standard Hook</span></h3>
                  <div class="custom-radio w-5 h-5 rounded-full border-2 border-zinc-500 flex items-center justify-center transition-colors shrink-0">
                    <svg class="custom-check w-3 h-3 text-[#050f09] opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  </div>
                </div>
              </div>
            </label>
          </div>

          <div class="mt-10 pt-6 border-t border-white/5 flex gap-4">
            <button onclick="goToStep(2, 2, 'Select System')" class="hidden sm:flex h-14 items-center justify-center rounded-md border border-white/10 bg-transparent px-8 text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
              Back
            </button>
            <button id="btn-plank-disabled" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-zinc-800 text-zinc-500 px-8 text-[13px] font-black uppercase tracking-[0.15em] cursor-not-allowed">
              Select Type &rarr;
            </button>
            <button id="btn-plank-proceed" style="display: none;" onclick="goToStep(4, 4, 'Configuration Matrix')" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:-translate-y-1">
              Proceed to Dimensions &rarr;
            </button>
          </div>
        </div>

        <div id="step-4" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Configuration <span class="text-emerald-400">Matrix</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Enter your project specifications to calculate required tonnage.</p>

          <div class="bg-[#0a170e] border border-emerald-500/20 p-6 sm:p-8 rounded-lg shadow-inner">
            <div class="space-y-6">
              
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Length (L) *</label>
                  <input type="number" id="dim-l" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" required />
                </div>
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Width (W) *</label>
                  <input type="number" id="dim-w" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" required />
                </div>
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Height (H) *</label>
                  <input type="number" id="dim-h" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" required />
                </div>
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Quantity *</label>
                  <input type="number" id="dim-qty" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="e.g. 100" required />
                </div>
              </div>

              <div class="pt-2 border-t border-white/5">
                <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2 mt-4">Remarks / Special Requirements</label>
                <textarea id="dim-remarks" rows="3" class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="Enter any specific load requirements, material grades, or custom configurations..."></textarea>
              </div>

            </div>

            <div class="mt-8 pt-6 border-t border-white/5 flex gap-4">
              <button onclick="handleDimBack()" class="hidden sm:flex h-14 items-center justify-center rounded-md border border-white/10 bg-transparent px-8 text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
                Back
              </button>
              <button id="btn-dim-proceed" onclick="handleDimProceed()" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:-translate-y-1">
                Proceed to Details &rarr;
              </button>
            </div>
          </div>
        </div>

        <div id="step-5" class="form-step hidden p-6 sm:p-12 transition-opacity duration-500">
          <h2 class="text-2xl font-black text-white uppercase tracking-tight mb-2">Business <span class="text-emerald-400">Details</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8">Enter your organizational details to register your quote file.</p>
          
          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Full Name *</label>
                <input type="text" id="entry-name" placeholder="John Doe" required class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Company Name *</label>
                <input type="text" id="entry-company" placeholder="BuildCorp India Ltd." required class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
              </div>
            </div>
            
            <div>
              <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">GSTIN (Optional)</label>
              <input type="text" id="entry-gstin" placeholder="27XXXXX1234X1XX" class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors uppercase" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Email Address *</label>
                <input type="email" id="entry-email" placeholder="john@buildcorp.in" required class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2">Mobile Number *</label>
                <div class="flex">
                  <span class="inline-flex items-center px-4 bg-white/5 border border-r-0 border-white/10 rounded-l-sm text-zinc-400 text-sm font-jakarta border-r-transparent">+91</span>
                  <input type="tel" id="entry-mobile" placeholder="98765 43210" required minlength="10" class="w-full bg-[#050f09] border border-white/10 rounded-r-sm px-4 py-3.5 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" />
                </div>
              </div>
            </div>
          </div>

          <div class="mt-10 flex gap-4 pt-6 border-t border-white/5">
            <button onclick="handleDetailsBack()" class="hidden sm:flex h-14 items-center justify-center rounded-sm border border-white/10 bg-transparent px-8 text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
              Back
            </button>
            <button id="btn-details-proceed" onclick="handleDetailsProceed()" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:-translate-y-1">
              Send OTP &rarr;
            </button>
          </div>
        </div>

        <div id="step-6" class="form-step hidden p-8 sm:p-12 text-center transition-opacity duration-500">
          <div class="w-16 h-16 mx-auto bg-emerald-500/10 border border-emerald-500/30 rounded-full flex items-center justify-center mb-6 shadow-inner">
            <svg class="w-8 h-8 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-2">Verify <span class="text-emerald-400">Identity</span></h2>
          <p class="font-jakarta text-zinc-400 text-sm mb-8" id="otp-message">Enter the 4-digit code sent to your mobile.</p>
          
          <div class="flex justify-center gap-3 mb-8">
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
            <input type="text" maxlength="1" class="otp-box w-14 h-16 text-center text-2xl font-black bg-[#050f09] border border-white/10 rounded-md text-white focus:border-emerald-500 focus:outline-none focus:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all" />
          </div>

          <div class="flex gap-4 sm:max-w-xs mx-auto mb-8">
            <button onclick="handleOTPBack()" class="flex h-14 w-1/3 items-center justify-center rounded-sm border border-white/10 bg-transparent text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
              Back
            </button>
            <button id="btn-otp-proceed" onclick="verifyOTPAndProceed()" class="w-2/3 flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:-translate-y-1">
              Verify &rarr;
            </button>
          </div>

          <div class="bg-[#050f09]/80 border border-emerald-500/20 p-5 rounded-md flex items-start gap-4 text-left max-w-md mx-auto">
            <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <div>
              <p class="text-[11px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Encrypted Payload</p>
              <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">
                Your organizational data is securely vaulted. It is strictly utilized for structural quote generation and backend logistics routing.
              </p>
            </div>
          </div>
        </div>

        <div id="step-7" class="form-step hidden p-12 sm:p-20 text-center transition-opacity duration-500">
          
          <div class="success-animation mx-auto w-24 h-24 mb-8">
            <svg class="checkmark w-full h-full rounded-full block stroke-emerald-500 shadow-[inset_0_0_0_#10b981]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52" id="gpay-svg">
              <circle class="checkmark__circle stroke-emerald-500 fill-none" cx="26" cy="26" r="25" />
              <path class="checkmark__check fill-none stroke-emerald-500" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
            </svg>
          </div>

          <h2 class="text-3xl font-black text-white uppercase tracking-tight mb-4">Payload <span class="text-emerald-400">Received</span></h2>
          <div id="quote-result" class="font-jakarta text-emerald-300 text-sm sm:text-base font-semibold mb-4"></div>
          <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8 max-w-sm mx-auto">
            Your dimensional data has been routed to our logistics engine. A dedicated technical sales agent will contact you within 48 hours with your official quotation.
          </p>
          <a href="/" class="inline-flex h-12 items-center justify-center rounded-sm border border-emerald-500/40 bg-emerald-500/10 px-8 text-[12px] font-bold text-emerald-400 uppercase tracking-widest hover:bg-emerald-500 hover:text-[#050f09] transition-all">
            Return to Homepage
          </a>
        </div>

      </div>
    </div>
  </main>

  <!-- TESTING RESULT MODAL -->
  <div id="test-result-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm">
    <div class="bg-[#0a1a10] border border-emerald-500/30 rounded-lg w-full max-w-sm p-6 shadow-[0_0_40px_rgba(16,185,129,0.15)]">
      <div class="flex items-center gap-2 mb-5 bg-amber-500/10 border border-amber-500/30 rounded px-3 py-2">
        <span class="text-amber-400 text-[11px] font-black uppercase tracking-widest">&#9888; For Testing Purposes Only</span>
      </div>
      <h3 class="text-white font-black text-base uppercase tracking-tight mb-1">Quote Result</h3>
      <p class="text-zinc-500 text-xs font-jakarta mb-4">Raw response from backend API</p>
      <div id="test-modal-body" class="space-y-0 mb-6 text-sm min-h-[40px]"></div>
      <button onclick="closeTestModal()" class="w-full h-11 rounded-sm bg-emerald-500 text-[#050f09] text-[12px] font-black uppercase tracking-widest hover:bg-emerald-400 transition-all">
        Acknowledge &amp; Continue
      </button>
    </div>
  </div>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
  
  .dim-input::-webkit-outer-spin-button,
  .dim-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* BULLETPROOF CUSTOM RADIO BUTTON CSS */
  input[type="radio"]:checked + .radio-card {
    border-color: #34d399; /* emerald-400 */
    background-color: rgba(16, 185, 129, 0.05); /* emerald-500/5 */
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.2);
  }
  input[type="radio"]:checked + .radio-card .custom-radio {
    border-color: #34d399;
    background-color: #10b981; /* emerald-500 */
  }
  input[type="radio"]:checked + .radio-card .custom-check {
    opacity: 1;
  }

  /* GPAY SUCCESS ANIMATION STYLES */
  .checkmark {
    stroke-width: 3;
    stroke-miterlimit: 10;
  }
  .animate-success .checkmark {
    animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both;
  }
  .checkmark__circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 3;
    stroke-miterlimit: 10;
  }
  .animate-success .checkmark__circle {
    animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }
  .checkmark__check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
  }
  .animate-success .checkmark__check {
    animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
  }

  @keyframes stroke {
    100% { stroke-dashoffset: 0; }
  }
  @keyframes scale {
    0%, 100% { transform: none; }
    50% { transform: scale3d(1.1, 1.1, 1); }
  }
  @keyframes fill {
    100% { box-shadow: inset 0px 0px 0px 30px rgba(16, 185, 129, 0.1); }
  }
</style>

<script is:inline>
  const API_URL = document.querySelector('main').dataset.apiUrl || 'http://localhost:8000';

  // ==========================================
  // UTILITY: BUTTON LOADING STATES
  // ==========================================
  function setButtonLoading(buttonId, loadingText) {
    const btn = document.getElementById(buttonId);
    btn.dataset.originalText = btn.innerHTML; 
    btn.innerHTML = `<svg class="animate-spin h-5 w-5 mr-2 text-[#050f09] inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> ${loadingText}`;
    btn.classList.add('opacity-70', 'pointer-events-none');
  }

  function restoreButton(buttonId) {
    const btn = document.getElementById(buttonId);
    btn.innerHTML = btn.dataset.originalText;
    btn.classList.remove('opacity-70', 'pointer-events-none');
  }

  // 1. MASTER DATA OBJECT (NO THICKNESS!)
  let quoteData = {
    user: { fullName: '', companyName: '', gstin: '', email: '', mobile: '' },
    productType: '',
    plankType: '', 
    dimensions: { length: '', width: '', height: '', qty: '', remarks: '' }
  };

  let totalVisualSteps = 5; 

  // 2. CORE NAVIGATION
  function goToStep(targetStepId, visualStepNumber, stepName) {
    const allSteps = document.querySelectorAll('.form-step');
    allSteps.forEach(step => {
      step.classList.add('opacity-0');
      setTimeout(() => { step.classList.add('hidden'); }, 300); 
    });

    setTimeout(() => {
      const targetStep = document.getElementById(`step-${targetStepId}`);
      targetStep.classList.remove('hidden');
      setTimeout(() => { targetStep.classList.remove('opacity-0'); }, 50);

      // Trigger GPay Animation if Step 7
      if (targetStepId === 7) {
        document.getElementById('gpay-svg').parentElement.classList.add('animate-success');
      }

    }, 300);

    const progressBar = document.getElementById('progress-bar');
    const stepIndicator = document.getElementById('step-indicator');
    const stepTitle = document.getElementById('step-title');

    if(visualStepNumber > 0 && visualStepNumber <= totalVisualSteps) {
      const progressPercentage = (visualStepNumber / totalVisualSteps) * 100;
      progressBar.style.width = `${progressPercentage}%`;
      stepIndicator.innerText = `Step ${visualStepNumber} of ${totalVisualSteps}`;
      stepTitle.innerText = stepName;
    }
  }

  // 3. LOGIC HANDLERS
  function selectProduct(productType) {
    quoteData.productType = productType;
    document.getElementById('btn-product-disabled').style.display = 'none';
    document.getElementById('btn-product-proceed').style.display = 'inline-flex';
    totalVisualSteps = (productType === 'plank') ? 6 : 5;
  }

  function handleSystemProceed() {
    if (quoteData.productType === 'plank') { goToStep(3, 3, 'Walkway Specifications'); } 
    else { goToStep(4, 3, 'Configuration Matrix'); }
  }

  function selectPlankType(type) {
    quoteData.plankType = type;
    document.getElementById('btn-plank-disabled').style.display = 'none';
    document.getElementById('btn-plank-proceed').style.display = 'inline-flex';
  }

  function handleDimBack() {
    if (quoteData.productType === 'plank') { goToStep(3, 3, 'Walkway Specifications'); } 
    else { goToStep(2, 2, 'Select System'); }
  }

  // =========================================================================
  // 4. BACKEND INTEGRATION & VALIDATION
  // =========================================================================

  function handleDimProceed() {
    // TASK 1: VALIDATION FOR DIMENSIONS
    const l = document.getElementById('dim-l').value;
    const w = document.getElementById('dim-w').value;
    const h = document.getElementById('dim-h').value;
    const qty = document.getElementById('dim-qty').value;

    if(!l || !w || !h || !qty) {
      alert("Please fill in Length, Width, Height, and Quantity before proceeding.");
      return;
    }

    let vStep = (quoteData.productType === 'plank') ? 5 : 4;
    goToStep(5, vStep, 'Business Details');
  }

  function handleDetailsBack() {
    let vStep = (quoteData.productType === 'plank') ? 4 : 3;
    goToStep(4, vStep, 'Configuration Matrix');
  }

  // A. TRIGGER SMS OTP
  async function handleDetailsProceed() {
    // TASK 1: VALIDATION FOR BUSINESS DETAILS
    const name = document.getElementById('entry-name').value;
    const company = document.getElementById('entry-company').value;
    const email = document.getElementById('entry-email').value;
    const mobile = document.getElementById('entry-mobile').value;

    if(!name || !company || !email || !mobile) {
      alert("Please fill in all required fields (*).");
      return;
    }

    if(mobile.length < 10) {
      alert("Please enter a valid 10-digit mobile number.");
      return;
    }

    quoteData.user.fullName = name;
    quoteData.user.companyName = company;
    quoteData.user.gstin = document.getElementById('entry-gstin').value;
    quoteData.user.email = email;
    quoteData.user.mobile = mobile;
    
    // TASK 2: LOADING STATE & SIMULATED DELAY
    setButtonLoading('btn-details-proceed', 'Sending OTP...');
    await new Promise(resolve => setTimeout(resolve, 1500)); // Fake 1.5s network delay

    // BACKEND DEV: Uncomment and replace simulated delay above
    /*
    try {
      const response = await fetch('/api/send-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: quoteData.user.mobile })
      });
      if (!response.ok) throw new Error("SMS failed");
    } catch (error) { 
      alert("Error sending SMS. Please check your number."); 
      restoreButton('btn-details-proceed');
      return; 
    }
    */

    restoreButton('btn-details-proceed');

    document.getElementById('otp-message').innerText = `Enter the 4-digit code sent to +91 ${quoteData.user.mobile}`;
    let vStep = (quoteData.productType === 'plank') ? 6 : 5;
    goToStep(6, vStep, 'Verify Identity');
  }

  function handleOTPBack() {
    let vStep = (quoteData.productType === 'plank') ? 5 : 4;
    goToStep(5, vStep, 'Business Details');
  }

  // B. VERIFY OTP AND SUBMIT
  async function verifyOTPAndProceed() {
    const otpInputs = document.querySelectorAll('.otp-box');
    let enteredOTP = "";
    otpInputs.forEach(input => { enteredOTP += input.value; });

    if(enteredOTP.length < 4) { alert("Please enter the full 4-digit OTP."); return; }

    // TASK 2: LOADING STATE & SIMULATED DELAY
    setButtonLoading('btn-otp-proceed', 'Verifying...');
    await new Promise(resolve => setTimeout(resolve, 1500)); // Fake 1.5s network delay

    // BACKEND DEV: Uncomment and replace simulated delay above
    /*
    try {
      const response = await fetch('/api/verify-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: quoteData.user.mobile, code: enteredOTP })
      });
      if (!response.ok) {
        alert("Invalid OTP. Try again.");
        otpInputs.forEach(input => input.value = '');
        otpInputs[0].focus();
        restoreButton('btn-otp-proceed');
        return; 
      }
    } catch (error) { 
      restoreButton('btn-otp-proceed');
      return; 
    }
    */

    // Await the final submission properly so it processes before restoring button
    const ok = await submitFinalQuote();
    if (ok) return; // step 7 shown, button is irrelevant
    restoreButton('btn-otp-proceed');
  }

  // C. SUBMIT FINAL PAYLOAD
  async function submitFinalQuote() {
    // THICKNESS HAS BEEN REMOVED HERE, PREVENTING THE SILENT CRASH!
    quoteData.dimensions.length = document.getElementById('dim-l').value;
    quoteData.dimensions.width = document.getElementById('dim-w').value;
    quoteData.dimensions.height = document.getElementById('dim-h').value;
    quoteData.dimensions.qty = document.getElementById('dim-qty').value;
    quoteData.dimensions.remarks = document.getElementById('dim-remarks').value;

    console.log("FINAL PAYLOAD:", JSON.stringify(quoteData, null, 2));

    let result = {};
    try {
      const response = await fetch(`${API_URL}/api/submit-quote`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(quoteData)
      });
      if (!response.ok) throw new Error('submit failed');
      result = await response.json();
      console.log("BACKEND RESPONSE:", JSON.stringify(result, null, 2));
    } catch (error) { alert("Error saving quote."); return false; }

    renderQuoteResult(result);
    showResultModal(result);
    return true;
  }

  function showResultModal(result) {
    const body = document.getElementById('test-modal-body');

    const topLabels = {
      success:            'Success',
      weight_kg:          'Total Weight',
      sheet_width_mm:     'Sheet Dev. Width',
      effective_length_mm:'Effective Length',
      rate_per_kg:        'Rate / kg',
      final_rate:         'Final Rate (per piece)',
      qty:                'Quantity',
    };

    const breakdownLabels = {
      sheet_wt_kg:     'Main Shell (F10)',
      stiffner_wt_kg:  'Stiffeners (F12)',
      end_plate_wt_kg: 'End Plates (F14)',
      hook_wt_kg:      'Hook Weight',
    };

    const fmt = (val) => {
      if (typeof val === 'number') return val % 1 === 0 ? val : val.toFixed(4).replace(/\.?0+$/, '');
      return val;
    };

    let html = '';

    // Top-level fields (skip 'breakdown' — handled separately below)
    for (const [key, val] of Object.entries(result)) {
      if (key === 'breakdown' || key === 'success') continue;
      const label = topLabels[key] || key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
      const unit  = key === 'weight_kg' ? ' kg'
                  : key.includes('_mm') ? ' mm'
                  : key.includes('rate') || key === 'final_rate' ? ' ₹'
                  : '';
      html += `<div class="flex justify-between items-center border-b border-white/5 py-2">
        <span class="text-zinc-400 font-jakarta text-xs">${label}</span>
        <span class="text-emerald-300 font-semibold font-jakarta text-xs">${fmt(val)}${unit}</span>
      </div>`;
    }

    // Breakdown section
    if (result.breakdown && typeof result.breakdown === 'object') {
      html += `<div class="mt-3 mb-1 text-[10px] font-black text-emerald-500 uppercase tracking-widest">Weight Breakdown</div>`;
      for (const [key, val] of Object.entries(result.breakdown)) {
        const label = breakdownLabels[key] || key.replace(/_/g, ' ');
        html += `<div class="flex justify-between items-center border-b border-white/5 py-2 pl-2">
          <span class="text-zinc-500 font-jakarta text-xs">${label}</span>
          <span class="text-white font-semibold font-jakarta text-xs">${fmt(val)} kg</span>
        </div>`;
      }
    }

    if (!html) html = '<p class="text-zinc-400 font-jakarta text-sm">No data returned from server.</p>';
    body.innerHTML = html;
    document.getElementById('test-result-modal').classList.remove('hidden');
  }

  function closeTestModal() {
    document.getElementById('test-result-modal').classList.add('hidden');
    goToStep(7, 0, 'Processing Complete');
  }

  function renderQuoteResult(result) {
    const el = document.getElementById('quote-result');
    if (!el) return;
    const weight = result.weight_kg ?? result.weight ?? null;
    const rate   = result.final_rate ?? result.rate ?? null;
    if (weight == null && rate == null) return;
    el.innerHTML =
      (weight != null ? `Estimated weight: <strong>${weight} kg</strong><br>` : '') +
      (rate   != null ? `Final rate: <strong>${rate}</strong>` : '');
  }

  // OTP Auto-Jump Logic
  document.addEventListener('DOMContentLoaded', () => {
    const otpInputs = document.querySelectorAll('.otp-box');
    otpInputs.forEach((input, index) => {
      input.addEventListener('input', () => {
        input.value = input.value.replace(/[^0-9]/g, ''); // Forces only numbers
        if (input.value.length === 1 && index < otpInputs.length - 1) {
          otpInputs[index + 1].focus();
        }
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && input.value.length === 0 && index > 0) {
          otpInputs[index - 1].focus();
        }
      });
    });
  });
</script>