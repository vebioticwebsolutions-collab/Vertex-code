                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Elevation per Tower</label>
                  <input type="number" id="tower-height" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="Meters" />
