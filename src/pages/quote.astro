              <div>
                <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Exit Configuration</label>
                <select id="tower-exit" class="w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 appearance-none transition-colors">
                  <option value="single">Single Exit (Top Only)</option>
                  <option value="multi">Multi-Level Exits</option>
                </select>
              </div>
            </div>

            <div id="form-plank" class="dynamic-form hidden space-y-6">
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Length (L)</label>
                  <input type="number" id="plank-l" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" />
                </div>
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Width (W)</label>
                  <input type="number" id="plank-w" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" />
                </div>
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Height (H)</label>
                  <input type="number" id="plank-h" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" />
                </div>
                <div>
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Thickness (Thk)</label>
                  <input type="number" id="plank-thk" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4 sm:gap-6" id="plank-extra-fields" style="display: none;">
                <div id="plank-field-bottom" style="display: none;">
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Bottom</label>
                  <input type="number" id="plank-bottom" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" />
                </div>
                <div id="plank-field-inner" style="display: none;">
                  <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Inner Bend</label>
                  <input type="number" id="plank-inner" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="mm" />
                </div>
              </div>

              <div>
                <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Total Quantity</label>
                <input type="number" id="plank-qty-total" class="dim-input w-full bg-[#050f09] border border-white/10 rounded-sm px-4 py-3 text-white text-sm font-jakarta focus:outline-none focus:border-emerald-500 transition-colors" placeholder="e.g. 500" />
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-white/5 flex gap-4">
              <button onclick="handleDimensionBack()" class="hidden sm:flex h-14 items-center justify-center rounded-md border border-white/10 bg-transparent px-8 text-[12px] font-bold text-zinc-400 uppercase tracking-widest hover:bg-white/5 transition-colors">
                Back
              </button>
              <button onclick="submitFinalQuote()" class="w-full inline-flex h-14 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-black text-[#050f09] uppercase tracking-[0.15em] hover:bg-emerald-400 transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] hover:-translate-y-1">
                Generate Final Quote &rarr;
              </button>
            </div>
          </div>
        </div>

        <div id="step-7" class="form-step hidden p-12 sm:p-20 text-center transition-opacity duration-500">
          
          <div class="success-animation mx-auto w-24 h-24 mb-8">
            <svg class="checkmark w-full h-full rounded-full block stroke-emerald-500 shadow-[inset_0_0_0_#10b981]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52" id="gpay-svg">
              <circle class="checkmark__circle stroke-emerald-500 fill-none" cx="26" cy="26" r="25" />
              <path class="checkmark__check fill-none stroke-emerald-500" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
            </svg>
          </div>

          <h2 class="text-3xl font-black text-white uppercase tracking-tight mb-4">Payload <span class="text-emerald-400">Received</span></h2>
          <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8 max-w-sm mx-auto">
            Your dimensional data has been routed to our logistics engine. A dedicated technical sales agent will contact you within 48 hours with your official quotation.
          </p>
          <a href="/" class="inline-flex h-12 items-center justify-center rounded-sm border border-emerald-500/40 bg-emerald-500/10 px-8 text-[12px] font-bold text-emerald-400 uppercase tracking-widest hover:bg-emerald-500 hover:text-[#050f09] transition-all">
            Return to Homepage
          </a>
        </div>

      </div>
    </div>
  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
  
  /* Hide arrows on number inputs */
  .dim-input::-webkit-outer-spin-button,
  .dim-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* GPay Success Animation Styles */
  .checkmark {
    stroke-width: 3;
    stroke-miterlimit: 10;
  }
  .animate-success .checkmark {
    animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both;
  }
  .checkmark__circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 3;
    stroke-miterlimit: 10;
  }
  .animate-success .checkmark__circle {
    animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }
  .checkmark__check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
  }
  .animate-success .checkmark__check {
    animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
  }

  @keyframes stroke {
    100% { stroke-dashoffset: 0; }
  }
  @keyframes scale {
    0%, 100% { transform: none; }
    50% { transform: scale3d(1.1, 1.1, 1); }
  }
  @keyframes fill {
    100% { box-shadow: inset 0px 0px 0px 30px rgba(16, 185, 129, 0.1); }
  }
</style>

<script is:inline>
  // 1. MASTER DATA OBJECT
  let quoteData = {
    user: { fullName: '', companyName: '', gstin: '', email: '', mobile: '' },
    productType: '',
    plankType: '', 
    dimensions: {}
  };

  let totalSteps = 6; 

  // 2. UI NAVIGATION ENGINE
  function nextStep(stepNumber, stepName) {
    // Hide all steps smoothly
    const allSteps = document.querySelectorAll('.form-step');
    allSteps.forEach(step => {
      step.classList.add('opacity-0');
      setTimeout(() => {
        step.classList.add('hidden');
      }, 300); 
    });

    // Show the target step
    setTimeout(() => {
      const targetStep = document.getElementById(`step-${stepNumber}`);
      targetStep.classList.remove('hidden');
      setTimeout(() => {
        targetStep.classList.remove('opacity-0');
      }, 50);

      // Trigger GPay Animation if Step 7
      if (stepNumber === 7) {
        document.getElementById('gpay-svg').parentElement.classList.add('animate-success');
      }

    }, 300);

    // Update Progress Bar
    const progressBar = document.getElementById('progress-bar');
    const stepIndicator = document.getElementById('step-indicator');
    const stepTitle = document.getElementById('step-title');

    if(stepNumber <= totalSteps) {
      const progressPercentage = (stepNumber / totalSteps) * 100;
      progressBar.style.width = `${progressPercentage}%`;
      stepIndicator.innerText = `Step ${stepNumber} of ${totalSteps}`;
      stepTitle.innerText = stepName;
    }
  }

  // Handle back routing
  function handleDimensionBack() {
    if (quoteData.productType === 'plank') {
      nextStep(5, 'Walkway Specifications');
    } else {
      nextStep(4, 'Select System');
    }
  }

  // 3. STEP 2 -> 3: SAVE USER DATA
  function saveUserDataAndProceed() {
    quoteData.user.fullName = document.getElementById('entry-name').value;
    quoteData.user.companyName = document.getElementById('entry-company').value;
    quoteData.user.gstin = document.getElementById('entry-gstin').value;
    quoteData.user.email = document.getElementById('entry-email').value;
    quoteData.user.mobile = document.getElementById('entry-mobile').value;
    
    document.getElementById('otp-message').innerText = `Enter the 4-digit code sent to +91 ${quoteData.user.mobile}`;
    nextStep(3, 'Verify Identity');
  }

  // 4. STEP 3 -> 4: VERIFY OTP
  function verifyOTPAndProceed() {
    console.log("OTP Verified. User data captured:", quoteData.user);
    nextStep(4, 'Select System');
  }

  // 5. STEP 4: PRODUCT SELECTION
  function selectProduct(productType) {
    quoteData.productType = productType;
    
    // UI Button Toggle
    document.getElementById('btn-product-disabled').style.display = 'none';
    const activeBtn = document.getElementById('btn-product-proceed');
    activeBtn.style.display = 'inline-flex';

    // Form Toggle
    document.querySelectorAll('.dynamic-form').forEach(form => form.classList.add('hidden'));
    document.getElementById(`form-${productType}`).classList.remove('hidden');

    // Routing Logic
    if (productType === 'plank') {
      totalSteps = 7;
      activeBtn.setAttribute('onclick', "nextStep(5, 'Walkway Specifications')");
    } else {
      totalSteps = 6;
      activeBtn.setAttribute('onclick', "nextStep(6, 'Configuration Matrix')");
    }
  }

  // 6. STEP 5: PLANK TYPE SELECTION
  function selectPlankType(type) {
    quoteData.plankType = type;
    
    document.getElementById('btn-plank-disabled').style.display = 'none';
    document.getElementById('btn-plank-proceed').style.display = 'inline-flex';

    const extraFieldsContainer = document.getElementById('plank-extra-fields');
    const bottomField = document.getElementById('plank-field-bottom');
    const innerField = document.getElementById('plank-field-inner');

    // Reset Defaults
    extraFieldsContainer.style.display = 'none';
    bottomField.style.display = 'none';
    innerField.style.display = 'none';

    if (type === '3-fold-without-hook') {
      extraFieldsContainer.style.display = 'grid';
      bottomField.style.display = 'block';
      innerField.style.display = 'block';
    } else if (type === '3-fold-standard-hook') {
      extraFieldsContainer.style.display = 'grid';
      bottomField.style.display = 'block';
    }
  }

  // 7. STEP 6 -> 7: SUBMIT PAYLOAD
  function submitFinalQuote() {
    if (quoteData.productType === 'ringlock') {
      quoteData.dimensions = {
        area: document.getElementById('ringlock-area').value,
        height: document.getElementById('ringlock-height').value,
        applicationType: document.getElementById('ringlock-type').value
      };
    } else if (quoteData.productType === 'tower') {
      quoteData.dimensions = {
        quantity: document.getElementById('tower-qty').value,
        height: document.getElementById('tower-height').value,
        exitConfig: document.getElementById('tower-exit').value
      };
    } else if (quoteData.productType === 'plank') {
      let plankData = {
        length: document.getElementById('plank-l').value,
        width: document.getElementById('plank-w').value,
        height: document.getElementById('plank-h').value,
        thickness: document.getElementById('plank-thk').value,
        totalQuantity: document.getElementById('plank-qty-total').value
      };

      if (quoteData.plankType === '3-fold-without-hook') {
        plankData.bottom = document.getElementById('plank-bottom').value;
        plankData.innerBend = document.getElementById('plank-inner').value;
      } else if (quoteData.plankType === '3-fold-standard-hook') {
        plankData.bottom = document.getElementById('plank-bottom').value;
      }
      quoteData.dimensions = plankData;
    }

    console.log("FINAL PAYLOAD READY FOR DATABASE:", JSON.stringify(quoteData, null, 2));
    nextStep(7, 'Processing Complete');
  }

  // OTP Input Auto-Jump UX
  document.addEventListener('DOMContentLoaded', () => {
    const otpInputs = document.querySelectorAll('.otp-box');
    otpInputs.forEach((input, index) => {
      input.addEventListener('input', () => {
        if (input.value.length === 1 && index < otpInputs.length - 1) {
          otpInputs[index + 1].focus();
        }
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && input.value.length === 0 && index > 0) {
          otpInputs[index - 1].focus();
        }
      });
    });
  });
</script>