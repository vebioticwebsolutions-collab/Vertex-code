---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ==========================================
// IMAGE IMPORTS (Mapped to your exact file names)
// ==========================================

// Section 3: Leading Manufacturers
import img3_1 from '../assets/home-page/(updated)3-1 (1).jpg'; 
import img3_2 from '../assets/home-page/(updated)3-2.jpg';

// Section 4: Ringlock, Towers, Planks
import img4_1 from '../assets/home-page/(updated)4-1 (1).jpg';
import img4_2 from '../assets/home-page/(updated)4-2 (1).jpg';
import img4_3 from '../assets/home-page/(updated)4-3.png';
import img4_4 from '../assets/home-page/(updated)4-4 (1).jpg';

// Section 6: Sectors
import img6_1 from '../assets/home-page/(updated)6-1.jpg';
import img6_2 from '../assets/home-page/(updated)6-2.jpg';
import img6_3 from '../assets/home-page/(updated)6-3.jpg';
import img6_4 from '../assets/home-page/(updated)6-4.jpg'; 

// Section 8 (Now moved up): Product Mini-Cards
import img8_1 from '../assets/home-page/(updated)8-1 (1).jpg';
import img8_2 from '../assets/home-page/(updated)8-2.jpg';
import img8_3 from '../assets/home-page/(updated)8-3.jpg';

// Logos
import logoAdani from '../assets/home-page/logo adani.png';
import logoLT from '../assets/home-page/logo L&T.png';
import logoTata from '../assets/home-page/logo tataprojects.jpeg';
import logoJKumar from '../assets/home-page/logo jkumar.png';
---

<Layout title="Vertex by Primesteeltech | Top Scaffolding Manufacturer Mumbai">
  
  <main class="bg-[#050f09] text-white overflow-hidden">
    
    <!-- 1. HERO SECTION -->
    <section class="relative pt-12 pb-16 sm:pt-16 sm:pb-24 lg:pt-16 lg:pb-32 border-b border-emerald-500/10 text-center z-10">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#10b98105_1px,transparent_1px),linear-gradient(to_bottom,#10b98105_1px,transparent_1px)] bg-[size:3rem_3rem] sm:bg-[size:4rem_4rem]"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[1000px] h-[400px] bg-emerald-500/20 blur-[130px] rounded-full pointer-events-none"></div>

      <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-col items-center">
        
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-[11px] sm:text-xs font-semibold text-emerald-400 uppercase tracking-widest mb-8 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
          <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 animate-pulse"></span>
          <span>Top manufacturer of walkway planks, staircase towers, and ringlock scaffolding</span>
        </div>

        <h1 class="text-2xl font-black tracking-tight text-center text-white sm:text-4xl lg:text-5xl uppercase leading-[1.25] sm:leading-[1.2] max-w-4xl">
          <span class="block">Best In class</span>
          <span class="block">Scaffolding Manufacturing</span>
          <span class="block mt-1 text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-500 whitespace-nowrap">Modular Ringlock Systems</span>
          <span class="block mt-1 text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-500 whitespace-nowrap">Anti Skid Walkway Planks</span>
          <span class="block mt-1 text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-500 whitespace-nowrap">Scaffolding Staircase Towers</span>
        </h1>

        <p class="font-jakarta mt-6 text-sm sm:text-base lg:text-lg leading-relaxed sm:leading-8 text-zinc-300 max-w-3xl font-medium">
          Engineered for India's toughest projects, Prime Steeltech India Pvt Ltd provides EN/BS/OSHO/BIS certified Ringlock & Cuplock Systems , Anti skid walkway planks , Scaffolding Staircase Towers and other Modular Scaffolding Systems & Formworks. With decades of expertise serving in India, Gulf and African countries, our systems ensure rock-solid stability and safety for diverse infrastructure and industrial projects. We also assist you throughout the project by providing services such as consultancy , personalization , erection & estimation of materials required for your project.
        </p>

        <div class="mt-10 sm:mt-12 flex flex-col sm:flex-row items-center justify-center gap-5 w-full sm:w-auto">
          <a href="/products" class="w-full sm:w-auto inline-flex h-14 min-w-[220px] items-center justify-center rounded-sm border-2 border-emerald-500/30 bg-[#0a170e] px-8 text-sm font-bold text-emerald-400 hover:border-emerald-400 hover:text-white hover:bg-emerald-500/20 active:bg-emerald-500/30 transition-all duration-300 uppercase tracking-widest backdrop-blur-sm shadow-inner">
            View Products
          </a>
          <a href="/quote" class="relative group w-full sm:w-auto inline-flex h-14 min-w-[220px] items-center justify-center rounded-sm bg-emerald-500 px-8 text-sm font-extrabold text-[#050f09] shadow-[0_0_25px_rgba(16,185,129,0.3)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] hover:bg-emerald-400 active:scale-[0.98] transition-all duration-300 uppercase tracking-widest overflow-hidden z-10">
            <span class="relative z-20">Get a Quote</span>
          </a>
        </div>
      </div>
    </section>

    <!-- 2. VIDEO SECTION -->
    <section class="py-16 sm:py-24 border-b border-emerald-500/10 relative bg-[#0a170e]">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
        
        <h2 class="text-2xl sm:text-3xl font-bold text-white uppercase tracking-tight mb-6">
          Elite Heritage. <span class="text-emerald-400">New Frontier.</span>
        </h2>
        
        <div class="space-y-6 text-zinc-300 text-sm sm:text-base leading-relaxed max-w-3xl mb-12 font-medium">
          <p class="font-jakarta">
            Prime Steeltech India is redefining the industry through a next-generation digital platform. This combines instant quoting and real-time specifications with faster procurement, merging engineering heritage with digital efficiency
          </p>
        </div>

        <div class="relative w-full max-w-4xl aspect-video rounded-sm overflow-hidden shadow-[0_0_50px_rgba(16,185,129,0.15)] border border-emerald-500/20 bg-black">
          <iframe 
            class="absolute top-0 left-0 w-full h-full border-0"
            src="https://www.youtube.com/embed/OBa_5lMDzVA?autoplay=0&rel=0" 
            title="Vertex Manufacturing Process" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
        <p class="mt-4 text-xs text-emerald-500/70 uppercase tracking-widest font-semibold">Watch our manufacturing process in action</p>

      </div>
    </section>

    <!-- 3. ENGINEERED FOR EXTREME LOADS (Moved up directly under video) -->
    <section class="py-16 sm:py-24 border-b border-emerald-500/10 relative overflow-hidden bg-[#050f09]">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-emerald-500/10 blur-[130px] rounded-full pointer-events-none"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-stretch">
          
          <div class="flex flex-col bg-[#0a170e] border border-emerald-500/20 rounded-sm p-8 sm:p-12 shadow-[0_0_40px_rgba(16,185,129,0.05)] backdrop-blur-sm relative overflow-hidden group">
            <div class="absolute inset-0 z-0 opacity-20 mix-blend-overlay">
               <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=1000&auto=format&fit=crop" alt="Steel Structure" class="w-full h-full object-cover grayscale group-hover:scale-105 transition-transform duration-700" />
            </div>

            <div class="relative z-10 flex-grow text-center lg:text-left">
              <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-4">
                Engineered for <br class="hidden lg:block"/><span class="text-emerald-400">Extreme Loads</span>
              </h2>
              <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
                Deep dive into our modular ringlock architecture, high-tensile steel planks, and heavy-duty robust industrial staircase systems.
              </p>
              
              <div class="grid grid-cols-3 gap-3 mb-8 max-w-md mx-auto lg:mx-0">
                <a href="/products/walkway-planks" class="bg-[#050f09]/80 rounded-sm aspect-square relative border border-emerald-500/20 hover:border-emerald-400/80 transition-colors flex items-end p-2 sm:p-3 shadow-inner group/card cursor-pointer overflow-hidden">
                  <span class="text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider relative z-20 group-hover/card:text-emerald-400 transition-colors">Walkway Planks</span>
                  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10"></div>
                  <Image src={img8_1} class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover/card:scale-110 group-hover/card:opacity-80 transition-all duration-500" alt="Planks" />
                </a>
                <a href="/products/staircase-tower" class="bg-[#050f09]/80 rounded-sm aspect-square relative border border-emerald-500/20 hover:border-emerald-400/80 transition-colors flex items-end p-2 sm:p-3 shadow-inner group/card cursor-pointer overflow-hidden">
                  <span class="text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider relative z-20 group-hover/card:text-emerald-400 transition-colors">Staircase Towers</span>
                  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10"></div>
                  <Image src={img8_2} class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover/card:scale-110 group-hover/card:opacity-80 transition-all duration-500" alt="Towers" />
                </a>
                <a href="/products/ringlock-scaffolding" class="bg-[#050f09]/80 rounded-sm aspect-square relative border border-emerald-500/20 hover:border-emerald-400/80 transition-colors flex items-end p-2 sm:p-3 shadow-inner group/card cursor-pointer overflow-hidden">
                  <span class="text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider relative z-20 group-hover/card:text-emerald-400 transition-colors">Ringlock Systems</span>
                  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10"></div>
                  <Image src={img8_3} class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover/card:scale-110 group-hover/card:opacity-80 transition-all duration-500" alt="Nodes" />
                </a>
              </div>
            </div>

            <a href="/products" class="mt-auto inline-flex h-14 w-full items-center justify-center rounded-sm border border-emerald-500/40 bg-emerald-500/10 px-8 text-sm font-bold text-emerald-400 hover:bg-emerald-500 hover:text-[#050f09] transition-all duration-300 uppercase tracking-widest relative z-10">
              VIEW ALL PRODUCTS
            </a>
          </div>

          <div class="flex flex-col bg-white rounded-sm p-8 sm:p-12 shadow-[0_0_40px_rgba(16,185,129,0.2)] relative overflow-hidden border-t-4 border-emerald-500 transform hover:-translate-y-1 transition-transform duration-300 z-10 text-center lg:text-left group">
             <div class="absolute inset-0 z-0 opacity-[0.04] mix-blend-multiply">
               <img src="https://images.unsplash.com/photo-1581092335397-9583eb92d232?q=80&w=1000&auto=format&fit=crop" alt="Engineering Blueprint" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
             </div>
             <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-bl-full pointer-events-none z-0"></div>
             
             <div class="relative z-10 flex-grow">
               <div class="inline-flex items-center gap-2 mb-4">
                 <span class="relative flex h-3 w-3">
                   <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                   <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                 </span>
                 <span class="text-[10px] font-bold uppercase tracking-widest text-emerald-700">Instant Pricing</span>
               </div>

               <h2 class="text-2xl sm:text-3xl font-black text-[#050f09] uppercase tracking-tight mb-4">
                 THE <span class="text-emerald-600">QUOTE ENGINE</span>
               </h2>
               
               <p class="font-jakarta text-zinc-600 text-sm sm:text-base leading-relaxed mb-6">
                 Skip spreadsheets and manual calculations. Get instant quotes based on your project parameters. Accurate pricing delivered instantly, zero delays.
               </p>
               
               <div class="bg-emerald-50 border-l-4 border-emerald-500 p-5 mb-8 rounded-r-sm text-left shadow-inner">
                 <p class="font-jakarta text-emerald-900 font-bold text-sm leading-relaxed">
                   Result: No more back-and-forth emails. Get everything you need to move forward in seconds.
                 </p>
               </div>
             </div>
             
             <a href="/quote" class="mt-auto w-full relative inline-flex h-14 items-center justify-center rounded-sm bg-[#050f09] px-8 text-sm font-extrabold text-white shadow-md hover:bg-emerald-500 hover:text-[#050f09] transition-colors duration-300 uppercase tracking-widest overflow-hidden z-10">
               <span class="relative z-20 flex items-center gap-2">
                 GENERATE INSTANT QUOTE &rarr;
               </span>
             </a>
          </div>

        </div>
      </div>
    </section>

    <!-- 4. LEADING MANUFACTURERS SECTION -->
    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10 relative overflow-hidden">
      <div class="absolute right-0 top-0 w-1/3 h-full bg-emerald-500/5 blur-[100px] pointer-events-none"></div>
      
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          
          <div class="order-2 lg:order-1 relative">
            <div class="absolute inset-0 bg-emerald-500/20 blur-3xl rounded-full transform -translate-x-10 translate-y-10"></div>
            
            <div class="relative w-full h-[400px] sm:h-[450px]">
              <div class="absolute top-0 left-0 w-3/4 h-[300px] sm:h-[350px] border border-emerald-500/20 rounded-sm overflow-hidden shadow-[0_0_40px_rgba(16,185,129,0.15)] group z-10">
                <Image src={img3_1} alt="Scaffolding and Formwork Manufacturing" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="absolute bottom-0 right-0 w-2/3 h-[200px] sm:h-[250px] border border-emerald-500/30 rounded-sm overflow-hidden shadow-2xl group z-20">
                <Image src={img3_2} alt="High Rise Scaffolding Execution" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              </div>
              
              <div class="absolute bottom-6 left-2 sm:left-4 bg-[#050f09]/95 backdrop-blur-md border border-emerald-500/40 p-4 rounded-sm shadow-2xl z-30 flex items-center gap-3 sm:gap-4">
                <span class="block text-3xl sm:text-4xl font-black text-emerald-400">26+</span>
                <span class="block text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-widest leading-tight">Years of Experience<br/>In Supplying Scaffolding</span>
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white uppercase tracking-tight mb-6 leading-tight">
              Leading Manufacturers of <span class="text-emerald-400">Staircase Towers and Walkway Planks</span> Across India
            </h2>
            <div class="space-y-6 font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium">
              <p>
                With a rich heritage of engineering excellence, <strong class="text-emerald-400">Prime Steeltech India</strong> has evolved into a leading player in the market for manufacturing and supplying elite scaffolding and formwork materials.
              </p>
              <p>
                You will find yourself working in a true partnership that results in an incredible experience, and an end product that exceeds all load-bearing and safety compliance expectations. We specialize in precision-engineered walkway planks and heavy-duty staircase towers designed for rapid deployment and maximum site safety.
              </p>
            </div>
            
            <ul class="mt-8 space-y-4">
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                <span class="text-sm font-bold text-white uppercase tracking-wide">PROVEN STRUCTURAL INTEGRITY</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                <span class="text-sm font-bold text-white uppercase tracking-wide">STRICT IN-HOUSE QUALITY ASSURANCE</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. BEST RINGLOCK / PLANKS -->
    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-16">
          <div>
            <div class="inline-flex items-center justify-center bg-emerald-500/10 border border-emerald-500/30 px-3 py-1.5 rounded-full mb-4">
              <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">Premium System Engineering</span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-6 leading-tight">
              HIGH-PERFORMANCE <span class="text-emerald-400">Ringlock Scaffolding System</span> in India
            </h2>
            <div class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium space-y-4">
              <p>
                We are recognized as one of the most reliable Scaffolding Manufacturers in India, offering superior support structures. Our flagship Ringlock Scaffolding System is fabricated from premium-grade materials and engineered to perform relentlessly in the most challenging project conditions.
              </p>
              <p>
                Featuring an advanced multi-directional rosette node design, our Ringlock systems allow up to eight connections at varying angles. This provides exemplary structural rigidity while significantly accelerating erection and dismantling times.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4 sm:gap-6 relative">
             <div class="absolute inset-0 bg-emerald-500/20 blur-3xl rounded-full"></div>
             <Image src={img4_1} class="w-full h-56 sm:h-72 object-cover rounded-md border-2 border-emerald-400 shadow-[0_0_25px_rgba(16,185,129,0.3)] relative z-10" alt="Ringlock Scaffolding Structure" />
             <Image src={img4_2} class="w-full h-56 sm:h-72 object-cover rounded-md border-2 border-emerald-400 shadow-[0_0_25px_rgba(16,185,129,0.3)] relative z-10 transform translate-y-6 sm:translate-y-8" alt="Industrial Ringlock Nodes" />
          </div>
        </div>

        <div class="bg-[#050f09] border border-emerald-500/20 rounded-sm p-8 sm:p-12 shadow-[0_0_40px_rgba(16,185,129,0.05)] relative overflow-hidden mt-12 sm:mt-24">
           <div class="absolute right-0 top-0 w-64 h-64 bg-emerald-500/5 blur-[80px] pointer-events-none"></div>
           
           <h3 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight mb-10 text-center sm:text-left relative z-10">
             Best <span class="text-emerald-400">Staircase Towers</span> and <span class="text-emerald-400">Walkway Planks</span> in India
           </h3>

           <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 relative z-10">
             <div class="flex flex-col sm:flex-row gap-6 items-start group">
                <div class="w-full sm:w-40 h-40 shrink-0 rounded-sm overflow-hidden border border-emerald-500/20 relative">
                  <Image src={img4_3} class="w-full h-full object-cover transform group-hover:scale-110 transition-duration-500" alt="Scaffolding Staircase Towers" />
                </div>
                <div>
                  <h4 class="text-white font-bold uppercase tracking-wider mb-2 text-sm group-hover:text-emerald-400 transition-colors">SCAFFOLDING STAIRCASE TOWERS</h4>
                  <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
                    Designed to safely handle heavy daily foot traffic. Our multi-level staircase towers feature secure interlocking parts, wide landing areas, and comfortable steps. This ensures your workers can easily and securely move up and down the construction site.

                  </p>
                  <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
                    We offer a wide range of staircase tower variants to meet any specific project requirements.
                  </p>
                </div>
             </div>

             <div class="flex flex-col sm:flex-row gap-6 items-start group">
                <div class="w-full sm:w-40 h-40 shrink-0 rounded-sm overflow-hidden border border-emerald-500/20 relative">
                  <Image src={img4_4} class="w-full h-full object-cover transform group-hover:scale-110 transition-duration-500" alt="Steel Walkway Planks" />
                </div>
                <div>
                  <h4 class="text-white font-bold uppercase tracking-wider mb-2 text-sm group-hover:text-emerald-400 transition-colors">Anti Skid Walkway Planks</h4>
                  <p class="font-jakarta text-zinc-400 text-xs sm:text-sm leading-relaxed">
                    Engineered with a perforated anti skid surface to prevent slips and falls. For enhanced structural integrity in demanding applications, we integrate welded stiffeners underneath the plank as needed, ensuring they resist bending, sagging, and wear, even under the weight of heavy materials and equipment.
                  </p>
                </div>
             </div>
           </div>
        </div>

      </div>
    </section>

    <!-- 6. NUMBER BAR -->
    <section class="relative py-16 bg-black border-b border-emerald-500/10 overflow-hidden">
      <div class="absolute inset-0 opacity-20 mix-blend-overlay grayscale">
        <img src="https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=2000&auto=format&fit=crop" alt="Industrial Steel Background" class="w-full h-full object-cover" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-emerald-900/20 via-transparent to-emerald-900/20 pointer-events-none"></div>
      
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center divide-x-0 lg:divide-x divide-emerald-500/20">
          <div class="flex flex-col items-center">
            <span class="text-4xl sm:text-5xl font-black text-emerald-400 mb-2 drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]">15k+</span>
            <span class="text-[10px] sm:text-xs font-bold text-emerald-100/70 uppercase tracking-widest">Tons of Steel Processed</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="text-4xl sm:text-5xl font-black text-emerald-400 mb-2 drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]">100%</span>
            <span class="text-[10px] sm:text-xs font-bold text-emerald-100/70 uppercase tracking-widest">OSHA & BIS Compliant</span>
          </div>
