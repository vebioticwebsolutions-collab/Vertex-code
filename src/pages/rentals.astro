<script is:inline>
  // Simple, smooth accordion logic for FAQs
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-btn');
      const content = item.querySelector('.faq-content');
      const icon = item.querySelector('svg');
      const title = item.querySelector('h4');

      btn.addEventListener('click', () => {
        const isOpen = content.style.maxHeight;

        // Close all other accordions first
        document.querySelectorAll('.faq-content').forEach(c => {
          c.style.maxHeight = null;
        });
        document.querySelectorAll('.faq-item svg').forEach(i => {
          i.style.transform = 'rotate(0deg)';
        });
        document.querySelectorAll('.faq-item h4').forEach(h => {
          h.classList.remove('text-emerald-400');
        });

        // Open the clicked one if it wasn't already open
        if (!isOpen) {
          content.style.maxHeight = content.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
          title.classList.add('text-emerald-400');
        }
      });
    });
  });
</script>