---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ==========================================
// CUSTOM ASSET IMPORTS
// ==========================================
// 1. Core Components Assets
import dimplesImg from '../../assets/walkway/(updated)Walkway Plank Anti-Skid Dimples.jpg';
import stiffnerImg from '../../assets/walkway/(updated)Walkway Plank Stiffner.jpg';
import hookImg from '../../assets/walkway/(updated)Walkway Plank Hook.jpg';
import gpSheetImg from '../../assets/walkway/(updated)Walkway Plank GP Sheet.jpg';

// 2. Extreme Environments Assets
import refineryImg from '../../assets/walkway/(updated)Walkway Plank Oil & Gas Refinery.jpg';
import highRiseImg from '../../assets/walkway/(updated)Walkway Plank High-Rise Buildings.jpg';
import solarImg from '../../assets/walkway/(updated)Walkway Plank Solar Rooftop.jpg';
import btmimg1 from '../../assets/walkway/ringlock.png';
import btmimg2 from '../../assets/walkway/staircase tower (1).jpg';
import btmimg3 from '../../assets/staircase/walkway plank (1).jpg';



---

<Layout title="Best Heavy-Duty Walkway Planks in India | Vertex by Primesteeltech">
  
  <main class="bg-[#050f09] min-h-screen pt-24 pb-16">
    
    <!-- ==========================================
         HERO SECTION (3D VIEWER)
         ========================================== -->
    <section class="pb-16 sm:pb-24 border-b border-emerald-500/10 relative overflow-visible">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none"></div>
      <div class="absolute top-40 left-0 w-[400px] h-[400px] bg-teal-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <nav class="mb-6 flex text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
          <a href="/products" class="hover:text-emerald-400 transition-colors">Products</a>
          <span class="mx-2">/</span>
          <span class="text-emerald-400">Walkway Planks</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
          
          <div class="lg:col-span-5 relative z-20">
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_20px_rgba(16,185,129,0.1)]">
              <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 animate-pulse"></span>
              Top Manufacturer in India
            </div>
            
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight mb-6 leading-[1.1]">
              Heavy-Duty Steel <br />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Walkway Planks</span>
            </h1>
            
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              The absolute foundation of safe industrial elevation. Our premium scaffolding walkway planks are roll-formed from high-tensile steel for maximum structural rigidity. Eliminate timber hazards with India's most secure, anti-slip scaffolding boards.
            </p>

            <div class="flex flex-wrap gap-3 mb-10">
              <span class="px-3 py-1.5 bg-[#0a170e] border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest rounded-sm flex items-center gap-2 shadow-inner">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> BIS Approved
              </span>
              <span class="px-3 py-1.5 bg-[#0a170e] border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest rounded-sm flex items-center gap-2 shadow-inner">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> OSHA Compliant
              </span>
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-4 mt-8">
              <a href="/quote" class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-bold text-[#050f09] uppercase tracking-widest hover:bg-emerald-400 transition-colors shadow-[0_0_20px_rgba(16,185,129,0.2)]">
                CONFIGURE & QUOTE
              </a>
              
              <a href="/pdfs/planks-specs.pdf" download class="group w-full sm:w-auto inline-flex h-12 items-center justify-center gap-2 rounded-[3px] border border-white/10 bg-transparent px-8 text-[13px] font-bold text-zinc-400 uppercase tracking-widest hover:border-emerald-500/40 hover:bg-emerald-500/5 hover:text-emerald-400 transition-colors">
                <svg class="h-4 w-4 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                DOWNLOAD SPECS
              </a>
            </div>
          </div>

          <div class="lg:col-span-7 relative z-10 w-full h-[400px] sm:h-[500px]">
            <div class="w-full h-full rounded-sm border border-white/10 overflow-hidden relative shadow-[0_0_40px_rgba(0,0,0,0.5)]">
              <Image src={btmimg3} alt="Anti-Skid Dimples" class="w-full h-full object-cover" />
            </div>
          </div>


        </div>
      </div>
    </section>

    <!-- ==========================================
         CORE COMPONENTS
         ========================================== -->
    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Core <span class="text-emerald-400">Components</span></h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6"></div>
          <p class="font-jakarta text-zinc-400 text-sm leading-relaxed">
            Every millimeter of our walkway planks is engineered for function. From the traction surface to the structural base, safety is built into the steel.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Component 1: Anti-Skid Dimples -->
          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={dimplesImg} alt="Punched Surface Detail" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Punched Surface</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Aggressive, extruded dimples that provide maximum boot grip and allow water, debris, and oil to pass through.</p>
          </div>

          <!-- Component 2: Stiffeners / Ribs -->
          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={stiffnerImg} alt="Structural Stiffener Detail" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Structural Stiffeners</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Deep-pressed continuous internal ribs that prevent bending, sagging, or material fatigue over long heavy-duty spans.</p>
          </div>

          <!-- Component 3: Hooks -->
          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={hookImg} alt="O-Type Hook Detail" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">O-Type Hooks</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Heavy-duty welded end hooks designed to sit perfectly and securely flush across standard tubular ledgers.</p>
          </div>

          <!-- Component 4: GP Sheet -->
          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={gpSheetImg} alt="Galvanized Plain Sheet" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Galvanized (GP) Sheet</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Roll-formed from premium GP steel sheets, ensuring absolute resistance to rust and weather degradation over its lifecycle.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         EXTREME ENVIRONMENTS
         ========================================== -->
    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Engineered for <span class="text-emerald-400">Extreme Environments</span></h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6"></div>
          <p class="font-jakarta text-zinc-400 text-sm leading-relaxed">
            Our steel scaffolding planks are the preferred choice for Tier-1 developers across India. Built to endure chemical exposure, heavy monsoon rains, and massive load demands.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Environment 1: Refinery -->
          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={refineryImg} alt="Refinery Scaffolding Planks" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Oil & Gas Refineries</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Fire-proof steel prevents the massive safety risks associated with traditional timber boards in highly flammable zones.</p>
            </div>
          </div>

          <!-- Environment 2: High-Rise -->
          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={highRiseImg} alt="High Rise Construction Walkways" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">High-Rise Commercial</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Solid interlocking prevents high-altitude uplift, ensuring platforms remain completely rigid during heavy storms.</p>
            </div>
          </div>

          <!-- Environment 3: Solar Rooftop -->
          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={solarImg} alt="Solar Rooftop Walkways" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Solar Rooftop Installations</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Provides secure, slip-resistant pathways across fragile commercial roof spaces for solar panel maintenance crews.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         ERECTION PROTOCOL
         ========================================== -->
    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="mb-12 md:flex md:items-end md:justify-between">
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Rapid <span class="text-emerald-400">Erection Protocol</span></h2>
            <div class="h-1 w-12 bg-emerald-400 mt-4 rounded-full"></div>
          </div>
          <p class="font-jakarta text-zinc-400 text-sm mt-4 md:mt-0 max-w-sm">Designed for maximum site velocity. Our planks require zero specialized tools for placement and securing.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
          <div class="hidden md:block absolute top-8 left-1/6 w-2/3 h-0.5 border-t border-dashed border-emerald-500/30 z-0"></div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">1</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Align on Ledgers</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Position the high-tensile O-hooks directly over the primary horizontal scaffolding ledgers.</p>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">2</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Snap to Lock</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Apply downward pressure to seat the hooks flush. The interlocking components securely grip the pipe below.</p>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">3</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Immediate Access</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">The platform is instantly load-bearing and ready for heavy foot traffic and material storage.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         TECHNICAL SPECIFICATIONS
         ========================================== -->
    <section class="py-16 sm:py-24 border-b border-emerald-500/10 relative bg-[#050f09]">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Technical <span class="text-emerald-400">Specifications</span></h2>
            <div class="h-1 w-12 bg-emerald-400 mt-4 rounded-full"></div>
          </div>
        </div>

        <div class="w-full overflow-x-auto rounded-sm border border-emerald-500/20 bg-[#0a170e] shadow-2xl">
          <table class="w-full text-left font-jakarta text-sm whitespace-nowrap">
            <thead class="bg-emerald-500/10 text-emerald-400 border-b border-emerald-500/20">
              <tr>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Parameter</th>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Specification</th>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Compliance Standard</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-emerald-500/10 text-zinc-300">
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Standard Widths</td>
                <td class="px-6 py-4">240 mm / 320 mm</td>
                <td class="px-6 py-4 text-zinc-500">BS EN 12811-1</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Standard Lengths</td>
                <td class="px-6 py-4">1.0m to 3.0m (Customizable)</td>
                <td class="px-6 py-4 text-zinc-500">System Compatible</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Steel Thickness</td>
                <td class="px-6 py-4">1.5 mm / 1.8 mm / 2.0 mm</td>
                <td class="px-6 py-4 text-zinc-500">Dependent on load class</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Live Load Capacity</td>
                <td class="px-6 py-4">Classes 4, 5, 6 (Up to 6 kN/m²)</td>
                <td class="px-6 py-4 text-zinc-500">OSHA Safety Factor</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Material & Coating</td>
                <td class="px-6 py-4">Pre-Galvanized (GP Sheet) / HDG</td>
                <td class="px-6 py-4 text-zinc-500">ISO 1461 Anti-Rust</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </section>

    <!-- ==========================================
         COMPLETE YOUR SYSTEM
         ========================================== -->
    <section class="py-16 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight">Complete Your <span class="text-emerald-400">System</span></h2>
          <a href="/products" class="hidden sm:block text-xs font-bold text-zinc-400 hover:text-emerald-400 transition-colors uppercase tracking-widest">View Full Catalog &rarr;</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          
          <a href="/products/ringlock-scaffolding" class="group relative overflow-hidden rounded-sm aspect-[21/9] sm:aspect-[16/9] bg-zinc-900 shadow-lg border border-emerald-500/20 flex items-end p-6 sm:p-8">
            <img src={btmimg1.src} class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700 z-0" alt="Ringlock Framework" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/50 to-transparent z-10"></div>
            <div class="relative z-20">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Flagship System</span>
              <h3 class="text-xl font-bold text-white uppercase tracking-wide group-hover:text-emerald-400 transition-colors">Ringlock Scaffolding</h3>
            </div>
            <div class="absolute bottom-6 sm:bottom-8 right-6 sm:right-8 z-20 w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30 group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-colors">
              <svg class="w-5 h-5 text-white group-hover:text-[#050f09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>

          <a href="/products/staircase-tower" class="group relative overflow-hidden rounded-sm aspect-[21/9] sm:aspect-[16/9] bg-zinc-900 shadow-lg border border-emerald-500/20 flex items-end p-6 sm:p-8">
            <img src={btmimg2.src} class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700 z-0" alt="Staircase Towers" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/50 to-transparent z-10"></div>
            <div class="relative z-20">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">High-Capacity Access</span>
              <h3 class="text-xl font-bold text-white uppercase tracking-wide group-hover:text-emerald-400 transition-colors">Staircase Towers</h3>
            </div>
            <div class="absolute bottom-6 sm:bottom-8 right-6 sm:right-8 z-20 w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30 group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-colors">
              <svg class="w-5 h-5 text-white group-hover:text-[#050f09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- ==========================================
         FAQ
         ========================================== -->
    <section class="py-16 sm:py-24 bg-[#050f09] border-t border-emerald-500/10">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-black text-center text-white uppercase tracking-tight mb-12">
          Walkway Planks <span class="text-emerald-400">FAQ</span>
        </h2>
        
        <div class="space-y-4 font-jakarta">
          
          <details class="group border border-emerald-500/20 bg-[#0a170e] rounded-sm open:border-emerald-500/50 transition-all duration-300">
            <summary class="flex items-center justify-between cursor-pointer p-6 font-bold text-white uppercase tracking-wider text-sm outline-none">
              Why are Vertex steel planks better than timber boards?
              <svg class="h-5 w-5 text-emerald-400 group-open:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
