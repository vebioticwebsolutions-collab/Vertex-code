---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ==========================================
// CUSTOM ASSET IMPORTS
// ==========================================
// 1. System Architecture Assets
import verticalImg from '../../assets/ringlock/Ringlock Vertical.png';
import ledgerImg from '../../assets/ringlock/Ringlock Ledger.png';
import braceImg from '../../assets/ringlock/Ringlock Diagonal Brace.png';
import jackImg from '../../assets/ringlock/Ringlock Adjustable Jack.png';

// 2. Extreme Environments Assets
import tanksImg from '../../assets/ringlock/Ringlock Curved & Round Tanks.png';
import bulletTrainImg from '../../assets/ringlock/Ringlock Bullet Train & Metrorail.png';
import eventsImg from '../../assets/ringlock/Ringlock Heavy Staging & Events.png';
---

<Layout title="Advanced Ringlock Scaffolding System India | Vertex by Primesteeltech">
  
  <main class="bg-[#050f09] min-h-screen pt-24 pb-16">
    
    <section class="pb-16 sm:pb-24 border-b border-emerald-500/10 relative overflow-visible">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none"></div>
      <div class="absolute top-40 left-0 w-[400px] h-[400px] bg-teal-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <nav class="mb-6 flex text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
          <a href="/products" class="hover:text-emerald-400 transition-colors">Products</a>
          <span class="mx-2">/</span>
          <span class="text-emerald-400">Ringlock Scaffolding</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
          
          <div class="lg:col-span-5 relative z-20">
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_20px_rgba(16,185,129,0.1)]">
              <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 animate-pulse"></span>
              Top Manufacturer in India
            </div>
            
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight mb-6 leading-[1.1]">
              Advanced <br />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Ringlock System</span>
            </h1>
            
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              The pinnacle of modular structural support. Our Ringlock scaffolding system utilizes precision-engineered multi-directional rosette nodes, allowing up to 8 connections per level. Build complex, high load-bearing geometries faster and safer than traditional tubular arrays.
            </p>

            <div class="flex flex-wrap gap-3 mb-10">
              <span class="px-3 py-1.5 bg-[#0a170e] border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest rounded-sm flex items-center gap-2 shadow-inner">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> BIS Approved Steel
              </span>
              <span class="px-3 py-1.5 bg-[#0a170e] border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest rounded-sm flex items-center gap-2 shadow-inner">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> ISO 9001:2015
              </span>
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-4 mt-8">
              <a href="/quote" class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-bold text-[#050f09] uppercase tracking-widest hover:bg-emerald-400 transition-colors shadow-[0_0_20px_rgba(16,185,129,0.2)]">
                CONFIGURE & QUOTE
              </a>
              
              <a href="/pdfs/ringlock-specs.pdf" download class="group w-full sm:w-auto inline-flex h-12 items-center justify-center gap-2 rounded-[3px] border border-white/10 bg-transparent px-8 text-[13px] font-bold text-zinc-400 uppercase tracking-widest hover:border-emerald-500/40 hover:bg-emerald-500/5 hover:text-emerald-400 transition-colors">
                <svg class="h-4 w-4 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                DOWNLOAD SPECS
              </a>
            </div>
          </div>

          <div class="lg:col-span-7 relative z-10 w-full h-[400px] sm:h-[500px]">
            <div id="3d-canvas-container" class="w-full h-full rounded-sm border border-white/10 bg-zinc-900/40 flex flex-col items-center justify-center text-zinc-500 overflow-hidden relative shadow-[0_0_40px_rgba(0,0,0,0.5)]">
              <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=1000&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-overlay grayscale"></div>
              
              <svg class="w-12 h-12 mb-4 text-zinc-600 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" /></svg>
              <span class="text-xs font-bold uppercase tracking-widest relative z-10">Mount 3D Viewer Here</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">System <span class="text-emerald-400">Architecture</span></h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6"></div>
          <p class="font-jakarta text-zinc-400 text-sm leading-relaxed">
            Unparalleled engineering at every node. Our Ringlock components form a rigid, unyielding matrix designed for extreme industrial environments.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={verticalImg} alt="Ringlock Vertical Standard" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Vertical Standards</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">High-tensile steel tubes featuring welded rosette rings every 500mm, forming the vertical backbone of the structure.</p>
          </div>

          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={ledgerImg} alt="Horizontal Ledgers" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Horizontal Ledgers</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Connecting pipes equipped with cast steel wedge heads that slide instantly into the vertical rosette slots.</p>
          </div>

          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={braceImg} alt="Diagonal Braces" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Diagonal Braces</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Vital lateral supports that utilize wedge-lock pins to create triangular rigidity, completely eliminating structural sway.</p>
          </div>

          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={jackImg} alt="Adjustable Base Jacks" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Adjustable Jacks</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Solid steel threaded bases designed to ensure the entire scaffold remains perfectly level on uneven ground.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Engineered for <span class="text-emerald-400">Extreme Environments</span></h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6"></div>
          <p class="font-jakarta text-zinc-400 text-sm leading-relaxed">
            Ringlock is the elite standard for complex structural demands. From circular tank maintenance to high-altitude facades, it adapts to any shape.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={tanksImg} alt="Petrochemical Tanks" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Curved & Tank Structures</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">The rosette node allows connections at non-right angles, perfectly hugging curved petrochemical tanks and silos.</p>
            </div>
          </div>

          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={bulletTrainImg} alt="Bullet Train Scaffolding" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Bullet Train & Metrorail</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Immense load capacity allows Ringlock to handle the heavy demands of modern elevated transit and railway engineering.</p>
            </div>
          </div>

          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={eventsImg} alt="Event Staging Support" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Heavy Event Staging</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Rapid assembly speed makes it the premier choice for erecting massive, temporary load-bearing stages and grandstands.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="mb-12 md:flex md:items-end md:justify-between">
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Rapid <span class="text-emerald-400">Erection Protocol</span></h2>
            <div class="h-1 w-12 bg-emerald-400 mt-4 rounded-full"></div>
          </div>
          <p class="font-jakarta text-zinc-400 text-sm mt-4 md:mt-0 max-w-sm">Hammer-lock technology means a 3-man crew can erect tons of support framework in hours, not days.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
          <div class="hidden md:block absolute top-8 left-1/6 w-2/3 h-0.5 border-t border-dashed border-emerald-500/30 z-0"></div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">1</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Slot the Ledger</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Slide the cast-steel wedge head of the horizontal ledger directly into one of the 8 holes on the vertical rosette.</p>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">2</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Hammer to Lock</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Drive the captive wedge pin down with a standard scaffolding hammer. The joint is now friction-locked and secure.</p>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">3</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Brace the Matrix</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Attach diagonal braces across the nodes. The entire bay is now self-squared and load-bearing ready.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 border-b border-emerald-500/10 relative bg-[#050f09]">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Technical <span class="text-emerald-400">Specifications</span></h2>
            <div class="h-1 w-12 bg-emerald-400 mt-4 rounded-full"></div>
          </div>
        </div>

        <div class="w-full overflow-x-auto rounded-sm border border-emerald-500/20 bg-[#0a170e] shadow-2xl">
          <table class="w-full text-left font-jakarta text-sm whitespace-nowrap">
            <thead class="bg-emerald-500/10 text-emerald-400 border-b border-emerald-500/20">
              <tr>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Parameter</th>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Specification</th>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Compliance Standard</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-emerald-500/10 text-zinc-300">
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Steel Grade</td>
                <td class="px-6 py-4">Q345 / S355 High-Tensile Steel</td>
                <td class="px-6 py-4 text-zinc-500">IS 1161 / EN 10219</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Tube Dimensions</td>
                <td class="px-6 py-4">48.3mm OD x 3.2mm Wall Thickness</td>
                <td class="px-6 py-4 text-zinc-500">Global Standard</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Rosette Capacity</td>
                <td class="px-6 py-4">Up to 8 connections (4 large, 4 small)</td>
                <td class="px-6 py-4 text-zinc-500">360-Degree Matrix</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Surface Finish</td>
                <td class="px-6 py-4">Hot-Dip Galvanized (>80 Microns)</td>
                <td class="px-6 py-4 text-zinc-500">ISO 1461 Anti-Rust</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Wedge Head</td>
                <td class="px-6 py-4">Precision Cast Steel</td>
                <td class="px-6 py-4 text-zinc-500">High Impact Resistant</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </section>

    <section class="py-16 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight">Complete Your <span class="text-emerald-400">System</span></h2>
          <a href="/products" class="hidden sm:block text-xs font-bold text-zinc-400 hover:text-emerald-400 transition-colors uppercase tracking-widest">View Full Catalog &rarr;</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          
          <a href="/products/walkway-planks" class="group relative overflow-hidden rounded-sm aspect-[21/9] sm:aspect-[16/9] bg-zinc-900 shadow-lg border border-emerald-500/20 flex items-end p-6 sm:p-8">
            <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?q=80&w=800&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700 z-0" alt="Walkway Planks" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/50 to-transparent z-10"></div>
            <div class="relative z-20">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Safe Elevation</span>
              <h3 class="text-xl font-bold text-white uppercase tracking-wide group-hover:text-emerald-400 transition-colors">Walkway Planks</h3>
            </div>
            <div class="absolute bottom-6 sm:bottom-8 right-6 sm:right-8 z-20 w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30 group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-colors">
              <svg class="w-5 h-5 text-white group-hover:text-[#050f09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>

          <a href="/products/staircase-tower" class="group relative overflow-hidden rounded-sm aspect-[21/9] sm:aspect-[16/9] bg-zinc-900 shadow-lg border border-emerald-500/20 flex items-end p-6 sm:p-8">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700 z-0" alt="Staircase Towers" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/50 to-transparent z-10"></div>
            <div class="relative z-20">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">High-Capacity Access</span>
              <h3 class="text-xl font-bold text-white uppercase tracking-wide group-hover:text-emerald-400 transition-colors">Staircase Towers</h3>
            </div>
            <div class="absolute bottom-6 sm:bottom-8 right-6 sm:right-8 z-20 w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30 group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-colors">
              <svg class="w-5 h-5 text-white group-hover:text-[#050f09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-t border-emerald-500/10">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-black text-center text-white uppercase tracking-tight mb-12">
          Ringlock Scaffolding <span class="text-emerald-400">FAQ</span>
        </h2>
        
        <div class="space-y-4 font-jakarta">
          
          <details class="group border border-emerald-500/20 bg-[#0a170e] rounded-sm open:border-emerald-500/50 transition-all duration-300">
            <summary class="flex items-center justify-between cursor-pointer p-6 font-bold text-white uppercase tracking-wider text-sm outline-none">
              Why choose Ringlock over traditional Cuplock scaffolding?
              <svg class="h-5 w-5 text-emerald-400 group-open:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
