---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ==========================================
// CUSTOM ASSET IMPORTS
// ==========================================
// 1. System Architecture Assets
import cuplockImg from '../../assets/staircase/Staircase Tower Cuplock Component.png';
import handrailImg from '../../assets/staircase/Staircase Tower Handrail.png';
import landingImg from '../../assets/staircase/(updated) Staircase Tower resting landing.jpg';
import stepArmImg from '../../assets/staircase/(updated) Staircase Tower step arm.jpg'; // <-- ADDED STEP ARM

// 2. Extreme Environments Assets
import deepPitsImg from '../../assets/staircase/Staircase Tower Deep Pits & Excavation.png';
import bulletTrainImg from '../../assets/staircase/Staircase Tower Bullet Train & Metrorail.png';
import plantMaintImg from '../../assets/staircase/Staricase Tower Plant & refinery Maintenance.png';
---

<Layout title="Heavy-Duty Staircase Towers India | Vertex by Primesteeltech">
  
  <script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "Heavy-Duty Scaffolding Staircase Tower",
  "image": "https://www.yourdomain.com/assets/staircase-tower.jpg",
  "description": "OSHA-compliant modular staircase tower with anti-slip resting landings, engineered for high-capacity industrial worker egress.",
  "brand": {
    "@type": "Brand",
    "name": "Vertex by Primesteeltech"
  },
  "material": "Hot-Dip Galvanized Steel",
  "offers": {
    "@type": "AggregateOffer",
    "availability": "https://schema.org/InStock",
    "offerCount": "1",
    "priceCurrency": "INR"
  }
}
</script>
  <main class="bg-[#050f09] min-h-screen pt-24 pb-16">
    
    <section class="pb-16 sm:pb-24 border-b border-emerald-500/10 relative overflow-visible">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none"></div>
      <div class="absolute top-40 left-0 w-[400px] h-[400px] bg-teal-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <nav class="mb-6 flex text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
          <a href="/products" class="hover:text-emerald-400 transition-colors">Products</a>
          <span class="mx-2">/</span>
          <span class="text-emerald-400">Staircase Towers</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
          
          <div class="lg:col-span-5 relative z-20">
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_20px_rgba(16,185,129,0.1)]">
              <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 animate-pulse"></span>
              High-Capacity Worker Egress
            </div>
            
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight mb-6 leading-[1.1]">
              Heavy-Duty <br />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Staircase Towers</span>
            </h1>
            
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              Engineered for safe, rapid vertical transit. Our modular staircase towers eliminate the dangers of vertical ladder climbing. Built seamlessly into our scaffolding matrices, they support high-density worker movement and heavy tool transport simultaneously.
            </p>

            <div class="flex flex-wrap gap-3 mb-10">
              <span class="px-3 py-1.5 bg-[#0a170e] border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest rounded-sm flex items-center gap-2 shadow-inner">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> OSHA Fall Protected
              </span>
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-4 mt-8">
              <a href="/quote" class="w-full sm:w-auto inline-flex h-12 items-center justify-center rounded-[3px] bg-emerald-500 px-8 text-[13px] font-bold text-[#050f09] uppercase tracking-widest hover:bg-emerald-400 transition-colors shadow-[0_0_20px_rgba(16,185,129,0.2)]">
                CONFIGURE & QUOTE
              </a>
              
              <a href="/pdfs/staircase-specs.pdf" download class="group w-full sm:w-auto inline-flex h-12 items-center justify-center gap-2 rounded-[3px] border border-white/10 bg-transparent px-8 text-[13px] font-bold text-zinc-400 uppercase tracking-widest hover:border-emerald-500/40 hover:bg-emerald-500/5 hover:text-emerald-400 transition-colors">
                <svg class="h-4 w-4 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                DOWNLOAD SPECS
              </a>
            </div>
          </div>

          <div class="lg:col-span-7 relative z-10 w-full h-[400px] sm:h-[500px]">
            <div id="3d-canvas-container" class="w-full h-full rounded-sm border border-white/10 bg-zinc-900/40 flex flex-col items-center justify-center text-zinc-500 overflow-hidden relative shadow-[0_0_40px_rgba(0,0,0,0.5)]">
              <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1590644365607-1c5a39178125?q=80&w=1000&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-overlay grayscale"></div>
              
              <svg class="w-12 h-12 mb-4 text-zinc-600 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" /></svg>
              <span class="text-xs font-bold uppercase tracking-widest relative z-10">Mount 3D Viewer Here</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">System <span class="text-emerald-400">Architecture</span></h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6"></div>
          <p class="font-jakarta text-zinc-400 text-sm leading-relaxed">
            Eliminate vertical fatigue and ladder risks. Our staircase towers are wide, solid, and built exactly to OSHA egress standards.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          
          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={cuplockImg} alt="Cuplock Component" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Interlocking Architecture</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Heavy-duty structural components that drop directly onto standard ledgers, forming the unyielding base of the stairs.</p>
          </div>

          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={handrailImg} alt="Safety Handrails" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Safety Handrails</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Continuous tubular guards that lock into the outer rosettes, completely enclosing the staircase to prevent fall hazards.</p>
          </div>

          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={landingImg} alt="Resting Landings" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Resting Landings</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Wide, flat platforms situated between stair flights, allowing workers to rest or safely maneuver heavy equipment.</p>
          </div>

          <div class="bg-[#050f09] border border-emerald-500/10 rounded-sm p-6 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.1)] transition-all duration-300 group hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-square bg-zinc-900 rounded-sm mb-6 overflow-hidden relative border border-white/5">
              <Image src={stepArmImg} alt="Step Arm Component" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 group-hover:opacity-100 transition-all duration-500" />
            </div>
            <h3 class="text-sm font-bold text-emerald-400 uppercase tracking-wide mb-2">Heavy-Duty Step Arms</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Robust structural brackets that securely lock into the vertical standards, providing unyielding support for the anti-slip stair treads.</p>
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Engineered for <span class="text-emerald-400">Extreme Environments</span></h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6"></div>
          <p class="font-jakarta text-zinc-400 text-sm leading-relaxed">
            Wherever continuous, high-volume worker access is required, Vertex staircase towers provide a permanent-feeling solution in a temporary structure.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={deepPitsImg} alt="Deep Excavation Access" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Deep Pits & Excavation</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Provides safe, low-angle descent into deep foundation pits where traditional ladders pose severe slip risks.</p>
            </div>
          </div>

          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={bulletTrainImg} alt="Bullet Train & Metrorail Projects" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Bullet Train & Metrorail</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Provides continuous, high-volume structural access for massive elevated transit and railway projects.</p>
            </div>
          </div>

          <div class="group relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 bg-zinc-900">
            <Image src={plantMaintImg} alt="Industrial Plant Maintenance" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2 group-hover:text-emerald-400 transition-colors">Plant & Refinery Maintenance</h3>
              <p class="font-jakarta text-xs text-zinc-300 leading-relaxed">Wide stair treads allow engineers to safely carry heavy diagnostic tools and parts up to operational pipeline levels.</p>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="mb-12 md:flex md:items-end md:justify-between">
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Rapid <span class="text-emerald-400">Erection Protocol</span></h2>
            <div class="h-1 w-12 bg-emerald-400 mt-4 rounded-full"></div>
          </div>
          <p class="font-jakarta text-zinc-400 text-sm mt-4 md:mt-0 max-w-sm">A plug-and-play addition. Stair stringers lock directly into your existing scaffolding nodes without custom fittings.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
          <div class="hidden md:block absolute top-8 left-1/6 w-2/3 h-0.5 border-t border-dashed border-emerald-500/30 z-0"></div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">1</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Erect the Bay</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Establish a standard 2.0m x 2.0m (or custom) scaffolding bay using Ringlock or Cuplock verticals.</p>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">2</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Drop in Stringers</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Hook the heavy-duty diagonal stair stringers over the horizontal ledgers, ensuring the safety latches engage.</p>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-[#050f09] border-2 border-emerald-500 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <span class="text-xl font-black text-emerald-400">3</span>
            </div>
            <h3 class="text-white font-bold uppercase tracking-wider text-sm mb-2">Slot the Treads</h3>
            <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Lay the anti-slip steel treads onto the stringer brackets. Secure the outer handrails to finalize the tower.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 border-b border-emerald-500/10 relative bg-[#050f09]">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight">Technical <span class="text-emerald-400">Specifications</span></h2>
            <div class="h-1 w-12 bg-emerald-400 mt-4 rounded-full"></div>
          </div>
        </div>

        <div class="w-full overflow-x-auto rounded-sm border border-emerald-500/20 bg-[#0a170e] shadow-2xl">
          <table class="w-full text-left font-jakarta text-sm whitespace-nowrap">
            <thead class="bg-emerald-500/10 text-emerald-400 border-b border-emerald-500/20">
              <tr>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Parameter</th>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Specification</th>
                <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Compliance Standard</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-emerald-500/10 text-zinc-300">
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Stair Width</td>
                <td class="px-6 py-4">0.8m to 1.2m (Variable Configurations)</td>
                <td class="px-6 py-4 text-zinc-500">Allows passing traffic</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Tread Capacity</td>
                <td class="px-6 py-4">Up to 5.0 kN/m² (Heavy Industrial)</td>
                <td class="px-6 py-4 text-zinc-500">BS EN 12811-1</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Handrail Height</td>
                <td class="px-6 py-4">Minimum 1.0m above nose of tread</td>
                <td class="px-6 py-4 text-zinc-500">OSHA Fall Protection</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Flight Rise</td>
                <td class="px-6 py-4">1.5m / 2.0m Vertical increments</td>
                <td class="px-6 py-4 text-zinc-500">System Compatible</td>
              </tr>
              <tr class="hover:bg-emerald-500/5 transition-colors">
                <td class="px-6 py-4 font-semibold text-white">Surface Finish</td>
                <td class="px-6 py-4">Hot-Dip / Pre-Galvanized Steel</td>
                <td class="px-6 py-4 text-zinc-500">ISO 1461 Anti-Rust</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </section>

    <section class="py-16 bg-[#0a170e] border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight">Complete Your <span class="text-emerald-400">System</span></h2>
          <a href="/products" class="hidden sm:block text-xs font-bold text-zinc-400 hover:text-emerald-400 transition-colors uppercase tracking-widest">View Full Catalog &rarr;</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          
          <a href="/products/ringlock-scaffolding" class="group relative overflow-hidden rounded-sm aspect-[21/9] sm:aspect-[16/9] bg-zinc-900 shadow-lg border border-emerald-500/20 flex items-end p-6 sm:p-8">
            <img src="https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=800&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700 z-0" alt="Ringlock Framework" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/50 to-transparent z-10"></div>
            <div class="relative z-20">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Flagship System</span>
              <h3 class="text-xl font-bold text-white uppercase tracking-wide group-hover:text-emerald-400 transition-colors">Ringlock Scaffolding</h3>
            </div>
            <div class="absolute bottom-6 sm:bottom-8 right-6 sm:right-8 z-20 w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30 group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-colors">
              <svg class="w-5 h-5 text-white group-hover:text-[#050f09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7-7m7-7H3"/></svg>
            </div>
          </a>

          <a href="/products/walkway-planks" class="group relative overflow-hidden rounded-sm aspect-[21/9] sm:aspect-[16/9] bg-zinc-900 shadow-lg border border-emerald-500/20 flex items-end p-6 sm:p-8">
            <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?q=80&w=800&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700 z-0" alt="Walkway Planks" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-[#050f09]/50 to-transparent z-10"></div>
            <div class="relative z-20">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Safe Elevation</span>
              <h3 class="text-xl font-bold text-white uppercase tracking-wide group-hover:text-emerald-400 transition-colors">Walkway Planks</h3>
            </div>
            <div class="absolute bottom-6 sm:bottom-8 right-6 sm:right-8 z-20 w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30 group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-colors">
              <svg class="w-5 h-5 text-white group-hover:text-[#050f09]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7-7m7-7H3"/></svg>
            </div>
          </a>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-t border-emerald-500/10">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-black text-center text-white uppercase tracking-tight mb-12">
          Staircase Towers <span class="text-emerald-400">FAQ</span>
        </h2>
        
        <div class="space-y-4 font-jakarta">
          
