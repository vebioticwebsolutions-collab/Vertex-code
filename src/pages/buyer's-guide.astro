---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Buyer's Guides | Prime Steel Tech">

<main class="bg-[#2b332a] min-h-screen pt-24">

  <!-- Hero -->

  <section class="pb-20">

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">

        <span class="inline-flex px-5 py-2 rounded-full
        border border-emerald-500/30
        bg-emerald-500/10
        text-emerald-400
        text-xs
        font-bold
        uppercase
        tracking-widest">

          Buyer Guides

        </span>

        <h1 class="mt-8 text-5xl font-black text-white uppercase">

          Technical Buyer's Guides

        </h1>

        <p class="mt-6 max-w-2xl mx-auto text-zinc-400 font-jakarta">

          Explore our comprehensive buyer guides designed to help
          you choose the right scaffolding products for your project.

        </p>

      </div>



      <!-- Cards -->

      <div class="grid md:grid-cols-3 gap-8">


        <!-- Ringlock -->

        <a
        href="/products/ringlock-guide"
        class="group relative overflow-hidden rounded-sm
        border border-white/10
        h-[360px]
        flex items-end p-8">

          <img
          src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?q=80&w=1600"
          class="absolute inset-0 h-full w-full object-cover
          group-hover:scale-105 transition duration-700" />

          <div class="absolute inset-0
          bg-gradient-to-t
          from-[#1e241d]
          via-[#1e241dcc]
          to-transparent">
          </div>

          <div class="relative z-10">

            <span class="block text-[11px]
            font-bold
            uppercase
            tracking-widest
            text-emerald-400 mb-3">

              Industrial Scaffolding

            </span>

            <h2 class="text-3xl font-black text-white uppercase">

              Ringlock Buyer's Guide

            </h2>

          </div>

        </a>



        <!-- Walkway -->

        <a
        href="/products/walkway-guide"
        class="group relative overflow-hidden rounded-sm
        border border-white/10
        h-[360px]
        flex items-end p-8">

          <img
          src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?q=80&w=1600"
          class="absolute inset-0 h-full w-full object-cover
          group-hover:scale-105 transition duration-700" />

          <div class="absolute inset-0
          bg-gradient-to-t
          from-[#1e241d]
          via-[#1e241dcc]
          to-transparent">
          </div>

          <div class="relative z-10">

            <span class="block text-[11px]
            font-bold
            uppercase
            tracking-widest
            text-emerald-400 mb-3">

              Safe Elevation

            </span>

            <h2 class="text-3xl font-black text-white uppercase">

              Walkway Plank Buyer's Guide

            </h2>

          </div>

        </a>



        <!-- Staircase -->

        <a
        href="/products/staircase-guide"
        class="group relative overflow-hidden rounded-sm
        border border-white/10
        h-[360px]
        flex items-end p-8">

          <img
          src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=1600"
          class="absolute inset-0 h-full w-full object-cover
          group-hover:scale-105 transition duration-700" />

          <div class="absolute inset-0
          bg-gradient-to-t
          from-[#1e241d]
          via-[#1e241dcc]
          to-transparent">
          </div>

          <div class="relative z-10">

            <span class="block text-[11px]
            font-bold
            uppercase
            tracking-widest
            text-emerald-400 mb-3">

              High Capacity Access

            </span>

            <h2 class="text-3xl font-black text-white uppercase">

              Staircase Tower Buyer's Guide

            </h2>

          </div>

        </a>


      </div>

    </div>

  </section>

</main>

</Layout>



<style is:global>

@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

.font-jakarta{

font-family:'Plus Jakarta Sans',sans-serif;

}

</style>