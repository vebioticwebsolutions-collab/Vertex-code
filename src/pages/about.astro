---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Vertex | Elite Scaffolding & Walkway Plank Manufacturers in Mumbai, India">
  
  <main class="bg-[#050f09] min-h-screen pt-16 pb-16 overflow-hidden">
    
    <section class="relative pb-16 sm:pb-24 border-b border-emerald-500/10 text-center overflow-visible z-10">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#10b98105_1px,transparent_1px),linear-gradient(to_bottom,#10b98105_1px,transparent_1px)] bg-[size:3rem_3rem] sm:bg-[size:4rem_4rem] z-0"></div>
      
      <div class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-emerald-500/15 blur-[150px] rounded-full pointer-events-none animate-pulse z-0"></div>
      <div class="absolute top-20 left-10 w-[400px] h-[400px] bg-teal-500/10 blur-[120px] rounded-full pointer-events-none z-0"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 flex flex-col items-center pt-16">
        
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-[11px] font-bold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_25px_rgba(16,185,129,0.2)] backdrop-blur-md">
          <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 animate-ping"></span>
          <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-400 absolute"></span>
          Mumbai Headquarters
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight mb-6 leading-[1.1]">
          FORGED IN STEEL <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-emerald-400 to-teal-500 drop-shadow-lg">BUILT ON TRUST </span>
        </h1>
        
        <p class="font-jakarta text-zinc-300 text-sm sm:text-base lg:text-lg leading-relaxed max-w-3xl font-medium">
          High-capacity structural steel scaffolding engineered to meet the massive demands of modern Indian infrastructure
        </p>
      </div>
    </section>

    <section class="py-12 bg-[#0a170e]/80 backdrop-blur-xl border-b border-emerald-500/10 relative z-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8 divide-x-0 sm:divide-x divide-emerald-500/20 text-center">
          
          <div class="flex flex-col items-center p-4 group">
            <span class="text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-br from-emerald-300 to-emerald-500 mb-2 group-hover:scale-110 transition-transform duration-500 drop-shadow-[0_0_10px_rgba(16,185,129,0.5)]">26+</span>
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Years Industry Heritage</span>
          </div>
          <div class="flex flex-col items-center p-4 border-t sm:border-t-0 border-emerald-500/20 text-center group">
            <span class="text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-br from-emerald-300 to-emerald-500 mb-2 group-hover:scale-110 transition-transform duration-500 drop-shadow-[0_0_10px_rgba(16,185,129,0.5)]">ISO</span>
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">9001:2015 Certified</span>
          </div>
          <div class="flex flex-col items-center p-4 border-t md:border-t-0 border-emerald-500/20 text-center group">
            <span class="text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-br from-emerald-300 to-emerald-500 mb-2 group-hover:scale-110 transition-transform duration-500 drop-shadow-[0_0_10px_rgba(16,185,129,0.5)]">Q345</span>
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">High-Tensile Steel</span>
          </div>
          <div class="flex flex-col items-center p-4 border-t md:border-t-0 border-emerald-500/20 text-center group">
            <span class="text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-br from-emerald-300 to-emerald-500 mb-2 group-hover:scale-110 transition-transform duration-500 drop-shadow-[0_0_10px_rgba(16,185,129,0.5)]">100%</span>
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">OSHA & BIS Compliant</span>
          </div>

        </div>
      </div>
    </section>

    <section class="relative py-16 sm:py-24 bg-[#050f09] overflow-hidden border-b border-emerald-500/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          
          <div class="relative aspect-[4/3] rounded-sm overflow-hidden shadow-[0_0_40px_rgba(16,185,129,0.15)] border border-emerald-500/30 group">
            <div class="absolute inset-0 bg-emerald-500/10 group-hover:bg-transparent transition-colors duration-700 z-10 mix-blend-overlay"></div>
            <img 
              src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=2070&auto=format&fit=crop" 
              alt="Primesteeltech Steel Scaffolding Manufacturing Facility" 
              class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 transform group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050f09] via-transparent to-transparent z-10"></div>
            
            <div class="absolute bottom-0 left-0 bg-[#0a170e]/90 backdrop-blur-md p-6 border-t-4 border-emerald-400 z-20 max-w-[300px] shadow-[0_-10px_30px_rgba(16,185,129,0.2)]">
              <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">Parent Company</span>
              <span class="block text-xl font-black text-white tracking-widest">PRIMESTEELTECH</span>
            </div>
          </div>

          <div>
            <div class="inline-flex items-center gap-2 rounded-sm border border-emerald-500/30 bg-emerald-500/10 px-3 py-1.5 text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-6">
              Engineering Heritage
            </div>
            
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-6">
              A Legacy of <br/><span class="text-emerald-400">Structural Integrity</span>
            </h2>
            
            <div class="space-y-6 font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium">
              <p>
                Established in 2011, Prime Steeltech India Pvt. Ltd. is backed by industry expertise that dates back to 1997, bringing nearly three decades of experience in scaffolding and construction support solutions. Founded with a commitment to safety, quality, and reliability, we have become a trusted partner for Tier-1 infrastructure developers across India.
              </p>
              <p>
                Through stringent quality control and rigorous load-bearing testing, we manufacture high-performance Ringlock Scaffolding Systems, Walkway Planks, Staircase Towers, and other engineered access solutions designed to meet the demands of modern construction and industrial projects. 
              </p>
              <p>
                Beyond manufacturing, we provide end-to-end solutions including structural layout design, supply, and custom fabrication, helping clients improve efficiency while maintaining the highest safety standards.
              </p>
              <p>
                In addition to serving the domestic market, Prime Steeltech has established a strong international presence, supporting major projects in the UAE and Saudi Arabia, including those associated with ADNOC and Aramco. Our focus remains the same—delivering safe, reliable, and engineered scaffolding solutions that projects can depend on
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10 relative overflow-hidden">
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-emerald-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
        
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4 drop-shadow-md">
            OUR VISION <span class="text-emerald-400">OUR MISSION</span>
          </h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6 shadow-[0_0_10px_rgba(16,185,129,0.8)]"></div>
          <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed">
           Our vision is to become India's most trusted scaffolding and Formworks partner that enables the world's infrastructure growth.Our mission is to provide high quality scaffolding and formwork components to every industry we serve, while ensuring the highest standards of safety, reliability, and customer satisfaction.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 max-w-4xl mx-auto">
          
          <div class="bg-[#050f09]/80 backdrop-blur-sm border border-emerald-500/20 rounded-sm p-10 text-center hover:border-emerald-400 hover:shadow-[0_0_40px_rgba(16,185,129,0.15)] transition-all duration-500 group relative overflow-hidden transform hover:-translate-y-2">
            <div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="w-48 h-48 mx-auto rounded-full bg-zinc-900 border-2 border-emerald-500/30 p-1.5 mb-8 relative overflow-hidden group-hover:border-emerald-400 transition-colors shadow-lg">
              <img src="https://placehold.co/400x400/151914/ffffff?text=Dharmesh+Bhatt" alt="Dharmesh Bhatt" class="w-full h-full object-cover rounded-full grayscale group-hover:grayscale-0 transition-all duration-700" />
            </div>
            
            <h3 class="text-2xl font-black text-white uppercase tracking-wider mb-2 relative z-10">Dharmesh Bhatt</h3>
            <p class="inline-block bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 rounded-sm text-emerald-400 font-bold text-xs uppercase tracking-widest mb-8 relative z-10">Founder Director</p>
            
            <div class="space-y-4 font-jakarta text-sm text-zinc-300 relative z-10">
              <a href="mailto:dharmesh@primesteeltech.co.in" class="flex items-center justify-center gap-2 hover:text-emerald-400 transition-colors group/link">
                <svg class="w-4 h-4 text-emerald-500 group-hover/link:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                dharmesh@primesteeltech.co.in
              </a>
              <a href="tel:09322321421" class="flex items-center justify-center gap-2 hover:text-emerald-400 transition-colors group/link">
                <svg class="w-4 h-4 text-emerald-500 group-hover/link:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                09322321421
              </a>
            </div>
          </div>

          <div class="bg-[#050f09]/80 backdrop-blur-sm border border-emerald-500/20 rounded-sm p-10 text-center hover:border-emerald-400 hover:shadow-[0_0_40px_rgba(16,185,129,0.15)] transition-all duration-500 group relative overflow-hidden transform hover:-translate-y-2">
            <div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="w-48 h-48 mx-auto rounded-full bg-zinc-900 border-2 border-emerald-500/30 p-1.5 mb-8 relative overflow-hidden group-hover:border-emerald-400 transition-colors shadow-lg">
              <img src="https://placehold.co/400x400/151914/ffffff?text=Jayraj+Bhatt" alt="Jayraj Bhatt" class="w-full h-full object-cover rounded-full grayscale group-hover:grayscale-0 transition-all duration-700" />
            </div>
            
            <h3 class="text-2xl font-black text-white uppercase tracking-wider mb-2 relative z-10">Jayraj Bhatt</h3>
            <p class="inline-block bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 rounded-sm text-emerald-400 font-bold text-xs uppercase tracking-widest mb-8 relative z-10">Director - Business Dev.</p>
            
            <div class="space-y-4 font-jakarta text-sm text-zinc-300 relative z-10">
              <a href="mailto:jayraj@primesteeltech.co.in" class="flex items-center justify-center gap-2 hover:text-emerald-400 transition-colors group/link">
                <svg class="w-4 h-4 text-emerald-500 group-hover/link:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                jayraj@primesteeltech.co.in
              </a>
              <a href="tel:09324560020" class="flex items-center justify-center gap-2 hover:text-emerald-400 transition-colors group/link">
                <svg class="w-4 h-4 text-emerald-500 group-hover/link:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                09324560020
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-[#050f09] border-b border-emerald-500/10 relative overflow-hidden">
      <div class="absolute left-0 top-1/2 -translate-y-1/2 w-64 h-full bg-teal-500/5 blur-[120px] pointer-events-none"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4 drop-shadow-md">
            Core engineering<br/><span class="text-emerald-400">Pillars</span>
          </h2>
          <div class="h-1 w-12 bg-emerald-400 mx-auto mt-4 rounded-full mb-6 shadow-[0_0_10px_rgba(16,185,129,0.8)]"></div>
          <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed">
            We are a professionally managed entity promoted by self-employed technocrats. We don't just supply metal; we supply indigenous technology, expertise, and complete engineering solutions.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          
          <div class="bg-[#0a170e]/80 backdrop-blur-sm border border-emerald-500/20 p-8 rounded-sm hover:border-emerald-400 hover:shadow-[0_0_30px_rgba(16,185,129,0.15)] transition-all duration-500 group hover:-translate-y-2 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-bl-full pointer-events-none"></div>
            <div class="h-14 w-14 bg-[#050f09] border border-emerald-500/30 rounded-sm flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 group-hover:border-emerald-400 transition-colors shadow-inner relative z-10">
              <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            </div>
            <h3 class="text-white font-black uppercase tracking-widest text-base mb-3 group-hover:text-emerald-300 transition-colors relative z-10">Engineered for Performance</h3>
            <p class="font-jakarta text-zinc-400 text-sm leading-relaxed relative z-10">
              Every component is designed and manufactured to meet demanding industrial requirements, delivering exceptional strength, stability, and long-term durability.
            </p>
          </div>

          <div class="bg-[#0a170e]/80 backdrop-blur-sm border border-emerald-500/20 p-8 rounded-sm hover:border-emerald-400 hover:shadow-[0_0_30px_rgba(16,185,129,0.15)] transition-all duration-500 group hover:-translate-y-2 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-bl-full pointer-events-none"></div>
            <div class="h-14 w-14 bg-[#050f09] border border-emerald-500/30 rounded-sm flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 group-hover:border-emerald-400 transition-colors shadow-inner relative z-10">
              <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-white font-black uppercase tracking-widest text-base mb-3 group-hover:text-emerald-300 transition-colors relative z-10">Quality Without Compromise</h3>
            <p class="font-jakarta text-zinc-400 text-sm leading-relaxed relative z-10">
              From raw material selection to final inspection, every stage of production is governed by rigorous quality standards to ensure consistent excellence.
            </p>
          </div>

          <div class="bg-[#0a170e]/80 backdrop-blur-sm border border-emerald-500/20 p-8 rounded-sm hover:border-emerald-400 hover:shadow-[0_0_30px_rgba(16,185,129,0.15)] transition-all duration-500 group hover:-translate-y-2 relative overflow-hidden md:col-span-2 lg:col-span-1">
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-bl-full pointer-events-none"></div>
            <div class="h-14 w-14 bg-[#050f09] border border-emerald-500/30 rounded-sm flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 group-hover:border-emerald-400 transition-colors shadow-inner relative z-10">
              <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="text-white font-black uppercase tracking-widest text-base mb-3 group-hover:text-emerald-300 transition-colors relative z-10">Efficiency on Site</h3>
            <p class="font-jakarta text-zinc-400 text-sm leading-relaxed relative z-10">
              Thoughtfully engineered solutions enable quicker assembly, reduced downtime, and smoother project execution, resulting in measurable operational benefits.
            </p>
          </div>

        </div>
      </div>
    </section>

    <section class="relative py-16 sm:py-24 bg-[#0a170e] border-b border-emerald-500/10 overflow-hidden">
      <div class="absolute inset-0 opacity-20 z-0">
        <svg class="absolute inset-0 w-full h-full text-emerald-500/20" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="1"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#grid)" />
        </svg>
      </div>
      
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 z-10">
        
        <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 gap-6">
          <div>
            <div class="inline-flex items-center gap-2 rounded-sm border border-emerald-500/40 bg-[#050f09] px-3 py-1.5 text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-4 shadow-[0_0_15px_rgba(16,185,129,0.1)]">
              <span class="flex h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-400 animate-pulse"></span>
              Pan-India Supply Chain
            </div>
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight drop-shadow-md">
              Where We <span class="text-emerald-400">Deliver</span>
            </h2>
          </div>
          
          <a href="/find-us" class="group inline-flex h-12 items-center justify-center gap-2 rounded-[3px] border border-emerald-500/50 bg-[#050f09] px-8 text-[13px] font-bold uppercase tracking-[0.15em] text-emerald-400 transition-all hover:border-emerald-400 hover:bg-emerald-500/20 hover:text-white hover:-translate-y-0.5 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
            <svg class="h-4 w-4 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Find Us
          </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          
          <div class="order-2 lg:order-1">
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8 font-medium">
              Headquartered in Mumbai, Prime SteelTech operates a high-speed logistics network engineered to supply large-scale infrastructure projects without delay. We provide rapid, dedicated supply across key regions including the Pune–Kolhapur stretch, Nashik & Central Maharashtra, Goa–Ratnagiri, South Gujarat, the Surat–Ahmedabad corridor, and Northern Karnataka. For major projects, our reach extends nationwide—efficiently servicing South and Eastern India supported by our strategic sub-branch in Raipur.
            </p>

            <div class="grid grid-cols-3 gap-4 mb-10 p-5 bg-[#050f09]/80 backdrop-blur-sm border border-emerald-500/30 rounded-sm shadow-[0_0_30px_rgba(16,185,129,0.05)]">
              <div class="text-center border-r border-white/10">
                <span class="block text-xl sm:text-2xl font-black text-emerald-400 mb-1 drop-shadow-md">5+</span>
                <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">Strategic Hubs</span>
              </div>
              <div class="text-center border-r border-white/10">
                <span class="block text-xl sm:text-2xl font-black text-emerald-400 mb-1 drop-shadow-md">24/7</span>
                <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">Fleet Dispatch</span>
              </div>
              <div class="text-center">
                <span class="block text-xl sm:text-2xl font-black text-emerald-400 mb-1 drop-shadow-md">100%</span>
