---
import Layout from '../layouts/Layout.astro';

// 10 Projects for the Tablet Slideshow
const projects = [
  {
    title: "Mumbai Metro Line 3",
    client: "L&T Construction",
    scope: "1,200 Tons Ringlock",
    location: "Mumbai, Maharashtra",
    year: "2024",
    image: "https://images.unsplash.com/photo-1541888086925-0c1bb67f8149?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Adani Data Center",
    client: "Adani Infra",
    scope: "850 Tons Formwork",
    location: "Noida, Uttar Pradesh",
    year: "2024",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Worli High-Rise",
    client: "J. Kumar Infraprojects",
    scope: "Staircase Towers",
    location: "Mumbai, Maharashtra",
    year: "2023",
    image: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Coastal Road Project",
    client: "BMC / L&T",
    scope: "Heavy Duty Planks",
    location: "Mumbai, Maharashtra",
    year: "2024",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Pune IT Park",
    client: "Tata Projects",
    scope: "500 Tons Scaffolding",
    location: "Pune, Maharashtra",
    year: "2023",
    image: "https://images.unsplash.com/photo-1541888086925-0c1bb67f8149?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Surat Diamond Bourse",
    client: "PSP Projects",
    scope: "Architectural Nodes",
    location: "Surat, Gujarat",
    year: "2023",
    image: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Nhava Sheva Bridge",
    client: "L&T Heavy Civil",
    scope: "Bridge Formwork",
    location: "Navi Mumbai, Maharashtra",
    year: "2024",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Bangalore Metro Hub",
    client: "BMRCL",
    scope: "Telescopic Props",
    location: "Bengaluru, Karnataka",
    year: "2024",
    image: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Hyderabad Tech Park",
    client: "DLF",
    scope: "2,000 Walkway Planks",
    location: "Hyderabad, Telangana",
    year: "2023",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Delhi Airport Expansion",
    client: "GMR Group",
    scope: "Custom Ringlock Array",
    location: "New Delhi",
    year: "2024",
    image: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=800&auto=format&fit=crop"
  }
];
---

<Layout title="Our Projects | Vertex by Primesteeltech">
  
  <main style="background:#050f09; min-height:100vh; color:white; overflow:hidden; padding-top:6rem; position:relative;">
    
    <!-- Ambient glow -->
    <div style="position:absolute; top:0; left:50%; transform:translateX(-50%); width:100%; max-width:1000px; height:500px; background:radial-gradient(ellipse at center, rgba(16,185,129,0.1), transparent 70%); pointer-events:none;"></div>

    <!-- ===== 1. HERO ===== -->
    <section style="position:relative; padding:3rem 0 1.5rem; text-align:center; z-index:10;">
      <div style="max-width:64rem; margin:0 auto; padding:0 1rem;">
        
        <div style="display:inline-flex; align-items:center; gap:0.5rem; border-radius:9999px; border:1px solid rgba(16,185,129,0.4); background:rgba(16,185,129,0.1); padding:0.5rem 1rem; font-size:0.65rem; font-weight:700; color:#34d399; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:1.5rem; box-shadow:0 0 20px rgba(16,185,129,0.15);">
          <svg style="width:1rem;height:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" /></svg>
          Deployed Across Tier-1 Sites
        </div>

        <h1 style="font-size:clamp(1.8rem, 5vw, 3.5rem); font-weight:900; letter-spacing:-0.02em; text-transform:uppercase; line-height:1.1; margin-bottom:1.5rem; color:white;">
          The <span style="background:linear-gradient(90deg, #6ee7b7, #14b8a6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Vertex</span> Portfolio
        </h1>

        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(0.85rem, 2vw, 1rem); line-height:1.7; color:#a1a1aa; max-width:40rem; margin:0 auto; font-weight:500;">
          From extreme-altitude skyscrapers to heavy civil bridges, our structural arrays have served as the backbone for India's most ambitious infrastructure projects.
        </p>

      </div>
    </section>

    <!-- ===== 2. TABLET SHOWCASE ===== -->
    <section style="position:relative; padding:2rem 0 3rem; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:20;">
      
      <!-- Tablet Device Frame -->
      <div id="tabletDevice" style="position:relative; width:92%; max-width:820px; margin:0 auto;">
        
        <!-- Tablet Outer Shell -->
        <div style="background:linear-gradient(160deg, #1c1c2e 0%, #111118 40%, #1a1a28 100%); border-radius:24px; padding:10px; box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 4px 6px rgba(0,0,0,0.3), 0 20px 60px rgba(0,0,0,0.5), 0 0 80px rgba(16,185,129,0.05), inset 0 1px 0 rgba(255,255,255,0.04); position:relative; overflow:hidden;">
          
          <!-- Subtle bezel shine -->
          <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg, transparent 10%, rgba(255,255,255,0.08) 50%, transparent 90%);"></div>
          
          <!-- Top Bezel -->
          <div style="display:flex; align-items:center; justify-content:center; height:22px; position:relative; z-index:5;">
            <div style="width:8px; height:8px; border-radius:50%; background:radial-gradient(circle, #1e293b, #0f172a); box-shadow: 0 0 6px rgba(16,185,129,0.15), inset 0 0 3px rgba(16,185,129,0.1);"></div>
          </div>

          <!-- Screen Area -->
          <div style="border-radius:14px; overflow:hidden; background:#0a0a0a; position:relative; aspect-ratio:16/9;">
            
            <!-- Slides Container -->
            <div id="slidesTrack" style="display:flex; width:100%; height:100%; transition:transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
              
              {projects.map((project, index) => (
                <div class="project-slide" style="min-width:100%; height:100%; position:relative; flex-shrink:0;">
                  
                  <!-- Full Background Image -->
                  <img src={project.image} alt={project.title} loading={index < 2 ? "eager" : "lazy"} style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0.7;" />
                  
                  <!-- Dark overlay gradients -->
                  <div style="position:absolute; inset:0; background:linear-gradient(to right, rgba(5,15,9,0.92) 0%, rgba(5,15,9,0.6) 45%, transparent 100%); z-index:2;"></div>
                  <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(5,15,9,0.8) 0%, transparent 40%); z-index:2;"></div>
                  
                  <!-- Project Content -->
                  <div style="position:absolute; inset:0; z-index:5; display:flex; flex-direction:column; justify-content:center; padding:clamp(1.2rem, 4vw, 3rem) clamp(1.5rem, 5vw, 4rem);">
                    
                    <!-- Top Meta -->
                    <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:clamp(0.5rem, 1.5vw, 1rem); flex-wrap:wrap;">
                      <span style="font-size:clamp(0.55rem, 1.2vw, 0.7rem); font-weight:800; text-transform:uppercase; letter-spacing:0.12em; color:#34d399; background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25); padding:0.2rem 0.7rem; border-radius:99px;">{project.client}</span>
                      <span style="font-size:clamp(0.5rem, 1vw, 0.65rem); font-weight:600; color:#71717a; display:flex; align-items:center; gap:0.2rem;">
                        <svg style="width:0.7rem; height:0.7rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        {project.location}
                      </span>
                      <span style="font-size:clamp(0.5rem, 1vw, 0.6rem); font-weight:700; color:#52525b; text-transform:uppercase; letter-spacing:0.1em;">{project.year}</span>
                    </div>
                    
                    <!-- Title -->
                    <h3 style="font-size:clamp(1.2rem, 3.5vw, 2.4rem); font-weight:900; text-transform:uppercase; color:white; letter-spacing:-0.02em; line-height:1.15; margin-bottom:clamp(0.3rem, 1vw, 0.6rem); max-width:70%;">{project.title}</h3>
                    
                    <!-- Scope -->
                    <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:clamp(0.8rem, 2vw, 1.5rem);">
                      <span style="font-size:clamp(0.55rem, 1vw, 0.7rem); font-weight:700; text-transform:uppercase; letter-spacing:0.15em; color:#52525b;">Scope:</span>
                      <span style="font-size:clamp(0.6rem, 1.2vw, 0.8rem); font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#d4d4d8;">{project.scope}</span>
                    </div>

                    <!-- CTAs -->
                    <div style="display:flex; gap:clamp(0.4rem, 1vw, 0.75rem); flex-wrap:wrap;">
                      <a href="/quote" style="display:inline-flex; align-items:center; gap:0.4rem; padding:clamp(0.5rem, 1.2vw, 0.7rem) clamp(1rem, 2vw, 1.5rem); border-radius:6px; background:linear-gradient(135deg, #10b981, #14b8a6); color:#050f09; font-size:clamp(0.6rem, 1.1vw, 0.75rem); font-weight:800; text-transform:uppercase; letter-spacing:0.08em; text-decoration:none; box-shadow:0 0 20px rgba(16,185,129,0.3); transition:all 0.3s ease;">
                        <svg style="width:0.85rem; height:0.85rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        Configure
                      </a>
                      <a href="/quote" style="display:inline-flex; align-items:center; gap:0.4rem; padding:clamp(0.5rem, 1.2vw, 0.7rem) clamp(1rem, 2vw, 1.5rem); border-radius:6px; background:transparent; border:1.5px solid rgba(16,185,129,0.35); color:#34d399; font-size:clamp(0.6rem, 1.1vw, 0.75rem); font-weight:800; text-transform:uppercase; letter-spacing:0.08em; text-decoration:none; transition:all 0.3s ease;">
                        <svg style="width:0.85rem; height:0.85rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        Get Quote
                      </a>
                    </div>

                  </div>

                  <!-- Slide counter -->
                  <div style="position:absolute; bottom:clamp(0.8rem, 2vw, 1.5rem); right:clamp(1rem, 3vw, 2rem); z-index:10; font-size:clamp(0.6rem, 1vw, 0.75rem); font-weight:700; color:rgba(255,255,255,0.2); letter-spacing:0.05em;">
                    <span style="font-size:clamp(1rem, 2.5vw, 1.8rem); font-weight:900; color:rgba(255,255,255,0.15);">{String(index + 1).padStart(2, '0')}</span>
                    <span style="margin:0 0.3rem;">/</span>
                    <span>10</span>
                  </div>

                </div>
              ))}

            </div>

            <!-- Progress Bar at bottom of screen -->
            <div style="position:absolute; bottom:0; left:0; right:0; height:3px; background:rgba(255,255,255,0.05); z-index:20;">
              <div id="slideProgress" style="height:100%; width:10%; background:linear-gradient(90deg, #10b981, #14b8a6); border-radius:0 2px 2px 0; transition:width 0.5s ease;"></div>
            </div>

          </div>

          <!-- Bottom Bezel -->
          <div style="display:flex; align-items:center; justify-content:center; height:18px;">
            <div style="width:48px; height:4px; border-radius:99px; background:rgba(255,255,255,0.06);"></div>
          </div>

        </div>

        <!-- Navigation Arrows — OUTSIDE the tablet -->
        <button id="prevBtn" aria-label="Previous project" style="position:absolute; left:-20px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(10,23,14,0.9); border:1px solid rgba(16,185,129,0.25); color:#34d399; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.3s ease; z-index:30; backdrop-filter:blur(8px); box-shadow:0 4px 20px rgba(0,0,0,0.4);">
          <svg style="width:18px; height:18px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="nextBtn" aria-label="Next project" style="position:absolute; right:-20px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(10,23,14,0.9); border:1px solid rgba(16,185,129,0.25); color:#34d399; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.3s ease; z-index:30; backdrop-filter:blur(8px); box-shadow:0 4px 20px rgba(0,0,0,0.4);">
          <svg style="width:18px; height:18px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
        </button>

      </div>

      <!-- Dot Indicators -->
      <div id="dotNav" style="display:flex; align-items:center; justify-content:center; gap:8px; margin-top:1.5rem; position:relative; z-index:30;">
        {projects.map((_, index) => (
          <button class="slide-dot" data-idx={index} aria-label={`Project ${index + 1}`} style={`width:${index === 0 ? '28px' : '8px'}; height:8px; border-radius:99px; border:1px solid ${index === 0 ? '#10b981' : 'rgba(255,255,255,0.1)'}; background:${index === 0 ? '#10b981' : 'rgba(255,255,255,0.08)'}; cursor:pointer; transition:all 0.35s ease; padding:0; box-shadow:${index === 0 ? '0 0 12px rgba(16,185,129,0.4)' : 'none'};`}></button>
        ))}
      </div>

      <!-- Glowing reflection under tablet -->
      <div style="width:70%; max-width:700px; height:40px; margin-top:-10px; background:radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, transparent 70%); pointer-events:none;"></div>

    </section>

    <!-- ===== 3. ACTION HUB ===== -->
    <section style="padding:4rem 0 5rem; position:relative; background:#0a170e; border-top:1px solid rgba(16,185,129,0.2); z-index:30; box-shadow:0 -20px 50px rgba(0,0,0,0.5);">
      <div style="max-width:64rem; margin:0 auto; padding:0 1rem; text-align:center;">
        
        <h2 style="font-size:clamp(1.5rem, 4vw, 2.5rem); font-weight:900; color:white; text-transform:uppercase; letter-spacing:-0.02em; margin-bottom:0.75rem;">
          Ready for your <span style="color:#34d399;">Next Project?</span>
        </h2>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(0.85rem, 1.5vw, 1rem); color:#a1a1aa; margin-bottom:2.5rem; max-width:32rem; margin-left:auto; margin-right:auto;">
          Configure your scaffolding requirements or get an instant quote from our engineering team.
        </p>

        <div style="display:flex; flex-direction:column; gap:1rem; align-items:center; justify-content:center; max-width:36rem; margin:0 auto;">
          
          <!-- Primary CTA -->
          <a href="/quote" id="ctaPrimary" style="position:relative; width:100%; max-width:320px; display:inline-flex; height:56px; align-items:center; justify-content:center; gap:0.6rem; border-radius:4px; background:linear-gradient(135deg, #10b981, #14b8a6); color:#050f09; font-size:0.8rem; font-weight:900; text-transform:uppercase; letter-spacing:0.12em; text-decoration:none; box-shadow:0 0 30px rgba(16,185,129,0.35); transition:all 0.3s ease; overflow:hidden;">
            <span style="position:absolute; top:8px; right:8px; display:flex; width:12px; height:12px;">
              <span style="position:absolute; display:inline-flex; width:100%; height:100%; border-radius:50%; background:#f87171; opacity:0.75; animation:ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
              <span style="position:relative; display:inline-flex; width:12px; height:12px; border-radius:50%; background:#ef4444; border:2px solid #050f09;"></span>
            </span>
            <svg style="width:1.1rem; height:1.1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Configure & Quote
          </a>

          <!-- Secondary CTA -->
          <a href="/contact-us" id="ctaSecondary" style="width:100%; max-width:320px; display:inline-flex; height:56px; align-items:center; justify-content:center; gap:0.5rem; border-radius:4px; border:2px solid rgba(16,185,129,0.3); background:#050f09; color:#34d399; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; text-decoration:none; transition:all 0.3s ease; box-shadow:0 0 20px rgba(16,185,129,0.08);">
            Get In Touch
            <svg style="width:1rem; height:1rem; transition:transform 0.3s ease;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>

        </div>
      </div>
    </section>

    <!-- ===== 4. CALL SALES ===== -->
    <section style="padding:4rem 0; background:#050f09; border-top:1px solid rgba(255,255,255,0.05); position:relative; overflow:hidden; text-align:center; z-index:20;">
      <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); width:100%; max-width:600px; height:300px; background:radial-gradient(ellipse at center, rgba(16,185,129,0.05), transparent 70%); pointer-events:none;"></div>
      
      <div style="position:relative; max-width:48rem; margin:0 auto; padding:0 1rem;">
        <div style="width:64px; height:64px; margin:0 auto 1.5rem; background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; box-shadow:inset 0 0 20px rgba(16,185,129,0.15);">
          <svg style="width:2rem; height:2rem; color:#34d399;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        
        <h3 style="font-size:clamp(1.2rem, 3vw, 1.5rem); font-weight:900; color:white; text-transform:uppercase; letter-spacing:-0.01em; margin-bottom:0.5rem;">Speak to a Sales Engineer</h3>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; color:#a1a1aa; font-size:0.85rem; margin-bottom:2rem;">Bypass the digital pipeline and speak directly with our core manufacturing team.</p>
        
        <a href="tel:+919819153834" style="display:inline-block; font-size:clamp(1.6rem, 5vw, 3rem); font-weight:900; color:white; letter-spacing:0.05em; text-decoration:none; transition:color 0.3s ease; filter:drop-shadow(0 0 15px rgba(16,185,129,0.2));">
          +91 9819153834
        </a>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }

  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Hover states for nav buttons */
  #prevBtn:hover, #nextBtn:hover {
    background: rgba(16,185,129,0.15) !important;
    border-color: rgba(16,185,129,0.5) !important;
    box-shadow: 0 0 25px rgba(16,185,129,0.25) !important;
    transform: translateY(-50%) scale(1.1) !important;
  }

  /* Hover states for CTAs */
  #ctaPrimary:hover {
    box-shadow: 0 0 50px rgba(16,185,129,0.5) !important;
    transform: translateY(-2px) !important;
  }

  #ctaSecondary:hover {
    background: #10b981 !important;
    color: #050f09 !important;
    border-color: #10b981 !important;
  }

  /* CTA links inside slides */
  .project-slide a:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(16,185,129,0.4) !important;
  }

  /* Phone link hover */
  a[href^="tel:"]:hover {
    color: #34d399 !important;
  }

  /* Responsive arrow positioning */
  @media (max-width: 900px) {
    #prevBtn { left: 6px !important; width: 36px !important; height: 36px !important; }
    #nextBtn { right: 6px !important; width: 36px !important; height: 36px !important; }
    #prevBtn svg, #nextBtn svg { width: 14px !important; height: 14px !important; }
  }

  @media (min-width: 640px) {
    #ctaPrimary, #ctaSecondary {
      max-width: none !important;
      width: auto !important;
      padding: 0 2.5rem !important;
    }
    
    /* Side by side CTAs on desktop */
    #ctaPrimary { max-width: none !important; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('slidesTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const progressBar = document.getElementById('slideProgress');
    const dots = document.querySelectorAll('.slide-dot');
    
    if (!track || !prevBtn || !nextBtn) return;

    const totalSlides = 10;
    let currentSlide = 0;
    let autoTimer = null;
    const AUTO_INTERVAL = 7000; // 7 seconds

    function goToSlide(index) {
      // Wrap around
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;
      
      currentSlide = index;
      track.style.transform = `translateX(-${currentSlide * 100}%)`;
      
      // Update progress bar
      if (progressBar) {
        progressBar.style.width = `${((currentSlide + 1) / totalSlides) * 100}%`;
      }

      // Update dots
      dots.forEach((dot, i) => {
        if (i === currentSlide) {
          dot.style.width = '28px';
          dot.style.background = '#10b981';
          dot.style.borderColor = '#10b981';
          dot.style.boxShadow = '0 0 12px rgba(16,185,129,0.4)';
        } else {
          dot.style.width = '8px';
          dot.style.background = 'rgba(255,255,255,0.08)';
          dot.style.borderColor = 'rgba(255,255,255,0.1)';
          dot.style.boxShadow = 'none';
        }
      });
    }

    function nextSlide() {
      goToSlide(currentSlide + 1);
    }

    function prevSlide() {
      goToSlide(currentSlide - 1);
    }

    // Reset auto-timer on interaction
    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(nextSlide, AUTO_INTERVAL);
    }

    // Button clicks
    nextBtn.addEventListener('click', () => { nextSlide(); resetAuto(); });
    prevBtn.addEventListener('click', () => { prevSlide(); resetAuto(); });

    // Dot clicks
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        goToSlide(parseInt(dot.dataset.idx));
        resetAuto();
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { nextSlide(); resetAuto(); }
      if (e.key === 'ArrowLeft') { prevSlide(); resetAuto(); }
    });

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    
    track.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    track.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) { nextSlide(); } else { prevSlide(); }
        resetAuto();
      }
    }, { passive: true });

    // Start auto-rotation
    autoTimer = setInterval(nextSlide, AUTO_INTERVAL);

    // Pause on hover
    const tabletDevice = document.getElementById('tabletDevice');
    if (tabletDevice) {
      tabletDevice.addEventListener('mouseenter', () => clearInterval(autoTimer));
      tabletDevice.addEventListener('mouseleave', () => resetAuto());
    }
  });
</script>