---
import Layout from '../layouts/Layout.astro';

// Unified Product Data Engine for the Interactive Grid
const products = [
  // Scaffolding Systems
  {
    name: "Cuplock Scaffolding System",
    category: "scaffolding",
    image: "https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=600&auto=format&fit=crop",
    specs: ["Rapid locking mechanism", "High load-bearing capacity", "Galvanized for rust resistance"]
  },
  {
    name: "H-Frame Scaffolding System",
    category: "scaffolding",
    image: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=600&auto=format&fit=crop",
    specs: ["Ideal for masonry & painting", "Rigid cross-bracing", "Quick vertical stacking"]
  },
  {
    name: "APS Unit Scaffolding System",
    category: "scaffolding",
    image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=600&auto=format&fit=crop",
    specs: ["Advanced perimeter safety", "Modular configuration", "OSHA compliant framework"]
  },
  {
    name: "Aluminum Scaffolding & Jacks",
    category: "scaffolding",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=600&auto=format&fit=crop",
    specs: ["Lightweight maneuverability", "Non-corrosive alloy", "Caster wheels with dual locks"]
  },

  // Pipes & Props
  {
    name: "Scaffolding Pipes and Tubes",
    category: "pipes",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=600&auto=format&fit=crop",
    specs: ["48.3mm outer diameter", "High tensile steel grade", "Custom length availability"]
  },
  {
    name: "Vertical Scaffolding Pipes",
    category: "pipes",
    image: "https://images.unsplash.com/photo-1590644365607-1c5a39178125?q=80&w=600&auto=format&fit=crop",
    specs: ["Heavy wall thickness", "Seamless structural joints", "End-to-end welded joints"]
  },
  {
    name: "Telescopic Steel Props",
    category: "pipes",
    image: "https://images.unsplash.com/photo-1581092335397-9583eb92d232?q=80&w=600&auto=format&fit=crop",
    specs: ["Infinite height adjustment", "Self-cleaning heavy duty thread", "Solid base and head plates"]
  },
  {
    name: "Adjustable Beam Spans",
    category: "pipes",
    image: "https://images.unsplash.com/photo-1581092160607-ee22621dd758?q=80&w=600&auto=format&fit=crop",
    specs: ["Flexible sliding mechanics", "High bending strength", "Eliminates timber wastage"]
  },

  // Formwork
  {
    name: "Floor Form Adjusters",
    category: "formwork",
    image: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=600&auto=format&fit=crop",
    specs: ["Precision concrete leveling", "Heavy impact resistance", "Reusable structural steel"]
  },
  {
    name: "Floor Form Panels",
    category: "formwork",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=600&auto=format&fit=crop",
    specs: ["Uniform concrete finish", "Stiffened with MS angles", "Seamless interlocking edges"]
  },
  {
    name: "Shuttering Plates",
    category: "formwork",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=600&auto=format&fit=crop",
    specs: ["Optimal concrete retention", "14 Gauge thick steel", "Minimal concrete leakage"]
  },
  {
    name: "Centering Sheets",
    category: "formwork",
    image: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=600&auto=format&fit=crop",
    specs: ["Curved/flat adaptability", "Corrosion resistant coating", "Easy to strip and clean"]
  },
  {
    name: "Column Form Work",
    category: "formwork",
    image: "https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=600&auto=format&fit=crop",
    specs: ["Square and circular molds", "Integrated tie-rod holes", "High pour pressure rating"]
  },
  {
    name: "Climbing Walform Systems",
    category: "formwork",
    image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=600&auto=format&fit=crop",
    specs: ["Continuous vertical pours", "Crane-independent climbing", "Ultimate high-rise efficiency"]
  },

  // Hardware
  {
    name: "Drop Forged Couplers",
    category: "hardware",
    image: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=600&auto=format&fit=crop",
    specs: ["BS 1139 standard compliance", "Slip-resistant grip", "T-bolt mechanism"]
  },
  {
    name: "Pressed Couplers",
    category: "hardware",
    image: "https://images.unsplash.com/photo-1581092335397-9583eb92d232?q=80&w=600&auto=format&fit=crop",
    specs: ["Cost-effective jointing", "Zinc plated finish", "Swivel and fixed variants"]
  },
  {
    name: "Clamps and Nuts",
    category: "hardware",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=600&auto=format&fit=crop",
    specs: ["Heavy duty wing nuts", "Water barrier tie-rods", "Cast iron durability"]
  },
  {
    name: "Reinforcement Hardware",
    category: "hardware",
    image: "https://images.unsplash.com/photo-1590644365607-1c5a39178125?q=80&w=600&auto=format&fit=crop",
    specs: ["Rebar mechanical splices", "Threaded alignment studs", "High seismic resistance"]
  }
];
---

<Layout title="Vertex Products | Top Scaffolding & Formwork Systems in India">
  
  <main class="bg-[#050f09] min-h-screen">
    
    <!-- Hero Section -->
    <section class="relative pt-28 pb-16 border-b border-white/5 text-center overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-emerald-500/10 blur-[120px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_15px_rgba(52,211,153,0.1)]">
          Top Scaffolding Manufacturer in India
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black text-white uppercase tracking-tight mb-6">
          Product <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Catalogue</span>
        </h1>
        <p class="font-jakarta text-zinc-400 max-w-2xl mx-auto text-sm sm:text-base leading-relaxed font-medium">
          The best in India. Engineered for extreme loads and absolute safety. Explore our flagship structural nodes below, or filter through our complete industrial catalogue.
        </p>
      </div>
    </section>

    <!-- =========================================================================
         HERO PRODUCTS (DEEP DIVE SECTIONS)
         ========================================================================= -->

    <!-- Deep Dive: Ringlock -->
    <section class="py-20 sm:py-24 border-b border-white/5 relative overflow-hidden">
      <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[500px] h-[500px] bg-emerald-500/5 blur-[100px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          
          <div class="aspect-[4/3] rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] relative overflow-hidden group">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>
          </div>

          <div>
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Top Rated in India <br/><span class="text-emerald-400">Ringlock Scaffolding</span></h2>
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              Our flagship modular system offers maximum flexibility and heavy load-bearing capacity. Designed with precision-engineered connection nodes, it allows for rapid assembly of complex geometries while maintaining rigid structural integrity.
            </p>
            
            <div class="space-y-3 mb-10">
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Premium Materials</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">High-tensile, hot-dip galvanized steel engineered for extreme weather resistance and longevity.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Total Compliance</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Manufactured to strictly align with global OSHA mandates and BIS approved structural standards.</p>
                </div>
              </div>
            </div>

            <a href="/products/ringlock-scaffolding" class="relative group inline-flex h-14 items-center justify-center rounded-sm bg-white px-10 text-sm font-extrabold text-[#050f09] shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_25px_rgba(52,211,153,0.4)] hover:text-white transition-all duration-300 uppercase tracking-widest overflow-hidden z-10 w-full sm:w-auto">
              <span class="relative z-20 flex items-center gap-2">Learn More &rarr;</span>
              <div class="absolute inset-0 bg-emerald-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 z-10"></div>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- Deep Dive: Staircase Towers -->
    <section class="py-20 sm:py-24 border-b border-white/5 bg-[#0a170e] relative overflow-hidden">
      <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[500px] h-[500px] bg-emerald-500/5 blur-[100px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          
          <div class="order-2 lg:order-1">
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Best Heavy-Duty <br/><span class="text-emerald-400">Staircase Towers</span></h2>
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              Safe, high-capacity access solutions for multi-level construction and industrial sites. Our modular staircase towers are built to withstand heavy foot traffic and extreme environmental conditions without compromising stability.
            </p>
            
            <div class="space-y-3 mb-10">
              <div class="flex items-start gap-4 p-4 rounded-sm bg-[#050f09]/50 border border-white/5 hover:border-emerald-500/30 hover:bg-[#050f09] transition-colors duration-300 backdrop-blur-sm shadow-inner">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Extreme Load Ratings</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Engineered specifically to support high-density worker movement and heavy tool transport simultaneously.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4 p-4 rounded-sm bg-[#050f09]/50 border border-white/5 hover:border-emerald-500/30 hover:bg-[#050f09] transition-colors duration-300 backdrop-blur-sm shadow-inner">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Safety Integrated</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Features heavy-duty interlocking handrails and anti-slip tread surfaces to eliminate site hazard risks.</p>
                </div>
              </div>
            </div>

            <a href="/products/staircase-tower" class="relative group inline-flex h-14 items-center justify-center rounded-sm bg-white px-10 text-sm font-extrabold text-[#050f09] shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_25px_rgba(52,211,153,0.4)] hover:text-white transition-all duration-300 uppercase tracking-widest overflow-hidden z-10 w-full sm:w-auto">
              <span class="relative z-20 flex items-center gap-2">Learn More &rarr;</span>
              <div class="absolute inset-0 bg-emerald-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 z-10"></div>
            </a>
          </div>

          <div class="order-1 lg:order-2 aspect-[4/3] rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] relative overflow-hidden group">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1590644365607-1c5a39178125?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0"></div>
          </div>

        </div>
      </div>
    </section>

    <!-- Deep Dive: Walkway Planks -->
    <section class="py-20 sm:py-24 border-b border-white/5">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          
          <div class="aspect-[4/3] rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] relative overflow-hidden group">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1581092160607-ee22621dd758?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0"></div>
          </div>

          <div>
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Premium Industrial <br/><span class="text-emerald-400">Walkway Planks</span></h2>
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              The foundation of safe elevation. Our heavy-duty steel walkway planks are roll-formed for structural rigidity, providing workers with an unyielding, secure platform at any height.
            </p>
            
            <div class="space-y-3 mb-10">
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Maximum Surface Grip</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Aggressive punched, anti-slip surface matrix ensures superior boot traction even in wet or oily conditions.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Unwarping Durability</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Structural ribs designed to prevent bending and material fatigue under sustained heavy material storage.</p>
                </div>
              </div>
            </div>

            <a href="/products/walkway-planks" class="relative group inline-flex h-14 items-center justify-center rounded-sm bg-white px-10 text-sm font-extrabold text-[#050f09] shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_25px_rgba(52,211,153,0.4)] hover:text-white transition-all duration-300 uppercase tracking-widest overflow-hidden z-10 w-full sm:w-auto">
              <span class="relative z-20 flex items-center gap-2">Learn More &rarr;</span>
              <div class="absolute inset-0 bg-emerald-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 z-10"></div>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- =========================================================================
         FULL CATALOGUE (INTERACTIVE GRID)
         ========================================================================= -->
    <section class="py-20 bg-[#0a170e]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <h2 class="text-3xl font-black text-white uppercase tracking-tight mb-6">Complete Product <span class="text-emerald-400">Catalogue</span></h2>
          
          <!-- Interactive Quick Filters -->
          <div class="flex flex-wrap items-center justify-center gap-3">
            <button class="filter-btn active px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest bg-emerald-500 text-[#050f09] transition-all duration-300 shadow-[0_0_15px_rgba(16,185,129,0.3)]" data-filter="all">All Products</button>
            <button class="filter-btn px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest border border-white/10 text-zinc-300 hover:border-emerald-500/50 hover:text-emerald-400 transition-all duration-300" data-filter="scaffolding">Scaffolding</button>
            <button class="filter-btn px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest border border-white/10 text-zinc-300 hover:border-emerald-500/50 hover:text-emerald-400 transition-all duration-300" data-filter="formwork">Formwork</button>
            <button class="filter-btn px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest border border-white/10 text-zinc-300 hover:border-emerald-500/50 hover:text-emerald-400 transition-all duration-300" data-filter="pipes">Pipes & Props</button>
            <button class="filter-btn px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest border border-white/10 text-zinc-300 hover:border-emerald-500/50 hover:text-emerald-400 transition-all duration-300" data-filter="hardware">Hardware</button>
          </div>
        </div>

        <!-- The Interactive Grid -->
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 pb-16">
          
          {products.map((item) => (
            <div class="product-card group relative h-[380px] rounded-sm bg-[#050f09] border border-white/5 overflow-hidden shadow-lg transition-all duration-500" data-category={item.category}>
              
              <!-- Background Image -->
              <img src={item.image} alt={item.name} class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-110 group-hover:opacity-30 transition-all duration-700 ease-out" loading="lazy" />
              
              <!-- Default Bottom Title Bar -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6 transform transition-all duration-500 ease-in-out group-hover:translate-y-8 group-hover:opacity-0">
                <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest block mb-2">{item.category}</span>
                <h3 class="text-xl font-black text-white uppercase tracking-wide leading-tight">{item.name}</h3>
              </div>

              <!-- Hover State (Slides up from bottom) -->
              <div class="absolute top-full left-0 w-full h-full bg-[#050f09]/95 backdrop-blur-md p-8 flex flex-col transition-all duration-500 ease-in-out group-hover:top-0 border-t-4 border-emerald-500">
                
                <h3 class="text-lg font-black text-white uppercase tracking-wide mb-6 leading-tight line-clamp-2">{item.name}</h3>
                
                <ul class="space-y-3 mb-auto">
                  {item.specs.map((spec) => (
                    <li class="flex items-start gap-2">
                      <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      <span class="font-jakarta text-sm text-zinc-300 leading-snug">{spec}</span>
                    </li>
                  ))}
                </ul>

                <div class="flex flex-col gap-3 mt-6">
                  <a href="/contact-us" class="w-full bg-emerald-500 text-[#050f09] text-xs font-bold uppercase tracking-widest text-center py-3.5 rounded-sm hover:bg-white transition-colors shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                    Get in Touch
                  </a>
                  <a href="https://primesteeltech.co.in" target="_blank" rel="noopener noreferrer" class="w-full border border-emerald-500/30 text-emerald-400 text-xs font-bold uppercase tracking-widest text-center py-3.5 rounded-sm hover:bg-emerald-500/10 transition-colors">
                    Learn More &rarr;
                  </a>
                </div>

              </div>
            </div>
          ))}

        </div>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const productCards = document.querySelectorAll('.product-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset all buttons to inactive state
        filterBtns.forEach(b => {
            b.classList.remove('bg-emerald-500', 'text-[#050f09]', 'active', 'shadow-[0_0_15px_rgba(16,185,129,0.3)]');
            b.classList.add('border', 'border-white/10', 'text-zinc-300');
        });
        
        // Set clicked button to active state
        btn.classList.remove('border', 'border-white/10', 'text-zinc-300');
        btn.classList.add('bg-emerald-500', 'text-[#050f09]', 'active', 'shadow-[0_0_15px_rgba(16,185,129,0.3)]');

        const filterValue = btn.getAttribute('data-filter');

        // Filter the cards
        productCards.forEach(card => {
          if (filterValue === 'all' || card.getAttribute('data-category') === filterValue) {
            card.style.display = 'block';
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'scale(1)';
            }, 50);
          } else {
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(() => {
              card.style.display = 'none';
            }, 300); // Matches transition duration
          }
        });
      });
    });
  });
</script>