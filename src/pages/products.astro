---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ==========================================
// 1. FLAGSHIP IMPORTS (Options 1 & 2)
// ==========================================
import ringlockOpt1 from '../assets/products/Ringlock Option 1.jpeg';
import ringlockOpt2 from '../assets/products/Ringlock Option 2.jpeg';
import towerFeatured from '../assets/products/(updated) Staircase Tower.jpg';
import plankOpt1 from '../assets/products/Walkway Plank Option 1.jpeg';
import plankOpt2 from '../assets/products/(updated) Walkway Plank Option 2 .jpg';

// ==========================================
// 2. FULL CATALOGUE IMPORTS (19 Items)
// ==========================================
import anchorNut from '../assets/products/anchor-nut product.jpg';
import baseJack from '../assets/products/base-jack product.jpg';
import cuplock from '../assets/products/Cuplock product.jpg';
import doubleCoupler from '../assets/products/double coupler.jpg';
import expJointPin from '../assets/products/exp-joint-pin product.jpg';
import fixedBasePlate from '../assets/products/fixed-base-plate product.jpg';
import floorformPanels from '../assets/products/floorform-panels-highres product.jpg';
import girderCoupler from '../assets/products/girder-coupler.jpg';
import gratings from '../assets/products/gratings-highres product.jpg';
import hFrame from '../assets/products/h frame product.jpg';
import ringlockProd from '../assets/products/(updated) Ringlock product.png';
import sleeveCoupler from '../assets/products/sleeve coupler.png'; 
import staircaseProd from '../assets/products/staircase tower product.jpg';
import stirrupHead from '../assets/products/stirrup head.jpg';
import swivelCoupler from '../assets/products/swivel coupler.jpg';
import telescopicProp from '../assets/products/telescopic steel prop.jpg';
import tieRod from '../assets/products/tie-rod product.jpg';
import universalJack from '../assets/products/universal jack product.jpg';
import walkwayPlank from '../assets/products/walkway plank.jpg';

// Unified Product Data Engine for the Interactive Grid
const products = [
  // Scaffolding Systems
  {
    name: "Ringlock Scaffolding",
    category: "scaffolding",
    image: ringlockProd,
    specs: ["Multi-directional rosette nodes", "Up to 8 connections per node", "High load-bearing capacity"]
  },
  {
    name: "Cuplock Scaffolding",
    category: "scaffolding",
    image: cuplock,
    specs: ["Rapid locking mechanism", "Galvanized rust resistance", "Rigid node points"]
  },
  {
    name: "H-Frame Scaffolding",
    category: "scaffolding",
    image: hFrame,
    specs: ["Ideal for masonry & painting", "Rigid cross-bracing", "Quick vertical stacking"]
  },
  {
    name: "Walkway Planks",
    category: "scaffolding",
    image: walkwayPlank,
    specs: ["Punched anti-slip surface", "Roll-formed structural rigidity", "Heavy-duty load rating"]
  },
  {
    name: "Staircase Towers",
    category: "scaffolding",
    image: staircaseProd,
    specs: ["High-volume worker egress", "Interlocking stringers", "OSHA compliant landings"]
  },
  {
    name: "Industrial Gratings",
    category: "scaffolding",
    image: gratings,
    specs: ["Heavy impact resistance", "High drainage capability", "Non-slip serrated edge"]
  },

  // Pipes & Props
  {
    name: "Telescopic Steel Prop",
    category: "pipes",
    image: telescopicProp,
    specs: ["Infinite height adjustment", "Self-cleaning heavy duty thread", "Solid base and head plates"]
  },

  // Formwork
  {
    name: "Floorform Panels",
    category: "formwork",
    image: floorformPanels,
    specs: ["Uniform concrete finish", "Stiffened with MS angles", "Seamless interlocking edges"]
  },

  // Hardware
  {
    name: "Double Coupler",
    category: "hardware",
    image: doubleCoupler,
    specs: ["90-degree rigid connection", "BS 1139 standard compliance", "Slip-resistant grip"]
  },
  {
    name: "Swivel Coupler",
    category: "hardware",
    image: swivelCoupler,
    specs: ["360-degree rotation", "Connects bracing tubes", "Drop-forged durability"]
  },
  {
    name: "Girder Coupler",
    category: "hardware",
    image: girderCoupler,
    specs: ["Secures tubes to beams", "Heavy duty clamping", "Used in pairs"]
  },
  {
    name: "Sleeve Coupler",
    category: "hardware",
    image: sleeveCoupler,
    specs: ["End-to-end external connection", "Maintains tube alignment", "High tensile steel"]
  },
  {
    name: "Base Jack",
    category: "hardware",
    image: baseJack,
    specs: ["Leveling on uneven ground", "Heavy duty threaded rod", "Solid load distribution"]
  },
  {
    name: "Universal Jack",
    category: "hardware",
    image: universalJack,
    specs: ["Top and bottom application", "Fits multiple tube sizes", "Precision height control"]
  },
  {
    name: "Fixed Base Plate",
    category: "hardware",
    image: fixedBasePlate,
    specs: ["Spreads load evenly", "Welded central spigot", "Flat concrete placement"]
  },
  {
    name: "Stirrup Head",
    category: "hardware",
    image: stirrupHead,
    specs: ["Holds timber or steel beams", "U-head configuration", "Seamless height adjustment"]
  },
  {
    name: "Expansion Joint Pin",
    category: "hardware",
    image: expJointPin,
    specs: ["Internal end-to-end jointing", "Expanding core mechanism", "Perfect tube alignment"]
  },
  {
    name: "Tie-Rod Array",
    category: "hardware",
    image: tieRod,
    specs: ["High tensile formwork anchor", "Continuous threading", "Resists high pour pressure"]
  },
  {
    name: "Anchor Nut",
    category: "hardware",
    image: anchorNut,
    specs: ["Secures tie-rods tightly", "Wide load distribution", "Cast iron durability"]
  }
];
---

<Layout title="Vertex Products | Top Scaffolding & Formwork Systems in India">
  
  <main class="bg-[#050f09] min-h-screen">
    
    <!-- ==========================================
         HERO TITLE
         ========================================== -->
    <section class="relative pt-24 pb-12 text-center overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-emerald-500/10 blur-[120px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_15px_rgba(52,211,153,0.1)]">
          Top Scaffolding Manufacturer in India
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black text-white uppercase tracking-tight mb-4">
          Product <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Catalogue</span>
        </h1>
        <p class="font-jakarta text-zinc-400 max-w-2xl mx-auto text-sm sm:text-base leading-relaxed font-medium">
          The best in India. Engineered for extreme loads and absolute safety. 
        </p>
      </div>
    </section>

    <!-- ==========================================
         THE ACTION HUB & BUYER'S GUIDE (NEW)
         ========================================== -->
    <section class="pb-16 pt-2 border-b border-white/5 relative z-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="bg-[#0a170e] border border-emerald-500/30 rounded-xl p-8 sm:p-12 shadow-[0_0_50px_rgba(16,185,129,0.15)] relative overflow-hidden flex flex-col lg:flex-row items-center justify-between gap-10">
          
          <!-- Background Glow -->
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-64 h-64 bg-emerald-500/10 blur-[80px] pointer-events-none"></div>

          <!-- Left: Content -->
          <div class="text-center lg:text-left lg:max-w-xl relative z-10">
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-4">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              Official 2026 Edition
            </div>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white uppercase tracking-tight mb-4 leading-tight">
              The Vertex <span class="text-emerald-400">Buyer's Guide</span>
            </h2>
            <p class="font-jakarta text-sm sm:text-base text-zinc-300 leading-relaxed font-medium mb-0">
              Before configuring your logistics, download our comprehensive engineering document. Contains complete specifications, load-bearing matrices, material grades, and BIS/OSHA compliance data for all systems.
            </p>
          </div>

          <!-- Right: Action Buttons -->
          <div class="flex flex-col w-full lg:w-auto gap-4 relative z-10 shrink-0">
            
            <!-- Main Lead Magnet CTA -->
            <a href="/buyers-guide" class="w-full inline-flex h-14 items-center justify-center gap-2 rounded-sm bg-gradient-to-r from-emerald-500 to-teal-400 px-8 text-sm font-black text-[#050f09] shadow-[0_0_25px_rgba(16,185,129,0.3)] hover:shadow-[0_0_40px_rgba(16,185,129,0.5)] hover:-translate-y-0.5 transition-all duration-300 uppercase tracking-widest">
              <svg class="w-5 h-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download Guide
            </a>
            
            <!-- The 3 Requested Sub-CTAs -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              
              <a href="/quote" class="inline-flex h-12 items-center justify-center rounded-sm border border-emerald-500 bg-emerald-500/10 px-4 text-[10px] font-bold text-emerald-400 hover:bg-emerald-500 hover:text-[#050f09] transition-all uppercase tracking-widest text-center shadow-inner group relative">
                <span class="absolute top-1.5 right-1.5 flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                </span>
                Get Quote
              </a>
              
              <a href="/contact-us" class="inline-flex h-12 items-center justify-center rounded-sm border border-white/10 bg-[#050f09] px-4 text-[10px] font-bold text-zinc-300 hover:border-emerald-500/50 hover:bg-emerald-500/5 hover:text-emerald-400 transition-all uppercase tracking-widest text-center">
                Get In Touch
              </a>
              
              <a href="tel:+919819153834" class="inline-flex h-12 items-center justify-center rounded-sm border border-white/10 bg-[#050f09] px-4 text-[10px] font-bold text-zinc-300 hover:border-emerald-500/50 hover:bg-emerald-500/5 hover:text-emerald-400 transition-all uppercase tracking-widest text-center">
                Call Sales
              </a>

            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ==========================================
         FLAGSHIP SECTIONS
         ========================================== -->
    <section class="py-20 sm:py-24 border-b border-white/5 relative overflow-hidden bg-[#050f09]">
      <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[500px] h-[500px] bg-emerald-500/5 blur-[100px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-stretch">
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full">
            <div class="relative rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] overflow-hidden group min-h-[300px] sm:min-h-full">
              <Image src={ringlockOpt1} alt="Ringlock Option 1" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>
              <div class="absolute bottom-3 left-3 bg-[#050f09]/90 border border-emerald-500/50 px-3 py-1 text-[10px] font-bold text-emerald-400 uppercase tracking-widest rounded-sm backdrop-blur-sm z-20">Configuration 1</div>
            </div>
            <div class="relative rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] overflow-hidden group min-h-[300px] sm:min-h-full">
              <Image src={ringlockOpt2} alt="Ringlock Option 2" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>
              <div class="absolute bottom-3 left-3 bg-[#050f09]/90 border border-emerald-500/50 px-3 py-1 text-[10px] font-bold text-emerald-400 uppercase tracking-widest rounded-sm backdrop-blur-sm z-20">Configuration 2</div>
            </div>
          </div>

          <div class="flex flex-col justify-center">
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Top Rated in India <br/><span class="text-emerald-400">Ringlock Scaffolding</span></h2>
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              Our flagship modular system offers maximum flexibility and heavy load-bearing capacity. Designed with precision-engineered connection nodes, it allows for rapid assembly of complex geometries while maintaining rigid structural integrity.
            </p>
            
            <div class="space-y-3 mb-10">
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Premium Materials</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">High-tensile, hot-dip galvanized steel engineered for extreme weather resistance and longevity.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Total Compliance</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Manufactured to strictly align with global OSHA mandates and BIS approved structural standards.</p>
                </div>
              </div>
            </div>

            <a href="/products/ringlock-scaffolding" class="relative group inline-flex h-14 items-center justify-center rounded-sm bg-white px-10 text-sm font-extrabold text-[#050f09] shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_25px_rgba(52,211,153,0.4)] hover:text-white transition-all duration-300 uppercase tracking-widest overflow-hidden z-10 w-full sm:w-auto">
              <span class="relative z-20 flex items-center gap-2">Learn More &rarr;</span>
              <div class="absolute inset-0 bg-emerald-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 z-10"></div>
            </a>
          </div>

        </div>
      </div>
    </section>

    <section class="py-20 sm:py-24 border-b border-white/5 bg-[#0a170e] relative overflow-hidden">
      <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[500px] h-[500px] bg-emerald-500/5 blur-[100px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-stretch">
          
          <div class="order-2 lg:order-1 flex flex-col justify-center">
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Best Heavy-Duty <br/><span class="text-emerald-400">Staircase Towers</span></h2>
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              Safe, high-capacity access solutions for multi-level construction and industrial sites. Our modular staircase towers are built to withstand heavy foot traffic and extreme environmental conditions without compromising stability.
            </p>
            
            <div class="space-y-3 mb-10">
              <div class="flex items-start gap-4 p-4 rounded-sm bg-[#050f09]/50 border border-white/5 hover:border-emerald-500/30 hover:bg-[#050f09] transition-colors duration-300 backdrop-blur-sm shadow-inner">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Extreme Load Ratings</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Engineered specifically to support high-density worker movement and heavy tool transport simultaneously.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4 p-4 rounded-sm bg-[#050f09]/50 border border-white/5 hover:border-emerald-500/30 hover:bg-[#050f09] transition-colors duration-300 backdrop-blur-sm shadow-inner">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Safety Integrated</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Features heavy-duty interlocking handrails and anti-slip tread surfaces to eliminate site hazard risks.</p>
                </div>
              </div>
            </div>

            <a href="/products/staircase-tower" class="relative group inline-flex h-14 items-center justify-center rounded-sm bg-white px-10 text-sm font-extrabold text-[#050f09] shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_25px_rgba(52,211,153,0.4)] hover:text-white transition-all duration-300 uppercase tracking-widest overflow-hidden z-10 w-full sm:w-auto">
              <span class="relative z-20 flex items-center gap-2">Learn More &rarr;</span>
              <div class="absolute inset-0 bg-emerald-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 z-10"></div>
            </a>
          </div>

          <div class="order-1 lg:order-2 aspect-[4/3] rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] relative overflow-hidden group">
            <Image src={towerFeatured} alt="Staircase Tower Setup" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-20 sm:py-24 border-b border-white/5 bg-[#050f09]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-stretch">
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full">
            <div class="relative rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] overflow-hidden group min-h-[300px] sm:min-h-full">
              <Image src={plankOpt1} alt="Walkway Plank Option 1" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>
              <div class="absolute bottom-3 left-3 bg-[#050f09]/90 border border-emerald-500/50 px-3 py-1 text-[10px] font-bold text-emerald-400 uppercase tracking-widest rounded-sm backdrop-blur-sm z-20">Punched Matrix</div>
            </div>
            <div class="relative rounded-sm bg-zinc-900 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] overflow-hidden group min-h-[300px] sm:min-h-full">
              <Image src={plankOpt2} alt="Walkway Plank Option 2" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out z-0" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>
              <div class="absolute bottom-3 left-3 bg-[#050f09]/90 border border-emerald-500/50 px-3 py-1 text-[10px] font-bold text-emerald-400 uppercase tracking-widest rounded-sm backdrop-blur-sm z-20">Reinforced Ribbing</div>
            </div>
          </div>

          <div class="flex flex-col justify-center">
            <h2 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Premium Industrial <br/><span class="text-emerald-400">Walkway Planks</span></h2>
            <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed mb-8">
              The foundation of safe elevation. Our heavy-duty steel walkway planks are roll-formed for structural rigidity, providing workers with an unyielding, secure platform at any height.
            </p>
            
            <div class="space-y-3 mb-10">
              <div class="flex items-start gap-4 p-4 rounded-sm bg-white/5 border border-white/5 hover:border-emerald-500/30 hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm">
                <svg class="h-6 w-6 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/></svg>
                <div>
                  <h4 class="text-white text-sm font-bold uppercase tracking-wider mb-1">Maximum Surface Grip</h4>
                  <p class="font-jakarta text-xs text-zinc-400 leading-relaxed">Aggressive punched, anti-slip surface matrix ensures superior boot traction even in wet or oily conditions.</p>
                </div>
              </div>
              
