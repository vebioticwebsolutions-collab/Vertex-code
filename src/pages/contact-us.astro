---
import Layout from '../layouts/Layout.astro';

// ==========================================
// CONTACT PAGE SCHEMA (SEO/GEO)
// ==========================================
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Prime SteelTech India Pvt Ltd",
  "url": "https://primesteeltech.co.in/contact-us",
  "description": "Contact Prime SteelTech for custom engineering consultations, bulk scaffolding orders, or technical support.",
  "mainEntity": {
    "@type": "Organization",
    "name": "Prime SteelTech India Pvt Ltd",
    "telephone": "+91-9393161504",
    "email": "enquiry@primesteeltech.co.in",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Shop No. 6, 'B' Wing, Tuljai CHS LTD., Kasturba Cross Road No. 4, Borivali (E)",
      "addressLocality": "Mumbai",
      "postalCode": "400066",
      "addressRegion": "Maharashtra",
      "addressCountry": "IN"
    }
  }
};
---

<Layout title="Contact Us | Prime SteelTech India Pvt Ltd">
  
  <!-- INJECT STRUCTURED DATA FOR AI ENGINES -->
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <main class="bg-[#2b332a] min-h-screen pt-20 pb-16 sm:pt-24 sm:pb-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- =========================================================================
           HEADER SECTION (CLEAN "GET IN TOUCH" DESIGN)
           ========================================================================= -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">
          Get in <span class="text-emerald-500">Touch</span>
        </h1>
        <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed">
          Whether you need a custom engineering consultation, bulk order pricing, or technical support, our team is ready to assist.
        </p>
      </div>

      <!-- =========================================================================
           2. SPLIT CONTACT SECTION (Form + Details)
           ========================================================================= -->
      <section class="relative overflow-hidden">
        <div class="relative z-10">
          
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
            
            <!-- LEFT SIDE: Contact Information & Department Routing -->
            <div class="flex flex-col justify-center gap-6">
              <div class="bg-[#1e241d] border border-white/5 rounded-sm p-8 sm:p-10 shadow-xl relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/5 rounded-bl-full pointer-events-none"></div>
                
                <h2 class="text-xl font-bold text-white uppercase tracking-widest mb-8 border-b border-white/10 pb-4 relative z-10">Corporate Headquarters</h2>
                
                <div class="space-y-6 relative z-10">
                  
                  <!-- Location Data -->
                  <div class="group flex items-start gap-6">
                    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-sm bg-white/5 border border-white/10 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 transition-colors">
                      <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    </div>
                    <div>
                      <h4 class="text-white font-bold uppercase tracking-wider mb-2 text-sm">Manufacturing & Logistics Hub</h4>
                      <p class="font-jakarta text-zinc-400 text-sm leading-relaxed max-w-xs">
                        Shop No. 6, 'B' Wing, Tuljai CHS LTD., Kasturba Cross Road No. 4, Borivali (E), Mumbai- 400 066.
                      </p>
                    </div>
                  </div>

                  <!-- Phone Data + WhatsApp Button Integration -->
                  <div class="group flex items-start gap-6">
                    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-sm bg-white/5 border border-white/10 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 transition-colors">
                      <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    </div>
                    <div class="flex flex-col gap-2 w-full">
                      <h4 class="text-white font-bold uppercase tracking-wider text-sm">Direct Engineering Desk</h4>
                      <div class="font-jakarta text-zinc-400 text-sm flex flex-col gap-1">
                        <a href="tel:+919393161504" class="hover:text-emerald-400 transition-colors">+91 93931 61504</a>
                        <a href="tel:09324560020" class="hover:text-emerald-400 transition-colors">09324 560020</a>
                      </div>
                      
                      <!-- WhatsApp Integration Link -->
                      <a href="https://wa.me/919393161504" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 mt-2 bg-[#25D366]/10 border border-[#25D366]/30 hover:bg-[#25D366] hover:text-[#151914] text-[#25D366] text-xs font-bold uppercase tracking-widest py-2.5 px-4 rounded-sm transition-all duration-300 w-fit">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                        Chat with Sales
                      </a>
                    </div>
                  </div>

                  <!-- Email Data -->
                  <div class="group flex items-start gap-6">
                    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-sm bg-white/5 border border-white/10 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 transition-colors">
                      <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    </div>
                    <div>
                      <h4 class="text-white font-bold uppercase tracking-wider mb-2 text-sm">General Enquiries</h4>
                      <div class="font-jakarta text-zinc-400 text-sm flex flex-col gap-1">
                        <a href="mailto:enquiry@primesteeltech.co.in" class="hover:text-emerald-400 transition-colors">enquiry@primesteeltech.co.in</a>
                        <a href="mailto:primage@gmail.com" class="hover:text-emerald-400 transition-colors">primage@gmail.com</a>
                      </div>
                    </div>
                  </div>

                </div>
              </div>

              <!-- Department Routing Card -->
              <div class="bg-zinc-900/40 border border-white/5 rounded-sm p-6">
                <h3 class="text-white font-bold text-xs uppercase tracking-widest mb-4 border-b border-white/10 pb-3">Department Routing</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <span class="block text-[10px] text-zinc-500 font-bold uppercase tracking-wider">Sales & Quotes</span>
                    <a href="mailto:sales@primesteeltech.co.in" class="text-emerald-400 text-sm hover:text-emerald-300 transition-colors font-medium">sales@primesteeltech.co.in</a>
                  </div>
                  <div>
                    <span class="block text-[10px] text-zinc-500 font-bold uppercase tracking-wider">Logistics & Dispatch</span>
                    <a href="mailto:logistics@primesteeltech.co.in" class="text-zinc-400 text-sm hover:text-white transition-colors font-medium">logistics@primesteeltech.co.in</a>
                  </div>
                </div>
              </div>
            </div>

            <!-- RIGHT SIDE: B2B Contact Form (Fully Functional Web3Forms) -->
            <div class="bg-zinc-900/80 border border-white/10 rounded-sm p-8 sm:p-10 shadow-2xl backdrop-blur-sm relative">
              <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/10 rounded-bl-full pointer-events-none"></div>

              <h3 class="text-xl font-bold text-white uppercase tracking-wide mb-6">Submit Project Enquiry</h3>
              
              <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5 font-jakarta">
                
                <!-- Web3Forms Access Token Hook -->
                <input type="hidden" name="access_key" value="d76b36cb-212f-45d8-b736-05fbb0a68950">
                <!-- Antispam Honeypot Field -->
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label for="firstName" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">First Name</label>
                    <input type="text" id="firstName" name="first_name" class="w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 focus:bg-white/10 transition-colors" placeholder="John" required />
                  </div>
                  <div class="space-y-2">
                    <label for="lastName" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">Last Name</label>
                    <input type="text" id="lastName" name="last_name" class="w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 focus:bg-white/10 transition-colors" placeholder="Doe" required />
                  </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label for="company" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">Company Name</label>
                    <input type="text" id="company" name="company" class="w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 focus:bg-white/10 transition-colors" placeholder="BuildCorp Inc." required />
                  </div>
                  <div class="space-y-2">
                    <label for="phone" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">Phone Number</label>
                    <input type="tel" id="phone" name="phone" class="w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 focus:bg-white/10 transition-colors" placeholder="+91 98765 43210" required />
                  </div>
                </div>

                <div class="space-y-2">
                  <label for="email" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">Corporate Email</label>
                  <input type="email" id="email" name="email" class="w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 focus:bg-white/10 transition-colors" placeholder="john@buildcorp.com" required />
                </div>

                <div class="space-y-2 relative">
                  <label for="interest" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">Primary Interest</label>
                  <div class="relative">
                    <select id="interest" name="primary_interest" class="w-full bg-[#1e241d] border border-white/10 rounded-sm px-4 py-3 pr-10 text-white text-sm focus:outline-none focus:border-emerald-500 transition-colors appearance-none cursor-pointer">
                      <option value="ringlock">Ringlock Scaffolding</option>
                      <option value="towers">Staircase Towers</option>
                      <option value="planks">Walkway Planks</option>
                      <option value="quote">General Pricing Quote</option>
                      <option value="other">Other Inquiry</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-emerald-400">
                      <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                    </div>
                  </div>
                </div>

                <div class="space-y-2">
                  <label for="message" class="text-xs font-bold text-zinc-400 uppercase tracking-wider block">Project Details / Requirements</label>
                  <textarea id="message" name="project_details" rows="4" class="w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 focus:bg-white/10 transition-colors resize-none" placeholder="Please provide dimensions, load requirements, or specific logistics needs..."></textarea>
                </div>

                <button type="submit" class="w-full h-14 mt-4 flex items-center justify-center rounded-sm bg-emerald-500 px-8 text-sm font-extrabold text-[#2b332a] shadow-[0_0_20px_rgba(52,211,153,0.2)] hover:bg-white hover:scale-[1.02] transition-all duration-300 uppercase tracking-widest">
                  Submit Enquiry
                </button>
              </form>

            </div>

          </div>

          <!-- =========================================================================
               3. INDUSTRIAL MAP SECTION
               ========================================================================= -->
          <div class="bg-[#1e241d] border border-white/5 rounded-sm p-4 sm:p-6 shadow-xl mt-12">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-lg font-bold text-white uppercase tracking-widest">HQ Location Mapping</h2>
              <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 rounded-sm">Mumbai, MH</span>
            </div>
            
            <div class="w-full aspect-video md:aspect-[21/9] rounded-sm overflow-hidden bg-black border border-white/10 relative">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3768.175204481358!2d72.8576402!3d19.2202685!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be7b0d5cbe98c25%3A0xc0fb1d76326e5e8a!2sKasturba%20Cross%20Road%20No.%204%2C%20Borivali%20East%2C%20Mumbai%2C%20Maharashtra%20400066!5e0!3m2!1sen!2sin!4v1717660000000!5m2!1sen!2sin" 
                class="w-full h-full border-0 grayscale contrast-125 opacity-80 mix-blend-luminosity hover:mix-blend-normal hover:grayscale-0 hover:opacity-100 transition-all duration-700" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
          </div>

        </div>
      </section>

    </div>
  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  
  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
</style>