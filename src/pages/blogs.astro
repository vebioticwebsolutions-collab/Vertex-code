---
import Layout from '../layouts/Layout.astro';

// Placeholder Blog Database
const blogs = [
  {
    title: "Understanding OSHA Compliance in Modern Scaffolding",
    category: "Safety & Compliance",
    date: "August 12, 2026",
    readTime: "6 min read",
    excerpt: "A deep dive into the latest occupational safety mandates and how high-tensile Ringlock systems are engineered to prevent site accidents.",
    image: "https://images.unsplash.com/photo-1541888087850-255d61488c9f?q=80&w=800&auto=format&fit=crop",
    link: "/blogs/osha-compliance",
    trending: true // Tagged for the dynamic island
  },
  {
    title: "The Load-Bearing Superiority of Ringlock vs. Cuplock",
    category: "Ringlock Scaffolding",
    date: "July 28, 2026",
    readTime: "8 min read",
    excerpt: "Traditional cuplock systems are reaching their limits in tier-1 infrastructure. We analyze the kinetic energy absorption of the 8-hole rosette node.",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop",
    link: "/blogs/ringlock-superiority",
    trending: true
  },
  {
    title: "Anti-Slip Coefficients: Engineering the Perfect Walkway Plank",
    category: "Walkway Planks",
    date: "July 15, 2026",
    readTime: "5 min read",
    excerpt: "Why flat steel fails. Exploring the physics behind punched-matrix traction and continuous side ribs in heavy-duty industrial planks.",
    image: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=800&auto=format&fit=crop",
    link: "/blogs/plank-engineering",
    trending: true
  },
  {
    title: "Designing for Egress: Multi-Level Staircase Towers",
    category: "Staircase Towers",
    date: "June 30, 2026",
    readTime: "7 min read",
    excerpt: "Safe vertical access is critical. How our interlocking stringers and resting landings comply with complex worker fatigue regulations.",
    image: "https://images.unsplash.com/photo-1590644365607-1c5a39178125?q=80&w=800&auto=format&fit=crop",
    link: "/blogs/staircase-egress"
  },
  {
    title: "Corrosion Resistance: Hot-Dip Galvanization Explained",
    category: "Manufacturing",
    date: "June 10, 2026",
    readTime: "4 min read",
    excerpt: "Coastal construction destroys standard steel. Discover why Prime SteelTech mandates a minimum 80µm zinc coating across all structural components.",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=800&auto=format&fit=crop",
    link: "/blogs/corrosion-resistance"
  },
  {
    title: "Accelerating Erection Time by 30% with Modular Nodes",
    category: "Ringlock Scaffolding",
    date: "May 22, 2026",
    readTime: "6 min read",
    excerpt: "Time is money on a construction site. A case study on how eliminating loose fittings dramatically speeds up project deployment.",
    image: "https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=800&auto=format&fit=crop",
    link: "/blogs/erection-speed"
  }
];

const trendingBlogs = blogs.filter(blog => blog.trending);

// ==========================================
// BLOG LISTING SCHEMA (SEO/GEO)
// ==========================================
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Prime SteelTech Engineering Insights",
  "url": "https://primesteeltech.co.in/blogs",
  "description": "Technical insights, engineering studies, and safety compliance guides for heavy-duty scaffolding and formwork systems in India.",
  "publisher": {
    "@type": "Organization",
    "name": "Prime SteelTech India Pvt Ltd"
  },
  "blogPost": blogs.map(blog => ({
    "@type": "BlogPosting",
    "headline": blog.title,
    "abstract": blog.excerpt,
    "datePublished": new Date(blog.date).toISOString(),
    "url": `https://primesteeltech.co.in${blog.link}`,
    "image": blog.image,
    "articleSection": blog.category
  }))
};
---

<Layout title="Engineering Blogs | Prime SteelTech Insights">
  
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <main class="bg-[#2b332a] min-h-screen pt-24 pb-24">
    
    <section class="relative pb-12 border-b border-white/5 text-center overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[200px] bg-emerald-500/10 blur-[100px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-col items-center">
        
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white uppercase tracking-tight mb-8">
          Industrial <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Knowledge Hub</span>
        </h1>
        
        <div class="relative w-full max-w-3xl min-h-[80px] bg-black/40 border border-emerald-500/30 rounded-[2rem] shadow-[0_0_30px_rgba(16,185,129,0.15)] backdrop-blur-md flex items-center px-6 sm:px-8 py-4 overflow-hidden group">
          
          <div class="flex flex-col items-center justify-center shrink-0 border-r border-white/10 pr-4 sm:pr-6 mr-4 sm:mr-6 h-full">
            <span class="relative flex h-2 w-2 mb-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest hidden sm:block">Trending</span>
          </div>

          <div class="relative flex-grow h-full w-full min-h-[44px]" id="dynamic-island-container">
            {trendingBlogs.map((blog, index) => (
              <a href={blog.link} class={`absolute inset-0 flex flex-col justify-center w-full island-item transition-all duration-500 ease-in-out ${index === 0 ? 'opacity-100 translate-y-0 z-10' : 'opacity-0 translate-y-4 z-0 pointer-events-none'}`}>
                
                <div class="flex items-center justify-between gap-4 mb-1.5">
                  <span class="text-sm sm:text-base font-bold text-white uppercase tracking-wide truncate group-hover:text-emerald-400 transition-colors">
                    {blog.title}
                  </span>
                  <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest shrink-0 hidden md:block group-hover:translate-x-1 transition-transform">
                    Read &rarr;
                  </span>
                </div>
                
                <div class="flex items-center gap-3 text-xs text-zinc-400 font-jakarta truncate text-left">
                  <span class="font-bold text-zinc-500 uppercase tracking-wider text-[10px] shrink-0 bg-white/5 px-2 py-0.5 rounded-sm">{blog.category}</span>
                  <span class="truncate">{blog.excerpt}</span>
                </div>
                
              </a>
            ))}
          </div>

        </div>

      </div>
    </section>

    <section class="py-12 relative z-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6">
          <h2 class="text-xl font-black text-white uppercase tracking-tight">Latest <span class="text-emerald-400">Releases</span></h2>
          
          <div class="flex flex-wrap gap-2">
            <button class="filter-btn active px-4 py-2 rounded-full bg-emerald-500 text-[#2b332a] text-[10px] font-bold uppercase tracking-widest transition-colors shadow-md" data-filter="all">All Specs</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white hover:bg-white/10 text-[10px] font-bold uppercase tracking-widest transition-colors" data-filter="Ringlock Scaffolding">Ringlock</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white hover:bg-white/10 text-[10px] font-bold uppercase tracking-widest transition-colors" data-filter="Staircase Towers">Towers</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white hover:bg-white/10 text-[10px] font-bold uppercase tracking-widest transition-colors" data-filter="Walkway Planks">Planks</button>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {blogs.map((blog) => (
            <a href={blog.link} class="blog-card group flex flex-col bg-[#1e241d] border border-white/5 rounded-sm overflow-hidden hover:border-emerald-500/50 hover:shadow-[0_10px_30px_rgba(0,0,0,0.5)] hover:-translate-y-1 transition-all duration-300" data-category={blog.category}>
              
              <div class="aspect-video relative overflow-hidden bg-zinc-900">
                <div class={`absolute inset-0 bg-[url('${blog.image}')] bg-cover bg-center opacity-70 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out`}></div>
                <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm border border-white/10 px-3 py-1 rounded-sm text-[9px] font-bold text-white uppercase tracking-widest z-10">
                  {blog.readTime}
                </div>
              </div>
              
              <div class="p-6 sm:p-8 flex-grow flex flex-col">
                <div class="flex items-center gap-2 text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-4">
                  <span>&bull;</span>
                  <span>{blog.category}</span>
                </div>
                
                <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-3 group-hover:text-emerald-400 transition-colors leading-snug">
                  {blog.title}
                </h3>
                
                <p class="font-jakarta text-zinc-400 text-xs leading-relaxed mb-6 flex-grow">
                  {blog.excerpt}
                </p>
                
                <div class="flex items-center justify-between border-t border-white/10 pt-4 mt-auto">
                  <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">{blog.date}</span>
                  <span class="text-[10px] font-bold text-white uppercase tracking-widest group-hover:text-emerald-400 group-hover:translate-x-1 transition-all">Read Spec &rarr;</span>
                </div>
              </div>
              
            </a>
          ))}
        </div>

      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  
  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  
  .filter-btn.active {
    background-color: #10b981; /* emerald-500 */
    color: #2b332a;
    border-color: #10b981;
  }
</style>

<script>
  // ==========================================
  // 1. DYNAMIC ISLAND ROTATION LOGIC (UPDATED TO 8 SECONDS)
  // ==========================================
  const islandItems = document.querySelectorAll('.island-item');
  let currentIndex = 0;

  if (islandItems.length > 1) {
    setInterval(() => {
      // Hide current
      islandItems[currentIndex].classList.remove('opacity-100', 'translate-y-0', 'z-10');
      islandItems[currentIndex].classList.add('opacity-0', '-translate-y-4', 'z-0', 'pointer-events-none');

      // Update index
      currentIndex = (currentIndex + 1) % islandItems.length;

      // Reset the incoming item from the bottom instantly
      islandItems[currentIndex].classList.remove('-translate-y-4');
      islandItems[currentIndex].classList.add('translate-y-4', 'transition-none');
      
      // Small timeout to allow the transition-none to apply, then animate it in
      setTimeout(() => {
        islandItems[currentIndex].classList.remove('transition-none', 'translate-y-4', 'opacity-0', 'pointer-events-none');
        islandItems[currentIndex].classList.add('opacity-100', 'translate-y-0', 'z-10');
      }, 50);

    }, 8000); // Rotates every 8 seconds for comfortable reading
  }

  // ==========================================
  // 2. CLIENT-SIDE FILTERING LOGIC
  // ==========================================
  const filterBtns = document.querySelectorAll('.filter-btn');
  const blogCards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active class from all buttons
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-emerald-500', 'text-[#2b332a]');
        b.classList.add('bg-white/5', 'text-white');
      });

      // Add active class to clicked button
      btn.classList.remove('bg-white/5', 'text-white');
      btn.classList.add('active', 'bg-emerald-500', 'text-[#2b332a]');

      // Filter the cards
      const targetCategory = btn.getAttribute('data-filter');

      blogCards.forEach(card => {
        const htmlCard = card as HTMLElement;
        const cardCategory = htmlCard.getAttribute('data-category');

        if (targetCategory === 'all' || cardCategory === targetCategory) {
          htmlCard.style.display = 'flex';
          htmlCard.style.opacity = '0';
          setTimeout(() => htmlCard.style.opacity = '1', 50);
        } else {
          htmlCard.style.display = 'none';
        }
      });
    });
  });
</script>