---
import Layout from '../layouts/Layout.astro';
import { faqs } from '../data/faqData.js';

// Derive category list + counts dynamically from the data, in a fixed display order
const categoryOrder = [
  "Ringlock Scaffolding",
  "Walkway Planks",
  "Staircase Towers",
  "Logistics & Pricing",
  "Safety & Compliance",
  "Engineering & Technical",
  "Formwork",
  "Materials & Maintenance",
  "General Scaffolding & Formwork"
];

const categories = categoryOrder
  .filter((cat) => faqs.some((f) => f.category === cat))
  .map((cat) => ({
    name: cat,
    count: faqs.filter((f) => f.category === cat).length
  }));

// Slugify helper for stable per-FAQ anchor IDs (useful for deep-linking + crawlability)
function slugify(text) {
  return text
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .slice(0, 60);
}

// FAQPage JSON-LD structured data — this is what allows Google / AI engines
// to surface individual Q&A pairs directly in search results and AI answers.
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout title="Scaffolding & Formwork FAQ | PrimeSteel Tech Engineering Support">

  <!-- FAQPage structured data for SEO + GEO (AI Overviews, ChatGPT, Perplexity, etc.) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="bg-[#2b332a] min-h-screen pt-20 pb-24">

    <section class="relative pt-16 sm:pt-24 pb-12 border-b border-white/5 text-center overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-emerald-500/10 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 px-4 py-2 text-[11px] font-semibold text-emerald-400 uppercase tracking-widest mb-6 shadow-[0_0_15px_rgba(52,211,153,0.1)]">
          Knowledge Base · {faqs.length} Answers
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight mb-6">
          How can we <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">help you?</span>
        </h1>
        <p class="font-jakarta text-zinc-300 text-sm sm:text-base leading-relaxed font-medium mb-10">
          Type your keywords below to instantly filter our engineering database.
        </p>

        <div class="relative max-w-2xl mx-auto group">
          <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-emerald-500 group-focus-within:text-emerald-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <input
            type="text"
            id="faq-search"
            class="block w-full pl-12 pr-4 py-5 bg-zinc-900/80 border border-white/10 rounded-sm text-white font-jakarta text-sm sm:text-base placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 shadow-2xl backdrop-blur-md transition-all"
            placeholder="Search for 'load capacity', 'shipping', 'OSHA'..."
            autocomplete="off"
          />
        </div>
      </div>
    </section>

    <!-- CATEGORY FILTER PILLS -->
    <section class="pt-10 pb-2 relative z-10">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div id="category-pills" class="flex flex-wrap justify-center gap-2 sm:gap-3">
          <button
            type="button"
            class="category-pill active-pill px-4 py-2 rounded-full text-[11px] sm:text-xs font-bold uppercase tracking-widest border transition-all bg-emerald-500 border-emerald-500 text-[#1a2419]"
            data-category="all"
          >
            All <span class="opacity-70 font-semibold">({faqs.length})</span>
          </button>
          {categories.map((cat) => (
            <button
              type="button"
              class="category-pill px-4 py-2 rounded-full text-[11px] sm:text-xs font-bold uppercase tracking-widest border border-white/10 bg-white/5 text-zinc-300 hover:border-emerald-500/40 hover:text-emerald-300 transition-all"
              data-category={cat.name}
            >
              {cat.name} <span class="opacity-70 font-semibold">({cat.count})</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <section class="py-10 relative z-10">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

        <div id="result-count" class="text-center text-zinc-500 text-xs font-jakarta font-medium uppercase tracking-widest mb-6">
          Showing all {faqs.length} answers
        </div>

        <div id="no-results" class="hidden text-center py-12 bg-white/5 border border-white/10 rounded-sm">
          <svg class="h-12 w-12 text-zinc-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2">No matching answers found</h3>
          <p class="font-jakarta text-zinc-400 text-sm mb-6">Our system couldn't find an exact match for your search.</p>
          <a href="/contact-us" class="inline-flex h-10 items-center justify-center rounded-sm bg-emerald-500 px-6 text-xs font-extrabold text-[#2b332a] shadow-md hover:bg-white transition-all uppercase tracking-widest">
            Contact Engineering Support
          </a>
        </div>

        <div id="faq-container" class="space-y-4">
          {faqs.map((faq, index) => {
            const slug = slugify(faq.question);
            return (
              <div
                class="faq-item group bg-zinc-900/50 border border-white/10 rounded-sm overflow-hidden transition-all duration-300 hover:border-emerald-500/30"
                data-category={faq.category}
                id={`faq-${slug}`}
              >

                <button
                  class="faq-toggle w-full flex items-center justify-between p-5 sm:p-6 text-left focus:outline-none"
                  aria-expanded="false"
                >
                  <div class="pr-8">
                    <span class="block text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-1">{faq.category}</span>
                    <h2 class="text-sm sm:text-base font-bold text-white uppercase tracking-wide group-hover:text-emerald-300 transition-colors">{faq.question}</h2>
                  </div>
                  <div class="shrink-0 h-8 w-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors">
                    <svg class="icon-plus h-4 w-4 text-emerald-400 block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    <svg class="icon-minus h-4 w-4 text-emerald-400 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
                  </div>
                </button>

                <div class="faq-answer hidden px-5 sm:px-6 pb-6 pt-2">
                  <div class="h-px w-full bg-white/5 mb-4"></div>
                  <p class="font-jakarta text-zinc-300 text-sm leading-relaxed border-l-2 border-emerald-500 pl-4">
                    {faq.answer}
                  </p>
                </div>

                <span class="search-data hidden">{faq.question.toLowerCase()} {faq.answer.toLowerCase()} {faq.category.toLowerCase()}</span>
              </div>
            );
          })}
        </div>

      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
</style>

<script>
  // 1. ACCORDION LOGIC
  const toggles = document.querySelectorAll('.faq-toggle');

  toggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const answer = toggle.nextElementSibling;
      const iconPlus = toggle.querySelector('.icon-plus');
      const iconMinus = toggle.querySelector('.icon-minus');
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';

      // Close all other open FAQs
      document.querySelectorAll('.faq-answer').forEach(ans => {
        if (ans !== answer) {
          ans.classList.add('hidden');
          if (ans.previousElementSibling) {
             ans.previousElementSibling.setAttribute('aria-expanded', 'false');
             ans.previousElementSibling.querySelector('.icon-plus')?.classList.remove('hidden');
             ans.previousElementSibling.querySelector('.icon-minus')?.classList.add('hidden');
          }
        }
      });

      // Toggle current FAQ
      if (!isExpanded) {
        answer?.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        iconPlus?.classList.add('hidden');
        iconMinus?.classList.remove('hidden');
      } else {
        answer?.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        iconPlus?.classList.remove('hidden');
        iconMinus?.classList.add('hidden');
      }
    });
  });

  // 2. LIVE SEARCH + CATEGORY FILTER LOGIC (combined)
  const searchInput = document.getElementById('faq-search') as HTMLInputElement;
  const faqItems = document.querySelectorAll<HTMLElement>('.faq-item');
  const noResultsDiv = document.getElementById('no-results');
  const resultCountDiv = document.getElementById('result-count');
  const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');

  let activeCategory = 'all';

  function applyFilters() {
    const searchTerm = (searchInput?.value || '').toLowerCase().trim();
    let visibleCount = 0;

    faqItems.forEach(item => {
      const searchData = item.querySelector('.search-data')?.textContent || '';
      const itemCategory = item.getAttribute('data-category') || '';

      const matchesSearch = searchTerm === '' || searchData.includes(searchTerm);
      const matchesCategory = activeCategory === 'all' || itemCategory === activeCategory;

      if (matchesSearch && matchesCategory) {
        item.style.display = 'block';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    if (resultCountDiv) {
      if (searchTerm === '' && activeCategory === 'all') {
        resultCountDiv.textContent = `Showing all ${faqItems.length} answers`;
      } else {
        resultCountDiv.textContent = `Showing ${visibleCount} of ${faqItems.length} answers`;
      }
    }

    if (visibleCount === 0) {
      noResultsDiv?.classList.remove('hidden');
    } else {
      noResultsDiv?.classList.add('hidden');
    }
  }

  searchInput?.addEventListener('input', applyFilters);

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      activeCategory = pill.getAttribute('data-category') || 'all';

      // Update active pill styling
      pills.forEach(p => {
        p.classList.remove('active-pill', 'bg-emerald-500', 'border-emerald-500', 'text-[#1a2419]');
        p.classList.add('bg-white/5', 'border-white/10', 'text-zinc-300');
      });
      pill.classList.add('active-pill', 'bg-emerald-500', 'border-emerald-500', 'text-[#1a2419]');
      pill.classList.remove('bg-white/5', 'border-white/10', 'text-zinc-300');

      applyFilters();
    });
  });
</script>
