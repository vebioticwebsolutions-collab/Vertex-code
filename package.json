{
  "name": "vertex-code",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npm run build:worker",
    "build:worker": "esbuild src/worker/index.js --bundle --platform=node --format=esm --packages=external --outfile=dist/worker/index.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "start": "node ./dist/server/entry.mjs",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "bullmq": "^5.79.1",
    "docxtemplater": "^3.69.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "pizzip": "^3.2.0",
    "postgres": "^3.4.9",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1"
  }
}
